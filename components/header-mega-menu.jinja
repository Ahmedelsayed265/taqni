<div class="dark d-none d-lg-block" style="position: relative">
    <div class="top-main-menu-wrapper">
        <nav role="navigation" class="d-flex flex-grow-1 main-nav-wrapper">
            <ul class="main-nav d-flex flex-grow-1 flex-wrap menu-header-theme-text-for-primary-bg">

                {% if settings.shop_mega_menu_display_shop or settings.shop_mega_menu_display_shop is none %}
                <li class="top-level-link shop-mega-menu-item">
                    <a href="{{ settings.shop_mega_menu_shop_url or '#' }}" class="mega-menu">
                        <span>{{ settings.shop_mega_menu_shop_label or 'Shop' }}</span>
                    </a>
                    <div class="sub-menu-block mega-menu-wide">
                        <div class="row">
                            <!-- Link Columns (2 Columns as requested) -->
                            <div class="col-lg-6">
                                <div class="row">
                                    <!-- Column 1 -->
                                    <div class="col-lg-6">
                                        <ul class="sub-menu-lists" style="list-style: none; padding: 0;">
                                            {% if settings.shop_mega_menu_links1 and settings.shop_mega_menu_links1 | length > 0 %}
                                                {% for link in settings.shop_mega_menu_links1 %}
                                                <li style="margin-bottom: 15px;"><a href="{{ link.url or '#' }}" style="color: #444; text-decoration: none; font-size: 16px; transition: color 0.3s; line-height: 1.6; font-weight: 500;">{{ link.text }}</a></li>
                                                {% endfor %}
                                            {% endif %}
                                        </ul>
                                    </div>
                                    <!-- Column 2 -->
                                    <div class="col-lg-6">
                                        <ul class="sub-menu-lists" style="list-style: none; padding: 0;">
                                            {% if settings.shop_mega_menu_links2 and settings.shop_mega_menu_links2 | length > 0 %}
                                                {% for link in settings.shop_mega_menu_links2 %}
                                                <li style="margin-bottom: 15px;"><a href="{{ link.url or '#' }}" style="color: #444; text-decoration: none; font-size: 16px; transition: color 0.3s; line-height: 1.6; font-weight: 500;">{{ link.text }}</a></li>
                                                {% endfor %}
                                            {% endif %}
                                        </ul>
                                    </div>
                                </div>
                            </div>

                            <!-- Promo Items Section -->
                            <div class="col-lg-6">
                                <div class="promo-items-wrapper d-flex gap-3" style="justify-content: flex-end;">
                                    {% if settings.shop_mega_menu_promo_items and settings.shop_mega_menu_promo_items | length > 0 %}
                                        {% for promo in settings.shop_mega_menu_promo_items %}
                                        <div class="promo-item" style="flex: 1;">
                                            <a href="{{ promo.url or '#' }}" style="text-decoration: none; display: block; color: inherit;">
                                                <div class="promo-img-wrapper" style="border-radius: 8px; overflow: hidden; margin-bottom: 8px; aspect-ratio: 1/1;">
                                                    <img src="{{ image_url(promo.image, w=250, h=250) }}" alt="{{ promo.title }}" style="width: 100%; height: 100%; object-fit: cover;">
                                                </div>
                                                <h6 style="font-weight: 600; margin: 0; font-size: 14px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: #333;">{{ promo.title }}</h6>
                                                <p style="text-decoration: underline; font-size: 12px; margin-top: 3px; font-weight: 600; color: #000;">{{ promo.subtitle }}</p>
                                            </a>
                                        </div>
                                        {% endfor %}
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </div>
                </li>
                {% endif %}

                {% for menu in store.settings.menus.main_menu.items %}
                {% if menu.url %}
                <li class="top-level-link {% if safeget(menu, " url")=='/c/' or safeget(menu, "url" )=='/categories/' %}
                    all-categories {% endif %}">
                    <a href="{{ menu.url }}" {% if menu.items | length> 0 %} class="mega-menu" {% endif %} ><span>{{
                            menu.label }}</span></a>
                    {% if menu.items | length > 0 %}
                    <div class="sub-menu-block">
                        <div class="row">
                            {% for menu_sub in menu.items %}
                            <div class="col-md-4 col-lg-4 col-sm-4">
                                {% if menu_sub.items | length > 0 %}
                                <h5 class="sub-menu-head">
                                    <a style="font-size: 1.16rem; color: inherit" href="{{ menu_sub.url }}">{{
                                        menu_sub.label }}</a>
                                </h5>
                                <ul class="sub-menu-lists">
                                    {% for menu_sub_sub in menu_sub.items %}
                                    <li><a href="{{ menu_sub_sub.url }}">{{ menu_sub_sub.label }}</a></li>
                                    {% endfor %}
                                </ul>
                                {% else %}
                                <h2 class="sub-menu-head"><a style="font-size: 1.16rem; color: inherit"
                                        href="{{ menu_sub.url }}">{{ menu_sub.label }}</a></h2>
                                {% endif %}
                            </div>
                            {% endfor %}
                        </div>
                    </div>
                    {% endif %}
                </li>
                {% endif %}
                {% endfor %}
            </ul>
        </nav>
    </div>
</div>