{% if product %}
<article class="outlit-product-card product-item {% if product.is_infinite == false and product.quantity <= 0 %}outlit-product-card--out-of-stock{% endif %}" itemscope itemtype="https://schema.org/Product">
  <div class="outlit-product-card__img-wrap">
    <a href="/products/{{ product.slug }}" class="outlit-product-card__img-link" aria-label="{{ product.name }}">
      <div class="outlit-product-card__img-inner">
        {% set main_image = product.main_image.image.small if product.main_image else product.image.small %}
        {% if main_image %}
          <img id="product-card-img-{{ product.id }}" class="outlit-product-card__img" 
               src="{{ main_image }}" loading="lazy" decoding="async" alt="{{ product.name }}">
        {% else %}
          <img id="product-card-img-{{ product.id }}" class="outlit-product-card__img" 
               src="{{ image_url(('product-img.svg' | asset_url), w=235, q=100) }}" loading="lazy" decoding="async" alt="{{ product.name }}">
        {% endif %}
      </div>
    </a>

    {# Badges #}
    {% if product.badge %}
      {% set positionProductCard = true %}
      {% include 'vitrin:products/badge.jinja' %}
    {% endif %}

    {# Wishlist #}
    {% if store.settings.products.wishlist_enabled %}
      <div class="outlit-product-card__wishlist">
        <span zid-visible-customer="true">
          <button type="button" zid-visible-wishlist="{{ product.id }}" class="outlit-product-card__wishlist-btn icon-heart-mask filled" onclick="addToWishlist(this, '{{ product.id }}')"></button>
          <button type="button" zid-hidden-wishlist="{{ product.id }}" class="outlit-product-card__wishlist-btn icon-heart-mask" onclick="addToWishlist(this, '{{ product.id }}')"></button>
        </span>
        <a zid-visible-guest="true" class="outlit-product-card__wishlist-btn icon-heart-mask" href="/auth/login?redirect_to={{ session.url.path }}" onclick="event.preventDefault(); handleLoginAction('', false); return false;"></a>
      </div>
    {% endif %}
  </div>

  <div class="outlit-product-card__body">
    <div class="outlit-product-card__info">
      {% set cat = product.categories[-1] if product.categories|length > 0 else product.category %}
      {% if cat %}
        <p class="outlit-product-card__category">{{ cat.name }}</p>
      {% endif %}

      <h3 class="outlit-product-card__title">
        <a href="/products/{{ product.slug }}">{{ product.name | safe }}</a>
      </h3>
    </div>

    <div class="outlit-product-card__footer">
      <div class="outlit-product-card__price-wrap">
        {% if product.formatted_sale_price %}
          <span class="price-current">{{ product.formatted_sale_price }}</span>
          <span class="price-old">{{ product.formatted_price }}</span>
        {% else %}
          <span class="price-current">{{ product.formatted_price }}</span>
        {% endif %}
      </div>

      <div class="outlit-product-card__actions">
        {% if product.is_infinite or product.quantity > 0 %}
          {% if product.has_options or product.has_fields or product.product_class == 'dynamic_bundle' %}
            <a href="/products/{{ product.slug }}" class="outlit-product-card__cart-btn" aria-label="{{ _('Select Options') }}">
               <svg width="20" height="20" viewBox="0 0 29 26" fill="none" xmlns="http://www.w3.org/2000/svg">
