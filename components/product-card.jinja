               </svg>
            </a>
          {% else %}
            <div class="outlit-product-card__ajax-cart" data-product-id="{{ product.id }}">
              <button type="button" class="outlit-product-card__cart-btn outlit-product-card__add-btn-ajax" onclick="event.preventDefault(); event.stopPropagation(); productCartAddToCart(this, '{{ product.id }}')">
                <span class="cart-btn-icon">
                  <svg width="20" height="20" viewBox="0 0 29 26" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path fill-rule="evenodd" clip-rule="evenodd" d="M10.7506 0.599789C10.9719 0.0939456 11.5611 -0.136899 12.067 0.0841639C12.573 0.30553 12.804 0.895567 12.5826 1.40155L7.9166 12.0676C7.69524 12.5735 7.10518 12.8045 6.59921 12.5832C6.09323 12.3618 5.86222 11.7718 6.08359 11.2658L7.22031 8.66717L3.40488 8.66717C2.9745 8.66717 2.70201 8.6669 2.49765 8.68084C2.29838 8.69445 2.25351 8.716 2.25351 8.716C2.09733 8.78491 2.06193 8.84611 2.04941 8.86932C2.02771 8.90966 1.99623 9.00048 1.9996 9.18768C2.00305 9.37741 2.04028 9.60597 2.10312 9.8869C2.12141 9.96867 2.15161 10.0934 2.18417 10.2277C2.21343 10.3484 2.24481 10.477 2.27109 10.59C3.24182 11.1057 3.93773 12.0256 4.12851 13.1115L4.91855 17.6105C4.98489 17.9883 5.03938 18.3609 5.09335 18.7306C5.19696 19.4405 5.29962 20.1416 5.483 20.8556C5.75284 21.9061 6.14404 22.7098 6.76035 23.2062C7.19342 23.5501 7.76216 23.7649 8.74082 23.8801C9.74488 23.9982 11.0517 24.0002 12.9098 24.0002L15.6666 24.0002C16.2188 24.0003 16.6666 24.448 16.6666 25.0002C16.6666 25.5524 16.2188 26.0001 15.6666 26.0002L12.8463 26.0002C11.0663 26.0002 9.64199 25.9999 8.50742 25.8664C7.33593 25.7285 6.35169 25.4378 5.5123 24.7697L5.50839 24.7668C4.39099 23.8684 3.85542 22.5602 3.5455 21.3537C3.3365 20.54 3.20427 19.641 3.0914 18.8742C3.04174 18.5368 2.99584 18.225 2.94882 17.9572L2.15878 13.4572C2.07572 12.985 1.75473 12.5552 1.2623 12.3215C0.807924 12.1059 0.461383 11.691 0.35312 11.1779C0.320066 11.0211 0.291657 10.9061 0.25937 10.7765C0.229041 10.6548 0.194827 10.5195 0.150972 10.3234C0.0791342 10.0022 0.00771242 9.61736 0.000581056 9.22381C-0.00656897 8.82745 0.0501743 8.3636 0.28769 7.92205C0.534603 7.46314 0.929996 7.11383 1.44687 6.88592C1.75417 6.75043 2.06855 6.70574 2.36191 6.68573C2.64262 6.66659 2.98438 6.66716 3.37363 6.66717L8.09531 6.66717L10.7506 0.599789ZM22.9996 14.6672C23.5519 14.6672 23.9996 15.1149 23.9996 15.6672V19.3332H27.6666C28.2187 19.3333 28.6665 19.7811 28.6666 20.3332C28.6666 20.8854 28.2188 21.3331 27.666