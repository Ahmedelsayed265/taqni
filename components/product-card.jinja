{% if product %}
<article
  class="outlit-product-card product-item position-relative {% if product.is_infinite == false and product.quantity <= 0 %}outlit-product-card--out-of-stock{% endif %}"
  itemscope itemtype="https://schema.org/Product">
  {# --- Part 1: Image --- #}
  <div class="outlit-product-card__img-wrap" style="height: var(--outlit-card-img-height, 280px);">
    <a href="/products/{{ product.slug }}" class="outlit-product-card__img-link" aria-label="{{ product.name }}">
      <div class="outlit-product-card__img-inner">
        {% if product.images or product.videos %}
        <img id="product-card-img-{{ product.id }}" class="outlit-product-card__img"
          src="{{ product.main_image.image.small if product.main_image else '' }}" {% if product.main_image and
          product.main_image.image %} width="{{ product.main_image.image.width | default(235) }}"
          height="{{ product.main_image.image.height | default(235) }}" {% else %} width="235" height="235" {% endif %}
          loading="lazy" decoding="async" alt="{{ product.name }}">
        {% else %}
        <img id="product-card-img-{{ product.id }}" class="outlit-product-card__img"
          src="{{ image_url(('product-img.svg' | asset_url), w=235, q=100, f='auto') }}" width="235" height="235"
          loading="lazy" decoding="async" alt="{{ product.name }}">
        {% endif %}
      </div>
    </a>

    {% if product.badge %}
    {% set positionProductCard = true %}
    {% include 'vitrin:products/badge.jinja' %}
    {% endif %}

    {% if store.settings.products.wishlist_enabled == true %}
    <div class="outlit-product-card__wishlist">
      <span zid-visible-customer="true">
        <button type="button" zid-visible-wishlist="{{ product.id }}"
          class="outlit-product-card__wishlist-btn icon-heart-mask filled"
          onclick="addToWishlist(this, '{{ product.id }}')" aria-label="{{ _('Add to favorites') }}"></button>
        <button type="button" zid-hidden-wishlist="{{ product.id }}"
          class="outlit-product-card__wishlist-btn icon-heart-mask" onclick="addToWishlist(this, '{{ product.id }}')"
          aria-label="{{ _('Add to favorites') }}"></button>
      </span>
      <a zid-visible-guest="true" class="outlit-product-card__wishlist-btn icon-heart-mask"
        href="/auth/login?redirect_to={{ session.url.path }}"
        onclick="event.preventDefault(); handleLoginAction('', false); return false;"
        aria-label="{{ _('Add to favorites') }}"></a>
      <img class="loader d-none" src="{{ 'spinner.gif' | asset_url }}" width="20" height="20" alt="" aria-hidden="true">
    </div>
    {% endif %}

    <span class="product-card-bundle-offer" data-bundle-offer-product-id="{{ product.id }}" aria-hidden="true"></span>


    <div class="outlit-product-card__row outlit-product-card__row--rating-cart">
      {% if store.settings.products.reviews_enabled %}
      {% set _rating_obj = product.rating or {} %}
      {% set _rating_count = _rating_obj.total_count or 0 %}
      {% set _rating_avg = _rating_obj.average or 0 %}
      <div class="outlit-product-card__rating">
        <span class="product-card-rating-count">({{ _rating_count }})</span>
        {% if _rating_count > 0 %}
            {% set rating = _rating_avg %}
            {% include 'components/rating-stars.jinja' %}
        {% endif %}
        <span class="outlit-product-card__rating-value">{{ '%.1f'|format(_rating_avg) }}</span>
      </div>
      {% endif %}
    </div>
  </div>

  {# --- Part 2: Text --- #}
  <div class="outlit-product-card__body">

    {% set _cats = product.categories or [] %}
    {% if _cats|length > 0 %}
    {% set last_cat = _cats[-1] %}
    {% set cat_name = last_cat.name if last_cat.name is string else (safeget(last_cat.name, session.lang) or
    safeget(last_cat.name, 'ar') or safeget(last_cat.name, 'en') or '') %}
    {% if cat_name %}
    <p class="outlit-product-card__category">
      <a href="/categories/{{ last_cat.id }}/{{ last_cat.slug }}">{{ cat_name }}</a>
    </p>
    {% endif %}
    {% elif product.category and product.category.name %}
    <p class="outlit-product-card__category">{{ product.category.name }}</p>
    {% endif %}

    <h3 class="outlit-product-card__title">
      <a href="/products/{{ product.slug }}">{{ product.name | safe }}</a>
    </h3>

    <div class="outlit-product-card__price-cart-row">
      <div class="outlit-product-card__price-wrap">
        {% if product.formatted_sale_price is not none %}
        <div class="outlit-product-card__price-row">
          <span class="outlit-product-card__price outlit-product-card__price--old">{{ product.formatted_price }}</span>
          <span class="outlit-product-card__price outlit-product-card__price--current">{{ product.formatted_sale_price
            }}</span>
        </div>
        {% else %}
        <span class="outlit-product-card__price outlit-product-card__price--current">{{ product.formatted_price }}</span>
        {% endif %}
      </div>

      {% if product.is_infinite or product.quantity > 0 %}
      {% if product.has_options or product.has_fields or product.product_class == 'dynamic_bundle' %}
      <a href="/products/{{ product.slug }}" class="outlit-product-card__add-cart-btn"
        aria-label="{{ _('Add to cart') }}">
        <span class="outlit-product-card__add-cart-icon" aria-hidden="true">
          <svg width="24" height="20" viewBox="0 0 24 20" fill="none" xmlns="http://www.w3.org/2000/svg">
            <g clip-path="url(#clip0_982_5238)">
              <g clip-path="url(#clip1_982_5238)">
                <path fill-rule="evenodd" clip-rule="evenodd"
                  d="M5.06467 1.72682C5.06467 1.40194 4.8013 1.13858 4.47643 1.13858C4.15156 1.13858 3.88819 1.40194 3.88819 1.72682V3.8837H1.73131C1.40643 3.8837 1.14307 4.14706 1.14307 4.47193C1.14307 4.79681 1.40643 5.06017 1.73131 5.06017H3.88819V7.21703C3.88819 7.5419 4.15156 7.80525 4.47643 7.80525C4.8013 7.80525 5.06467 7.5419 5.06467 7.21703V5.06017H7.22151C7.54638 5.06017 7.80974 4.79681 7.80974 4.47193C7.80974 4.14706 7.54638 3.8837 7.22151 3.8837H5.06467V1.72682Z"
                  fill="#050505" />
