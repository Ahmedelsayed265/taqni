<style>
    .products-filter-modern {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 15px 0;
        font-family: inherit;
    }

    .filter-left-section {
        display: flex;
        align-items: center;
    }

    .filter-right-section {
        display: flex;
        align-items: center;
        gap: 30px;
    }

    .filter-trigger-btn,
    .sort-trigger-btn {
        display: flex;
        align-items: center;
        gap: 10px;
        background: transparent;
        border: none;
        padding: 0;
        cursor: pointer;
        color: #333;
        font-size: 14px;
        transition: opacity 0.2s;
    }

    .filter-trigger-btn:hover,
    .sort-trigger-btn:hover {
        opacity: 0.7;
    }

    .filter-label-text,
    .sort-label-text {
        font-weight: 400;
        color: #444;
    }

    .filter-icon-svg,
    .sort-icon-svg {
        display: flex;
        align-items: center;
        justify-content: center;
        color: #000;
    }

    .product-count-display {
        font-size: 14px;
        color: #666;
    }

    .product-count-number {
        font-weight: 600;
        color: #222;
        margin-right: 4px;
    }

    .sort-wrapper-modern .dropdown-menu {
        margin-top: 10px;
        border: 1px solid #eee;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
        border-radius: 8px;
        padding: 8px 0;
        min-width: 180px;
    }

    .sort-wrapper-modern .dropdown-item {
        padding: 10px 20px;
        font-size: 14px;
        color: #333;
    }

    .sort-wrapper-modern .dropdown-item:hover {
        background-color: #f8f8f8;
    }

    @media (max-width: 768px) {
        .products-filter-modern {
            flex-direction: column;
            align-items: flex-start;
            gap: 15px;
            padding: 15px 0;
        }

        .filter-right-section {
            width: 100%;
            justify-content: space-between;
        }
    }
</style>

<div class="products-filter-modern">
    <div class="filter-left-section">
        <button type="button" class="filter-trigger-btn" {% if has_products_filtration %} data-toggle="collapse"
            data-target="#filters-form-collapse-sm" {% else %} data-toggle="modal" data-target="#filterModal" {% endif
            %} aria-label="{{ _('Filter') }}">
            <span class="filter-label-text">{{ _("Filter") }}</span>
            <span class="filter-icon-svg">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M3 7H6" stroke="#050505" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M3 17H9" stroke="#050505" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M18 17L21 17" stroke="#050505" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M15 7L21 7" stroke="#050505" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M6 7C6 6.06812 6 5.60218 6.15224 5.23463C6.35523 4.74458 6.74458 4.35523 7.23463 4.15224C7.60218 4 8.06812 4 9 4C9.93188 4 10.3978 4 10.7654 4.15224C11.2554 4.35523 11.6448 4.74458 11.8478 5.23463C12 5.60218 12 6.06812 12 7C12 7.93188 12 8.39782 11.8478 8.76537C11.6448 9.25542 11.2554 9.64477 10.7654 9.84776C10.3978 10 9.93188 10 9 10C8.06812 10 7.60218 10 7.23463 9.84776C6.74458 9.64477 6.35523 9.25542 6.15224 8.76537C6 8.39782 6 7.93188 6 7Z" stroke="#050505" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M12 17C12 16.0681 12 15.6022 12.1522 15.2346C12.3552 14.7446 12.7446 14.3552 13.2346 14.1522C13.6022 14 14.0681 14 15 14C15.9319 14 16.3978 14 16.7654 14.1522C17.2554 14.3552 17.6448 14.7446 17.8478 15.2346C18 15.6022 18 16.0681 18 17C18 17.9319 18 18.3978 17.8478 18.7654C17.6448 19.2554 17.2554 19.6448 16.7654 19.8478C16.3978 20 15.9319 20 15 20C14.0681 20 13.6022 20 13.2346 19.8478C12.7446 19.6448 12.3552 19.2554 12.1522 18.7654C12 18.3978 12 17.9319 12 17Z" stroke="#050505" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M9 7L15 7" stroke="#050505" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M15 17L18 17" stroke="#050505" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M9 17L12 17" stroke="#050505" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </span>
        </button>
    </div>

    <div class="filter-right-section">
        <div class="product-count-display">
            {% if count > 0 %}
            <span class="product-count-number">{{ count }}</span>
            <span class="product-count-label">{{ _("products") }}</span>
            {% else %}
            <span class="product-count-label">{{ _("No products") }}</span>
            {% endif %}
        </div>

        <div class="sort-wrapper-modern dropdown">
            <button type="button" class="sort-trigger-btn" id="products-list-sort" data-toggle="dropdown"
                aria-haspopup="true" aria-expanded="false">
                <span class="sort-label-text">{{ _("Sort by") }}</span>
                <span class="sort-icon-svg">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M11 8L19 8.00006" stroke="#050505" stroke-width="1.5" stroke-linecap="round"
                            stroke-linejoin="round" />
                        <path d="M11 12H16" stroke="#050505" stroke-width="1.5" stroke-linecap="round"
                            stroke-linejoin="round" />
                        <path d="M11 16H14" stroke="#050505" stroke-width="1.5" stroke-linecap="round"
                            stroke-linejoin="round" />
                        <path d="M11 4H21" stroke="#050505" stroke-width="1.5" stroke-linecap="round"
                            stroke-linejoin="round" />
                        <path
                            d="M5.5 21V3M5.5 21C4.79977 21 3.49153 19.0057 3 18.5M5.5 21C6.20023 21 7.50847 19.0057 8 18.5"
                            stroke="#050505" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </span>
            </button>
            <div class="dropdown-menu select-dropdown dropdown-menu-right">
                <a class="dropdown-item"
                    href="{{ session.url.include_query_params(sort_by='created_at', order='desc') }}">
                    {{ _("Newest") }}
                </a>
                <a class="dropdown-item"
                    href="{{ session.url.include_query_params(sort_by='popularity_order', order='asc') }}">
                    {{ _("Most popular") }}
                </a>
                <a class="dropdown-item" href="{{ session.url.include_query_params(sort_by='price', order='asc') }}">
                    {{ _("Low to high") }}
                </a>
                <a class="dropdown-item" href="{{ session.url.include_query_params(sort_by='price', order='desc') }}">
                    {{ _("High to low") }}
                </a>
            </div>
        </div>
    </div>
</div>

<div id="filters-form-collapse-sm" class="collapse mt-3">
    {% include 'components/products-filter-form.jinja' %}
</div>
<div class="modal fade filter-modal" id="filterModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content filter-modal-content">
            <div class="modal-body filter-modal-body">
                <div class="filter-modal-inner">
                    <div class="filter-modal-header d-flex align-items-center justify-content-between">
                        <div class="filter-modal-title-wrap">
                            <span class="filter-modal-title">{{ _("Filter") }}</span>
                        </div>
                        <button id="products-list-filter-form-close" type="button" class="btn filter-modal-close"
                            data-dismiss="modal" aria-label="{{ _('Close') }}">
                            <span class="icon-times2"></span>
                        </button>
                    </div>
                    <div class="filter-modal-body-content">
                        {% include 'components/products-filter-form.jinja' %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    (function () {
        function initProductsFilterFormPriceRange() {
            var forms = document.querySelectorAll('.form-products-filter');
            if (!forms.length) { return; }

            forms.forEach(function (form) {
                var fromInput = form.querySelector('#price_min');
                var toInput = form.querySelector('#price_max');
                var host = form.querySelector('#slider-range');
                if (!fromInput || !toInput || !host) { return; }

                if (host.dataset.enhanced === 'true') { return; }
                host.dataset.enhanced = 'true';

                var wrapper = document.createElement('div');
                wrapper.className = 'price-range-slider-wrapper';

                var track = document.createElement('div');
                track.className = 'price-range-track';
                wrapper.appendChild(track);

                var minVal = parseInt(fromInput.min || '0', 10);
                var maxVal = parseInt(toInput.max || '100000', 10);

                var currentMin = parseInt(fromInput.value || minVal, 10);
                if (isNaN(currentMin)) { currentMin = minVal; }
                currentMin = Math.max(minVal, Math.min(maxVal, currentMin));

                var currentMax = parseInt(toInput.value || maxVal, 10);
                if (isNaN(currentMax)) { currentMax = maxVal; }
                currentMax = Math.max(minVal, Math.min(maxVal, currentMax));
                if (currentMin > currentMax) { currentMin = currentMax; }

                var sliderMin = document.createElement('input');
                sliderMin.type = 'range';
                sliderMin.className = 'price-range-input price-range-input-min';
                sliderMin.min = String(minVal);
                sliderMin.max = String(maxVal);
                sliderMin.step = '1';
                sliderMin.value = String(currentMin);

                var sliderMax = document.createElement('input');
                sliderMax.type = 'range';
                sliderMax.className = 'price-range-input price-range-input-max';
                sliderMax.min = String(minVal);
                sliderMax.max = String(maxVal);
                sliderMax.step = '1';
                sliderMax.value = String(currentMax);

                wrapper.appendChild(sliderMin);
                wrapper.appendChild(sliderMax);

                host.innerHTML = '';
                host.appendChild(wrapper);

                function clamp(v, min, max) {
                    return Math.max(min, Math.min(max, v));
                }

                function updateFromSliders(event) {
                    var minNow = parseInt(sliderMin.value || minVal, 10);
                    var maxNow = parseInt(sliderMax.value || maxVal, 10);
                    if (isNaN(minNow)) { minNow = minVal; }
                    if (isNaN(maxNow)) { maxNow = maxVal; }

                    if (minNow > maxNow) {
                        if (event && event.target === sliderMin) {
                            maxNow = minNow;
                            sliderMax.value = String(maxNow);
                        } else {
                            minNow = maxNow;
                            sliderMin.value = String(minNow);
                        }
                    }

                    fromInput.value = String(minNow);
                    toInput.value = String(maxNow);
                }

                function updateFromInputs() {
                    var minNow = parseInt(fromInput.value || minVal, 10);
                    var maxNow = parseInt(toInput.value || maxVal, 10);

                    if (isNaN(minNow)) { minNow = minVal; }
                    if (isNaN(maxNow)) { maxNow = maxVal; }

                    minNow = clamp(minNow, minVal, maxVal);
                    maxNow = clamp(maxNow, minVal, maxVal);
                    if (minNow > maxNow) { minNow = maxNow; }

                    sliderMin.value = String(minNow);
                    sliderMax.value = String(maxNow);
                    fromInput.value = String(minNow);
                    toInput.value = String(maxNow);
                }

                sliderMin.addEventListener('input', function (e) { updateFromSliders(e); });
                sliderMax.addEventListener('input', function (e) { updateFromSliders(e); });
                fromInput.addEventListener('input', updateFromInputs);
                toInput.addEventListener('input', updateFromInputs);

                updateFromInputs();
            });
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initProductsFilterFormPriceRange);
        } else {
            initProductsFilterFormPriceRange();
        }
    })();
</script>