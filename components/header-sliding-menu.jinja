{% set side_menu = settings.side_menu %}
<div id="sidenav-overlay" onclick="closeSlidingMenu()"></div>
<nav class="side-menu-new" id="sliding-menu">
    <div class="side-menu__inner">
        <!-- Close Button -->
        <button class="side-menu__close" onclick="closeSlidingMenu()" aria-label="Close">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
        </button>

        <!-- Left Side: Promo Image Section -->
        <div class="side-menu__promo">
            <div class="side-menu__promo-bg">
                {% if side_menu.image %}
                    <img src="{{ side_menu.image }}" alt="{{ side_menu.image_title }}">
                {% else %}
                    <img src="{{ 'placeholder.jpg' | asset_url }}" alt="Promo">
                {% endif %}
                <div class="side-menu__promo-overlay"></div>
            </div>
            <div class="side-menu__promo-content">
                <h2 class="side-menu__promo-title">{{ side_menu.image_title }}</h2>
                <a href="{{ side_menu.image_link }}" class="side-menu__promo-link">{{ side_menu.image_link_text }}</a>
            </div>
        </div>

        <!-- Right Side: Navigation & Contacts -->
        <div class="side-menu__main">
            <ul class="side-menu__nav">
                {% for menu in store.settings.menus.main_menu.items %}
                    <li class="side-menu__nav-item">
                        <a href="{{ menu.url | localized_url if menu.resource_type != 'url' else menu.url }}" class="side-menu__nav-link">
                            {{ menu.label }}
                        </a>
                    </li>
                {% endfor %}
            </ul>

            <!-- Footer Contacts -->
            <div class="side-menu__footer">
                <div class="side-menu__footer-row">
                    <div class="side-menu__contact-group">
                        <span class="side-menu__label">Contact</span>
                        <a href="#" class="side-menu__footer-link">{{ side_menu.privacy_text }}</a>
                    </div>
                    <div class="side-menu__contact-group side-menu__contact-group--right">
                        <span class="side-menu__label">EMAIL</span>
                        <a href="mailto:{{ side_menu.email }}" class="side-menu__footer-link">{{ side_menu.email }}</a>
                        
                        <div class="side-menu__support">
                            <span class="side-menu__label">Contact Customer Support</span>
                            <a href="tel:{{ side_menu.phone }}" class="side-menu__footer-link">{{ side_menu.phone }}</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</nav>

<script>
function closeSlidingMenu() {
    document.body.classList.remove('sidenav-open');
}
</script>