                      </svg>
                      <input type="text" class="form-control send-coupon side-cart-coupon-input" placeholder="{{ _('Add discount coupon') | e }}" autocomplete="off">
                      <button type="submit" class="btn coupon-activate-btn side-cart-coupon-apply" aria-label="{{ _('Apply discount coupon') }}">
                        <img class="send-coupon-progress side-cart-coupon-spinner d-none" src="{{ 'spinner.gif' | asset_url }}" width="15" height="15" alt="">
                        <span class="side-cart-coupon-apply-text">{{ _('Activate') }}</span>
                      </button>
                    </div>
                  </div>
                </form>
                <div class="side-cart-coupon-applied d-none message-coupon alert alert-primary mt-2" role="alert">
                  <span class="side-cart-coupon-code"></span>
                  <button type="button" class="btn btn-link btn-sm p-0 side-cart-coupon-remove" onclick="if(typeof deleteSideCartCoupon === 'function') deleteSideCartCoupon();" aria-label="{{ _('Remove coupon') }}">
                    <span class="icon-trash-alt" aria-hidden="true"></span>
                    <img class="delete-coupon-progress d-none" src="{{ 'spinner.gif' | asset_url }}" width="14" height="14" alt="">
                  </button>
                </div>
                <div class="message-coupon side-cart-message-coupon d-none small"></div>
              </div>
            </div>

            <a href="/checkout" class="btn btn-primary btn-lg btn-block cart-checkout-btn btn-side-cart-checkout mb-2">{{ _('Proceed to checkout') }}</a>
            <div class="mt-2">
              <a href="{{ url_for('cart_page') }}" class="btn btn-block continue-btn btn-side-cart-view-cart">{{ _('View cart') }}</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</aside>

{% if side_cart_products_list and side_cart_products_list.id %}
