{# Side Cart (سلة تسوق جانبية) - RTL + Bootstrap 5 Offcanvas #}
{% set side_cart_recommended_list = safeget(settings, 'side_cart_recommended_list') %}
<aside class="offcanvas offcanvas-end block-side-cart"
       id="side-cart-modern"
       tabindex="-1"
       aria-labelledby="side-cart-title"
       data-empty="{{ _('Cart is empty') | e }}"
       data-recommended-title="{{ settings.side_cart_cart_name or _('You might also like') | e }}"
       data-remove-label="{{ _('Remove') | e }}"
       data-free-shipping-applied="{{ _('Free shipping applied') | e }}"
       data-free-shipping-between="{{ _('Free shipping applies for cart total between %(min)s and %(max)s') | e }}"
       data-free-shipping-add-total="{{ _('Would you like free shipping?') }} {{ _('Add valuable products') }} %(total)s"
       data-total-label="{{ _('Total') | e }}"
       data-coupon-applied="{{ _('Coupon applied') | e }}"
       data-update-quantity-error="{{ _('Failed to update quantity') | e }}"
       data-reviews-enabled="{{ 'true' if store.settings.products.reviews_enabled else 'false' }}">

  <div class="offcanvas-header block-side-cart-header">
    <div class="side-cart-header-left">
      <svg width="24" height="24" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M4.08223 20.2577L4.56921 17.4958C5.14478 14.2315 5.43257 12.5994 6.57223 11.633C7.71189 10.6667 9.34898 10.6667 12.6232 10.6667H19.3769C22.6511 10.6667 24.2882 10.6667 25.4279 11.633C26.5675 12.5994 26.8553 14.2315 27.4309 17.4958L27.9179 20.2577C28.7143 24.7748 29.1125 27.0333 27.8863 28.5167C26.66 30 24.3946 30 19.8639 30H12.1362C7.60545 30 5.34009 30 4.11381 28.5167C2.88754 27.0333 3.28577 24.7748 4.08223 20.2577Z" stroke="#050505" stroke-width="1.5"/>
        <path d="M10 10.6667L10.2238 7.98158C10.4741 4.97742 12.9854 2.66667 16 2.66667C19.0146 2.66667 21.5259 4.97742 21.7762 7.98158L22 10.6667" stroke="#050505" stroke-width="1.5"/>
        <path d="M20 14.6667C19.8266 16.5508 18.0876 18 16 18C13.9124 18 12.1734 16.5508 12 14.6667" stroke="#050505" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </div>
    <h5 class="offcanvas-title" id="side-cart-title">
      {{ _('shopping bag') }} (<span class="side-cart-count-title">0</span>)
    </h5>
    <button type="button"
            class="btn-close side-cart-close"
            onclick="typeof window.closeSideCart === 'function' && window.closeSideCart()"
            aria-label="{{ _('Close') }}">
      <svg width="24" height="24" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M24 24L8 8M8 24L24 8" stroke="#000" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  </div>

  <div class="offcanvas-body block-side-cart-body">
    <div class="loading-cart d-none" aria-hidden="true">
      <span class="loader-cart" aria-hidden="true"></span>
    </div>

    <div class="cart-list">
        <div id="side-cart-free-shipping" class="free-shipping-rule-section d-none">
            <div class="free-shipping-header-row d-flex justify-content-between align-items-center">
                <div class="free-shipping-message-text free-shipping-rule-message"></div>
                <div class="free-shipping-add-more free-shipping-rule-read-more d-none">
                    <a href="/categories">{{ _("Add more") }}</a>
                </div>
            </div>
            <div class="free-shipping-track">
                <div class="free-shipping-track-fill free-shipping-rule-progress">
                    <div class="free-shipping-truck-icon">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path fill-rule="evenodd" clip-rule="evenodd" d="M7.56088 2.2891C6.93688 2.49185 6.42335 2.92949 6.12235 3.50002H5.09448C4.63041 3.50002 4.24535 3.50001 3.92815 3.53203C3.59415 3.56576 3.29508 3.63795 3.01275 3.80657C2.73041 3.97521 2.52508 4.20433 2.33701 4.48243C2.18399 4.70876 2.02797 4.99022 1.84797 5.3233L1.75588 5.49415L0.897014 7.08916C0.877014 7.12483 0.861281 7.16323 0.850414 7.20363C0.838014 7.24963 0.832481 7.29643 0.833314 7.34276V8.70263C0.833314 9.45776 0.833313 10.0749 0.898881 10.5622C0.967348 11.0714 1.11555 11.513 1.46801 11.8655C1.84475 12.2422 2.32588 12.3875 2.88881 12.4491C3.08908 13.2445 3.80915 13.8334 4.66675 13.8334C5.50595 13.8334 6.21341 13.2696 6.43108 12.5001H9.56908C9.78676 13.2696 10.4942 13.8334 11.3334 13.8334C12.191 13.8334 12.9111 13.2445 13.1113 12.4491C13.6743 12.3875 14.1554 12.2422 14.5321 11.8655C14.9994 11.3982 15.1106 10.7702 15.1478 10.025C15.1615 9.74916 14.9491 9.51443 14.6733 9.50069C14.3975 9.48696 14.1627 9.69936 14.149 9.97516C14.1133 10.6922 14.007 10.9764 13.825 11.1584C13.686 11.2974 13.4873 11.3922 13.0813 11.4452C12.8462 10.7039 12.1525 10.1667 11.3334 10.1667C10.4942 10.1667 9.78671 10.7306 9.56908 11.5001H6.43108C6.21348 10.7306 5.50595 10.1667 4.66675 10.1667C3.84761 10.1667 3.15395 10.7039 2.91888 11.4452C2.51288 11.3922 2.31415 11.2974 2.17515 11.1584C2.03941 11.0227 1.94355 10.8273 1.88995 10.4289C1.83448 10.0161 1.83341 9.46656 1.83341 8.66676V7.83343H4.54495C4.96415 7.83376 5.28855 7.83403 5.56661 7.74369C6.12475 7.56236 6.56235 7.12476 6.74368 6.56661C6.83401 6.28851 6.83381 5.96412 6.83348 5.54493L6.83341 5.46674C6.83341 4.68331 6.83961 4.41018 6.90681 4.20321C7.05521 3.74656 7.41321 3.38853 7.86988 3.24015C8.04928 3.18187 8.27835 3.16947 8.84622 3.1672L14.6667 3.16674C14.9429 3.16674 15.1667 2.94288 15.1667 2.66674C15.1667 2.3906 14.9429 2.16669 14.6667 2.16669H9.04075C8.38608 2.16646 7.93888 2.16628 7.56088 2.2891ZM11.3334 11.1667C11.7937 11.1667 12.1667 11.5398 12.1667 12C12.1667 12.4603 11.7937 12.8334 11.3334 12.8334C10.8732 12.8334 10.5001 12.4603 10.5001 12C10.5001 11.5398 10.8732 11.1667 11.3334 11.1667ZM4.66675 11.1667C5.12701 11.1667 5.50008 11.5398 5.50008 12C5.50008 12.4603 5.12701 12.8334 4.66675 12.8334C4.20648 12.8334 3.83341 12.4603 3.83341 12C3.83341 11.5398 4.20648 11.1667 4.66675 11.1667ZM4.81204 4.50039L5.85048 4.50003C5.83315 4.74808 5.83328 5.03291 5.83341 5.37407L5.83289 5.68761C5.83083 6.04686 5.82189 6.16744 5.79261 6.25759C5.71021 6.51129 5.51128 6.71016 5.25761 6.79263C5.15108 6.82723 5.00201 6.83343 4.46675 6.83343H2.17048L2.62461 5.99008C2.85935 5.55415 3.01841 5.25993 3.16541 5.04259C3.30601 4.83461 3.41308 4.73227 3.52555 4.66509C3.63801 4.59791 3.77881 4.5522 4.02861 4.52697C4.23167 4.50647 4.47912 4.50156 4.81204 4.50039ZM14.6667 4.83336C14.9429 4.83336 15.1667 5.05722 15.1667 5.33336C15.1667 5.6095 14.9429 5.83336 14.6667 5.83336H10.6667C10.3906 5.83336 10.1667 5.6095 10.1667 5.33336C10.1667 5.05722 10.3906 4.83336 10.6667 4.83336H14.6667ZM15.1667 7.33336C15.1667 7.05723 14.9429 6.83336 14.6667 6.83336H12.0001C11.7239 6.83336 11.5001 7.05723 11.5001 7.33336C11.5001 7.60949 11.7239 7.83336 12.0001 7.83336H14.6667C14.9429 7.83336 15.1667 7.60949 15.1667 7.33336Z" fill="white"/>
                        </svg>
                    </div>
                </div>                            
            </div>
        </div>

      <div class="empty-cart-box d-none" id="additional-cart">
        <div class="empty-cart-message d-flex flex-column align-items-center justify-content-center py-5">
          <div class="empty-cart-icon-wrapper mb-4">
             <svg width="151" height="150" viewBox="0 0 151 150" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M88.0833 93.75L110.104 115.625M110.104 115.625L132.125 137.5M110.104 115.625L88.0833 137.5M110.104 115.625L132.125 93.75" stroke="#404040" stroke-width="2.5" stroke-linecap="round"/>
                <path d="M44.0417 46.875V43.75C44.0417 26.4911 58.1261 12.5 75.5001 12.5C92.874 12.5 106.958 26.4911 106.958 43.75V46.875" stroke="#404040" stroke-width="2.5"/>
                <path d="M128.303 78.125L131.006 62.0973C132.196 55.0394 132.791 51.5104 130.959 49.1927C129.126 46.875 125.741 46.875 118.97 46.875H32.0295C25.259 46.875 21.8738 46.875 20.0413 49.1927C18.2088 51.5104 18.8039 55.0394 19.9941 62.0973L27.3112 105.488C29.8915 120.79 31.1817 128.44 36.2909 132.97C41.4001 137.5 48.7393 137.5 63.4177 137.5H69.2083" stroke="#404040" stroke-width="2.5" stroke-linecap="round"/>
                <path d="M28.3125 109.375L69.2083 109.375" stroke="#404040" stroke-width="2.5" stroke-linecap="round"/>
             </svg>
          </div>
          <h2 class="mt-empty">{{ _('Your shopping cart is empty') }}</h2>
          <p style="font-size: 18px; color: #454545; margin-top: 10px;">{{ _("Add some products to your cart to complete your order.") }}</p>
          
          <div class="empty-recommended-grid w-100 mt-4" id="empty-recommended-products">
             {% for item in side_cart_recommended_list %}
                <div class="recommended-item-card">
                   <a href="{{ item.link }}" class="recommended-item-link">
                      <div class="recommended-item-img-wrap">
                         <img src="{{ item.image }}" alt="{{ item.title }}" loading="lazy">
                      </div>
                      <span class="recommended-item-title">{{ item.title }}</span>
                   </a>
                </div>
             {% endfor %}
          </div>

          <div class="mt-shopping mt-4">
            <a href="/" class="view-all-products-link">
              {{ _('View all products') }}
            </a>
          </div>
        </div>
      </div>

      <ul class="item-inside-cart side-cart-items list-unstyled mb-0 d-none"></ul>

      <div class="side-cart-recommended d-none" id="side-cart-recommended"
           data-default-product-image="{{ ('product-img.svg' | asset_url) | e }}"
           data-spinner-url="{{ ('spinner.gif' | asset_url) | e }}">
        <div class="mb-1">
          <div class="titles">
            <h2 class="section-title side-cart-recommended-title" style="margin-bottom: 10px; text-align: start; font-size: 16px;"></h2>
          </div>
          <div class="products-slider-wrapper" style="position: relative;">
            <div class="loading-spinner side-cart-recommended-loading" style="text-align: center; padding: 10px;">{{ _('Loading...') }}</div>
            <div class="products-slider s-slider side-cart-recommended-slider cart-category-products-slider" style="display: none;"></div>
          </div>
        </div>
      </div>

      {% if side_cart_products_list and side_cart_products_list.id %}
        <div id="side-cart-custom-category-products" class="category-products " style="margin-top: 10px; margin-bottom: 10px;">
            <div class="mb-1">
            <div class="titles">
                <h2 class="section-title" style="margin-bottom: 10px; text-align: start; font-size: 16px;">{{ settings.side_cart_cart_name or _("recommended products") }}</h2>
                </div>
                <div class="products-slider-wrapper" style="position: relative;">
                    <div class="loading-spinner" style="text-align: center; padding: 10px;">{{ _("Loading...") }}</div>
                    <div class="products-slider s-slider cart-category-products-slider" style="display: none;"></div>
                </div>
            </div>
        </div>
      {% endif %}
    </div>

    <div class="footer-side-cart d-none">
      <div class="cart-sidebar-wrapper">
        <div class="cart-sidebar-card order-summary-card mb-4">
    
          <div class="cart-totals-div" id="cart-side-totals" role="status" aria-live="polite" aria-atomic="true"></div>

          <div class="cart-checkout-section">
            <a href="/checkout" class="btn btn-primary btn-lg btn-block btn-side-cart-checkout">{{ _('Proceed to checkout') }}</a>
            <div class="text-center">
              <a href="{{ url_for('cart_page') }}" class="btn-side-cart-view-cart">{{ _('View cart') }}</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</aside>

{% if side_cart_products_list and side_cart_products_list.id %}
{% set _cart_svg_options_icon = '<svg width="24" height="20" viewBox="0 0 24 20" fill="none" xmlns="http://www.w3.org/2000/svg"><g clip-path="url(#clip0_982_5238)"><g clip-path="url(#clip1_982_5238)"><path fill-rule="evenodd" clip-rule="evenodd" d="M5.06467 1.72682C5.06467 1.40194 4.8013 1.13858 4.47643 1.13858C4.15156 1.13858 3.88819 1.40194 3.88819 1.72682V3.8837H1.73131C1.40643 3.8837 1.14307 4.14706 1.14307 4.47193C1.14307 4.79681 1.40643 5.06017 1.73131 5.06017H3.88819V7.21703C3.88819 7.5419 4.15156 7.80525 4.47643 7.80525C4.8013 7.80525 5.06467 7.5419 5.06467 7.21703V5.06017H7.22151C7.54638 5.06017 7.80974 4.79681 7.80974 4.47193C7.80974 4.14706 7.54638 3.8837 7.22151 3.8837H5.06467V1.72682Z" fill="#050505"/><path d="M3.88777 3.88371V4.16942H4.17348V3.88371H3.88777ZM3.88777 5.06018H4.17348V4.77446H3.88777V5.06018ZM5.06425 5.06018V4.77446H4.77853V5.06018H5.06425ZM5.06425 3.88371H4.77853V4.16942H5.06425V3.88371ZM4.47601 1.4243C4.64308 1.4243 4.77853 1.55974 4.77853 1.72683H5.34996C5.34996 1.24415 4.95868 0.852875 4.47601 0.852875V1.4243ZM4.17348 1.72683C4.17348 1.55974 4.30893 1.4243 4.47601 1.4243V0.852875C3.99333 0.852875 3.60205 1.24415 3.60205 1.72683H4.17348ZM4.17348 3.88371V1.72683H3.60205V3.88371H4.17348ZM1.73089 4.16942H3.88777V3.59799H1.73089V4.16942ZM1.42836 4.47194C1.42836 4.30486 1.5638 4.16942 1.73089 4.16942V3.59799C1.24821 3.59799 0.856934 3.98927 0.856934 4.47194H1.42836ZM1.73089 4.77446C1.5638 4.77446 1.42836 4.63902 1.42836 4.47194H0.856934C0.856934 4.95461 1.24821 5.34589 1.73089 5.34589V4.77446ZM3.88777 4.77446H1.73089V5.34589H3.88777V4.77446ZM4.17348 7.21703V5.06018H3.60205V7.21703H4.17348ZM4.47601 7.51955C4.30893 7.51955 4.17348 7.38411 4.17348 7.21703H3.60205C3.60205 7.6997 3.99333 8.09098 4.47601 8.09098V7.51955ZM4.77853 7.21703C4.77853 7.38411 4.64308 7.51955 4.47601 7.51955V8.09098C4.95868 8.09098 5.34996 7.6997 5.34996 7.21703H4.77853ZM4.77853 5.06018V7.21703H5.34996V5.06018H4.77853ZM7.22109 4.77446H5.06425V5.34589H7.22109V4.77446ZM7.52361 4.47194C7.52361 4.63902 7.38817 4.77446 7.22109 4.77446V5.34589C7.70376 5.34589 8.09504 4.95461 8.09504 4.47194H7.52361ZM7.22109 4.16942C7.38817 4.16942 7.52361 4.30486 7.52361 4.47194H8.09504C8.09504 3.98927 7.70376 3.59799 7.22109 3.59799V4.16942ZM5.06425 4.16942H7.22109V3.59799H5.06425V4.16942ZM4.77853 1.72683V3.88371H5.34996V1.72683H4.77853Z" fill="#050505"/><path d="M21.714 1.82431H12.5712C11.6875 1.82431 10.9712 2.54065 10.9712 3.42431V12.5672C10.9712 13.4508 11.6875 14.1672 12.5712 14.1672H21.714C22.5977 14.1672 23.314 13.4508 23.314 12.5672V3.42431C23.314 2.54065 22.5977 1.82431 21.714 1.82431Z" fill="#FFF4FA" stroke="#050505" stroke-width="1.37143"/><path d="M17.1427 6.39572H10.2855C9.40189 6.39572 8.68555 7.11207 8.68555 7.99572V14.8529C8.68555 15.7365 9.40189 16.4529 10.2855 16.4529H17.1427C18.0263 16.4529 18.7427 15.7365 18.7427 14.8529V7.99572C18.7427 7.11207 18.0263 6.39572 17.1427 6.39572Z" fill="#FFF4FA" stroke="#050505" stroke-width="1.37143"/><path d="M12.5713 10.9672H7.9999C7.11625 10.9672 6.3999 11.6835 6.3999 12.5672V17.1386C6.3999 18.0222 7.11625 18.7386 7.9999 18.7386H12.5713C13.455 18.7386 14.1713 18.0222 14.1713 17.1386V12.5672C14.1713 11.6835 13.455 10.9672 12.5713 10.9672Z" fill="#FFF4FA" stroke="#050505" stroke-width="1.37143"/></g></g><defs><clipPath id="clip0_982_5238"><rect width="24" height="19.42" fill="white"/></clipPath><clipPath id="clip1_982_5238"><rect width="24" height="19.4286" fill="white" transform="translate(0 -0.00427246)"/></clipPath></defs></svg>' %}
{% set _cart_svg_add_icon = '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M13 18H21M17 22L17 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M7 7.5V7C7 4.23858 9.23858 2 12 2C14.7614 2 17 4.23858 17 7V7.5" stroke="currentColor" stroke-width="1.5"/><path d="M10 22C7.71999 21.9999 6.57085 21.9917 5.76809 21.2752C4.95603 20.5505 4.75097 19.3264 4.34085 16.8781L3.17786 9.93557C2.98869 8.8063 2.89411 8.24167 3.18537 7.87083C3.47662 7.5 4.01468 7.5 5.09079 7.5H18.9092C19.9853 7.5 20.5234 7.5 20.8146 7.87083C21.1059 8.24167 21.0113 8.8063 20.8221 9.93557L20.4763 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M4.5 17.5H10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>' %}

<script>
(function() {
var CART_CATEGORY_SVG_OPTIONS = {{ _cart_svg_options_icon | tojson }};
var CART_CATEGORY_SVG_ADD = {{ _cart_svg_add_icon | tojson }};

document.addEventListener('DOMContentLoaded', async function() {
    function getSideCartEl() {
        return document.getElementById('side-cart-modern');
    }
    const container = document.getElementById('side-cart-modern-custom-category-products');
    if (!container) return;

    const loader = container.querySelector('.loading-spinner');
    const selectedCategoryId = "{{ side_cart_products_list.id if side_cart_products_list else '' }}";

    if (!selectedCategoryId || selectedCategoryId === "" || selectedCategoryId === "None") {
        if (loader) loader.textContent = "{{ _('No category selected') }}";
        container.style.display = 'none';
        return;
    }

    function waitForZid(maxWaitMs) {
        maxWaitMs = maxWaitMs || 8000;
        return new Promise(function(resolve) {
            if (typeof zid !== 'undefined' && zid.products && typeof zid.products.list === 'function') {
                resolve();
                return;
            }
            var start = Date.now();
            var t = setInterval(function() {
                if (typeof zid !== 'undefined' && zid.products && typeof zid.products.list === 'function') {
                    clearInterval(t);
                    resolve();
                    return;
                }
                if (Date.now() - start >= maxWaitMs) {
                    clearInterval(t);
                    resolve();
                }
            }, 200);
        });
    }

    async function loadCategoryProducts() {
        try {
            if (loader) loader.textContent = "{{ _('Loading...') }}";
            await waitForZid(8000);
            if (typeof zid === 'undefined' || !zid.products || typeof zid.products.list !== 'function') {
                if (loader) loader.textContent = "{{ _('Failed to load products') }}";
                return;
            }
            const categoryId = selectedCategoryId;

            var apiTimeout = 15000;
            var listPromise = zid.products.list({
                categories: categoryId,
                page_size: 50
            }, { showErrorNotification: false });
            var timeoutPromise = new Promise(function(_, reject) {
                setTimeout(function() { reject(new Error('timeout')); }, apiTimeout);
            });
            const response = await Promise.race([listPromise, timeoutPromise]);
            
            // Check different response structures
            var products = [];
            if (response && Array.isArray(response.results)) {
                products = response.results;
            } else if (response && Array.isArray(response.products)) {
                products = response.products;
            } else if (Array.isArray(response)) {
                products = response;
            } else if (response && response.data) {
                var d = response.data;
                if (Array.isArray(d.results)) products = d.results;
                else if (Array.isArray(d.products)) products = d.products;
                else if (Array.isArray(d)) products = d;
            }
            if (!products || products.length === 0) {
                if (loader) loader.textContent = "{{ _('No products in this category') }}";
                return;
            }

            if (loader) loader.remove();
            
            // Get or create slick slider container
            const sliderWrapper = container.querySelector('.products-slider-wrapper');
            let productsSlider = container.querySelector('.cart-category-products-slider');
            
            if (!productsSlider) {
                productsSlider = document.createElement('div');
                productsSlider.className = 'products-slider s-slider cart-category-products-slider';
                if (sliderWrapper) {
                    sliderWrapper.appendChild(productsSlider);
                } else {
                    container.appendChild(productsSlider);
                }
            }
            
            // Clear existing content
            productsSlider.innerHTML = '';
            productsSlider.style.display = 'block';

            const defaultImage = {{ image_url(("product-img.svg" | asset_url), w=235, q=100, f="auto") | tojson }};
            const spinnerUrl = {{ ("spinner.gif" | asset_url) | tojson }};
            const uBellUrl = {{ ("u_bell.svg" | asset_url) | tojson }};
            const wishlistEnabled = {{ 'true' if store.settings.products.wishlist_enabled else 'false' }};
            const reviewsEnabled = {{ 'true' if store.settings.products.reviews_enabled else 'false' }};
            const addToFavoritesLabel = {{ _("Add to favorites") | tojson }};
            const addToCartLabel = {{ _("Add to cart") | tojson }};
            const qtyLabel = {{ _("Quantity") | tojson }};
            const increaseQtyLabel = {{ _("Increase quantity") | tojson }};
            const decreaseQtyLabel = {{ _("Decrease quantity") | tojson }};
            const notifyWhenAvailableText = {{ _("Notify me when available") | tojson }};

            function buildRatingHtml(ratingObj) {
              if (!reviewsEnabled) return '';
              ratingObj = ratingObj || {};
              const totalCount = ratingObj.total_count || 0;
              const avg = ratingObj.average || 0;
              const ratingRounded = Math.ceil((avg * 2)) / 2;
              let stars = '';
              if (totalCount > 0) {
                for (let n = 1; n <= 5; n++) {
                  if (n <= ratingRounded) {
                    stars += '<span class="icon-star1"></span>';
                  } else if (n <= ratingRounded + 0.5) {
                    stars += '<span class="icon-half-star"></span>';
                  } else {
                    stars += '<span class="icon-star1 deactive"></span>';
                  }
                }
              }
              return '' +
                '<div class="outlit-product-card__rating">' +
                  '<span class="product-card-rating-count">(' + totalCount + ')</span>' +
                  (totalCount > 0 ? 
                  '<div class="d-inline-flex product-card-rating" data-rating="' + avg + '">' +
                    stars +
                  '</div>' : '') +
                  '<span class="outlit-product-card__rating-value">' + (avg ? avg.toFixed(1) : '0.0') + '</span>' +
                '</div>';
            }

            products.forEach(product => {
                const productImages = Array.isArray(product.images) ? product.images : [];
                const mainImgObj = product.main_image && product.main_image.image ? product.main_image.image : null;
                const firstImgObj = productImages[0] && productImages[0].image ? productImages[0].image : null;
                const mainImg = (mainImgObj && (mainImgObj.small || mainImgObj.medium || mainImgObj.large)) ||
                    (firstImgObj && (firstImgObj.small || firstImgObj.medium || firstImgObj.large)) ||
                    defaultImage;
                const width = (mainImgObj && mainImgObj.width) || 235;
                const height = (mainImgObj && mainImgObj.height) || 235;

                const badge = product.badge || null;
                const badgeBody = (badge && badge.body && (badge.body.ar || badge.body.en)) || '';
                const badgeIcon = (badge && badge.icon && badge.icon.code) || '';

                const productName = (product.name || '');
                const productSlug = (product.slug || '').replace(/'/g, "\\'").replace(/"/g, '\\"').replace(/\\/g, '\\\\');
                const productId = String(product.id || '');

                const badgeBodyEscaped = (badgeBody || '').replace(/'/g, "\\'").replace(/"/g, '\\"').replace(/</g, '&lt;').replace(/>/g, '&gt;');
                const badgeIconEscaped = (badgeIcon || '').replace(/'/g, "\\'").replace(/"/g, '\\"');

                const formattedPrice = product.formatted_sale_price || product.formatted_price || '';
                const hasSalePrice = !!product.formatted_sale_price;
                const discountPercentage = product.discount_percentage || '';

                const hasOptions = product.has_options || product.has_fields || product.product_class === 'dynamic_bundle' ||
                    (product.options && product.options.length > 0) ||
                    (product.variants && product.variants.length > 0);
                const outOfStock = !product.is_infinite && product.quantity <= 0;

                const ratingHtml = buildRatingHtml(product.rating || {});

                const article = document.createElement('article');
                article.className = 'prod-col outlit-product-card product-item position-relative' + (outOfStock ? ' outlit-product-card--out-of-stock' : '');
                article.setAttribute('itemscope', '');
                article.setAttribute('itemtype', 'https://schema.org/Product');

                let wishlistHtml = '';
                if (wishlistEnabled) {
                    wishlistHtml =
                        '<div class="outlit-product-card__wishlist">' +
                            '<span zid-visible-customer="true">' +
                                '<button type="button" zid-visible-wishlist="' + productId + '" class="outlit-product-card__wishlist-btn icon-heart-mask filled" onclick="addToWishlist(this, \'' + productId + '\')" aria-label="' + addToFavoritesLabel + '"></button>' +
                                '<button type="button" zid-hidden-wishlist="' + productId + '" class="outlit-product-card__wishlist-btn icon-heart-mask" onclick="addToWishlist(this, \'' + productId + '\')" aria-label="' + addToFavoritesLabel + '"></button>' +
                            '</span>' +
                            '<a zid-visible-guest="true" class="outlit-product-card__wishlist-btn icon-heart-mask" href="/auth/login?redirect_to={{ session.url.path }}" onclick="event.preventDefault(); handleLoginAction(\'\', false); return false;" aria-label="' + addToFavoritesLabel + '"></a>' +
                            '<img class="loader d-none" src="' + spinnerUrl + '" width="20" height="20" alt="" aria-hidden="true">' +
                        '</div>';
                }

                let priceHtml = '';
                if (hasSalePrice) {
                    priceHtml =
                        '<div class="outlit-product-card__price-wrap">' +
                            '<div class="outlit-product-card__price-row">' +
                                (discountPercentage ? '<span class="outlit-product-card__discount">-' + discountPercentage + '%</span>' : '') +
                                '<span class="outlit-product-card__price outlit-product-card__price--old">' + (product.formatted_price || '') + '</span>' +
                                '<span class="outlit-product-card__price outlit-product-card__price--current ">' + formattedPrice + '</span>' +
                            '</div>' +
                        '</div>';
                } else {
                    priceHtml =
                        '<div class="outlit-product-card__price-wrap">' +
                            '<span class="outlit-product-card__price outlit-product-card__price--current ">' + formattedPrice + '</span>' +
                        '</div>';
                }

                let categoryHtml = '';
                if (Array.isArray(product.categories) && product.categories.length > 0) {
                    const lastCat = product.categories[product.categories.length - 1];
                    const catName = (lastCat && lastCat.name) ? (typeof lastCat.name === 'string' ? lastCat.name : (lastCat.name.ar || lastCat.name.en || '')) : '';
                    if (catName && lastCat.id && lastCat.slug) {
                        categoryHtml =
                            '<p class="outlit-product-card__category">' +
                                '<a href="/categories/' + lastCat.id + '/' + (lastCat.slug || '') + '">' + catName + '</a>' +
                            '</p>';
                    }
                } else if (product.category && product.category.name) {
                    categoryHtml = '<p class="outlit-product-card__category">' + product.category.name + '</p>';
                }

                let addCartHtml = '';
                if (product.is_infinite || product.quantity > 0) {
                    if (hasOptions || product.has_fields || product.product_class === 'dynamic_bundle') {
                        addCartHtml =
                            '<a href="/products/' + productSlug + '" class="outlit-product-card__add-cart-btn" aria-label="' + addToCartLabel + '">' +
                                '<span class="outlit-product-card__add-cart-icon" aria-hidden="true">' +
                                    CART_CATEGORY_SVG_OPTIONS +
                                '</span>' +
                            '</a>';
                    } else {
                        addCartHtml =
                            '<div class="outlit-product-card__add-cart-wrap" data-product-id="' + productId + '">' +
                                '<button type="button" class="outlit-product-card__add-cart-btn outlit-product-card__add-cart-btn--ajax" onclick="event.preventDefault(); event.stopPropagation(); productCartAddToCart(this, \'' + productId + '\')" aria-label="' + addToCartLabel + '">' +
                                    '<span class="outlit-product-card__add-cart-progress add-to-cart-progress outlit-product-card__add-cart-points d-none" aria-hidden="true">' +
                                        '<span></span><span></span><span></span>' +
                                    '</span>' +
                                    '<span class="outlit-product-card__add-cart-icon" aria-hidden="true">' +
                                        CART_CATEGORY_SVG_ADD +
                                    '</span>' +
                                '</button>' +
                                '<div class="outlit-product-card__quantity-wrap d-none" role="group" aria-label="' + qtyLabel + '">' +
                                    '<button type="button" class="outlit-product-card__qty-btn outlit-product-card__qty-plus" aria-label="' + increaseQtyLabel + '">+</button>' +
                                    '<span class="outlit-product-card__qty-num" data-qty>1</span>' +
                                    '<button type="button" class="outlit-product-card__qty-btn outlit-product-card__qty-minus" aria-label="' + decreaseQtyLabel + '">−</button>' +
                                    '<button type="button" class="outlit-product-card__qty-remove" onclick="event.preventDefault(); event.stopPropagation(); productCardRemoveFromCart(this)" aria-label="{{ _('Remove from cart') }}">' +
                                        '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><path d="M3 6h18M8 6V4a2 2 0 012-2h4a2 2 0 012 2v2m3 0v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6h14z"/><path d="M10 11v6M14 11v6"/></svg>' +
                                    '</button>' +
                                '</div>' +
                            '</div>';
                    }
                } else {
                    addCartHtml =
                        '<div class="outlit-product-card__out-of-stock-cta">' +
                            '<a class="btn btn-primary btn-product-card-out-of-stock" href="/products/' + productSlug + '">' +
                                '<img src="' + uBellUrl + '" alt="" width="18" height="18" class="d-inline" aria-hidden="true">' +
                                '<span>' + notifyWhenAvailableText + '</span>' +
                            '</a>' +
                        '</div>';
                }

                article.innerHTML =
                    '<div class="outlit-product-card__img-wrap" style="height: var(--outlit-card-img-height, 280px);">' +
                        '<a href="/products/' + productSlug + '" class="outlit-product-card__img-link" aria-label="' + productName.replace(/"/g, '&quot;') + '">' +
                            '<div class="outlit-product-card__img-inner">' +
                                '<img id="product-card-img-' + productId + '"' +
                                     ' class="outlit-product-card__img"' +
                                     ' src="' + mainImg + '"' +
                                     ' width="' + width + '"' +
                                     ' height="' + height + '"' +
                                     ' loading="lazy" decoding="async"' +
                                     ' alt="' + productName.replace(/"/g, '&quot;') + '">' +
                            '</div>' +
                        '</a>' +
                        (badge ? (
                            '<div class="badge-name badge-name-product-card">' +
                                (badgeIconEscaped ? '<span class="badge-icon ' + badgeIconEscaped + '"></span>' : '') +
                                (badgeBodyEscaped ? '<span class="badge-text">' + badgeBodyEscaped + '</span>' : '') +
                            '</div>'
                        ) : '') +
                        wishlistHtml +
                        '<span class="product-card-bundle-offer" data-bundle-offer-product-id="' + productId + '" aria-hidden="true"></span>' +
                        '<div class="outlit-product-card__row outlit-product-card__row--rating-cart">' +
                            (ratingHtml || '') +
                            addCartHtml +
                        '</div>' +
                    '</div>' +
                    '<div class="outlit-product-card__body">' +
                        categoryHtml +
                        '<h3 class="outlit-product-card__title">' +
                            '<a href="/products/' + productSlug + '">' + productName + '</a>' +
                        '</h3>' +
                        priceHtml +
                    '</div>';

                productsSlider.appendChild(article);
            });
            
            // Initialize bundle offers if available
            if (typeof window.initBundleOffers === 'function') {
                window.initBundleOffers();
            }
            
            // Initialize Slick Carousel
            if (typeof $ !== 'undefined' && $.fn.slick) {
                const $slider = $(productsSlider);
                
                // Destroy existing slider if any
                if ($slider.hasClass('slick-initialized')) {
                    $slider.slick('unslick');
                }
                
                const arrowNextClass = window.appDirection === 'ltr' ? 'icon-keyboard_arrow_right' : 'icon-keyboard_arrow_left';
                const arrowPrevClass = window.appDirection === 'ltr' ? 'icon-keyboard_arrow_left' : 'icon-keyboard_arrow_right';
                const screenWidth = window.screen.width;
                const editingMode = {{ 'true' if store.editing_mode else 'false' }};
                const slidesCount = products.length;
                
                if (screenWidth >= 0 || editingMode) {
                    $slider.slick({
                        slidesToShow: 1.5,
                        slidesToScroll: 1,
                        infinite: false,
                        autoplay: false,
                        arrows:false,
                        dots: false,
                        rtl: !(window.appDirection === 'ltr'),
                        nextArrow: '<button class="slick-next slick-arrow" aria-label="Next" type="button"><span class="' + arrowNextClass + '"></span></button>',
                        prevArrow: '<button class="slick-prev slick-arrow" aria-label="Previous" type="button"><span class="' + arrowPrevClass + '"></span></button>',
                        responsive: [
                           {
            breakpoint: 380,
            settings: {
                slidesToShow: 1.5,
                slidesToScroll: 1
            }
        }              ]
                    });
                }
            }

        } catch (err) {
            if (loader) {
                loader.textContent = err && err.message === 'timeout'
                    ? "{{ _('Failed to load products') }}"
                    : "{{ _('Failed to load products') }}";
            }
        }
    }

    loadCategoryProducts();
});
})();
</script>
{% endif %}
