<footer class="taqni-footer taqni-footer--dark">
    <div class="taqni-footer-top">
        <div class="container">
            <div class="taqni-footer-grid">
                <!-- Column 1: Brand Info -->
                <div class="taqni-footer-col taqni-footer-brand">
                    <a href="/" class="taqni-footer-logo">
                        {% set logoUrl = settings.about_us_logo or store.logo %}
                        <img src="{{ image_url(logoUrl, h=100, q=100) }}" alt="{{ store.name }}">
                    </a>
                    <div class="taqni-footer-bio">
                        <p>{{ settings.about_us_des | safe }}</p>
                    </div>
                    
                    <div class="taqni-footer-social">
                        {% set social_links = [
                            {'id': 'facebook', 'icon': 'icon-facebook-f'},
                            {'id': 'instagram', 'icon': 'icon-instagram'},
                            {'id': 'twitter', 'icon': 'x-icon-twitter'},
                            {'id': 'snapchat', 'icon': 'icon-snapchat-ghost'},
                            {'id': 'tiktok', 'icon': 'icon-tiktok'},
                            {'id': 'phone', 'icon': 'icon-call'},
                            {'id': 'email', 'icon': 'icon-envelope-secondary'}
                        ] %}
                        <div class="social-icons-row">
                            {% for social in social_links %}
                                {% set url = safeget(store.settings.contact, social.id) %}
                                {% if url %}
                                    <a href="{{ 'https://' ~ social.id ~ '.com/' ~ url if social.id not in ['phone', 'email'] else (('tel:' if social.id == 'phone' else 'mailto:') ~ url) }}" target="_blank" class="social-item">
                                        {% if social.id == 'twitter' %}
                                            <svg viewBox="0 0 512 512" class="social-svg"><path d="M389.2 48h70.6L305.6 224.2 487 464H345L233.7 318.6 106.5 464H35.8L200.7 275.5 26.8 48H172.4L272.9 180.9 389.2 48zM364.4 421.8h39.1L151.1 88h-42L364.4 421.8z" fill="currentColor"/></svg>
                                        {% else %}
                                            <i class="{{ social.icon }}"></i>
                                        {% endif %}
                                    </a>
                                {% endif %}
                            {% endfor %}
                        </div>
                    </div>
                </div>

                <!-- Column 2: Navigation Groups -->
                <div class="taqni-footer-col taqni-footer-nav">
                    <div class="nav-groups-grid">
                        {% if settings.links_1_links %}
                            <div class="nav-group">
                                <h4 class="nav-title">{{ settings.links_1_title }}</h4>
                                <ul class="nav-list">
                                    {% for link in settings.links_1_links %}
                                        <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                                    {% endfor %}
                                </ul>
                            </div>
                        {% endif %}
                        
                        {% if settings.links_2_links %}
                            <div class="nav-group">
                                <h4 class="nav-title">{{ settings.links_2_title }}</h4>
                                <ul class="nav-list">
                                    {% for link in settings.links_2_links %}
                                        <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                                    {% endfor %}
                                </ul>
                            </div>
                        {% endif %}

                        {% if settings.links_3_links %}
                            <div class="nav-group">
                                <h4 class="nav-title">{{ settings.links_3_title | default(_("Legal Links")) }}</h4>
                                <ul class="nav-list">
                                    {% for link in settings.links_3_links %}
                                        <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                                    {% endfor %}
                                </ul>
                            </div>
                        {% endif %}
                    </div>
                </div>

                <!-- Column 3: Featured Image -->
                <div class="taqni-footer-col taqni-footer-image">
                    {% set footer_img = settings.featured_image_image %}
                    <div class="featured-image-wrap">
                        {% if footer_img %}
                            <img src="{{ image_url(footer_img, w=1000) }}" alt="Footer Banner" class="footer-feat-img">
                        {% else %}
                            <div class="footer-feat-img-placeholder"></div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Bottom Bar -->
    <div class="taqni-footer-bottom">
        <div class="container">
            <div class="bottom-bar-flex">
                <div class="copyright">
                    <p>{{ store.settings.branding.copyrights | default('All rights reserved to ' ~ store.name ~ ' © 2026') | safe }}</p>
                </div>
                <div class="bottom-links">
                    <a href="/p/terms-and-conditions">{{ _("Terms & Conditions") }}</a>
                    <a href="/p/privacy-policy">{{ _("Privacy Policy") }}</a>
                </div>
            </div>
        </div>
    </div>
</footer>

<style>
    .taqni-footer--dark {
        background-color: #0b0b1a; /* Dark premium navy */
        color: rgba(255, 255, 255, 0.8);
        border-top: 1px solid rgba(255, 255, 255, 0.05);
    }

    .taqni-footer-top {
        padding: 100px 0 80px;
    }

    .taqni-footer-grid {
        display: grid;
        grid-template-columns: 1.2fr 2fr 1.2fr;
        gap: 80px;
    }

    .taqni-footer-logo img {
        max-height: 45px;
        margin-bottom: 30px;
        display: block;
        filter: brightness(0) invert(1);
    }

    .taqni-footer-bio p {
        font-size: 16px;
        line-height: 1.8;
        margin-bottom: 35px;
        max-width: 300px;
        color: rgba(255, 255, 255, 0.5);
    }

    .social-icons-row {
        display: flex;
        gap: 15px;
    }

    .social-item {
        width: 42px;
        height: 42px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.08);
        color: rgba(255, 255, 255, 0.7);
        text-decoration: none !important;
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    }

    .social-item:hover {
        background: #fff;
        color: #000;
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.3);
    }

    .social-svg {
        width: 16px;
        height: 16px;
    }

    .nav-groups-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 40px;
    }

    .nav-title {
        color: #fff;
        font-size: 24px;
        font-weight: 700;
        margin-bottom: 25px;
        letter-spacing: 0.5px;
    }

    .nav-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .nav-list li {
        margin-bottom: 14px;
    }

    .nav-list a {
        color: rgba(255, 255, 255, 0.45);
        text-decoration: none !important;
        font-size: 16px;
        transition: color 0.3s ease, padding-right 0.3s ease;
        display: block;
    }

    .nav-list a:hover {
        color: #fff;
        padding-right: 5px;
    }

    .featured-image-wrap {
        width: 100%;
        aspect-ratio: 16 / 9;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 20px 40px rgba(0,0,0,0.4);
    }

    .footer-feat-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.6s ease;
    }

    .featured-image-wrap:hover .footer-feat-img {
        transform: scale(1.05);
    }

    .footer-feat-img-placeholder {
        width: 100%;
        height: 100%;
        background: linear-gradient(135deg, #1a1a2e, #16213e);
    }

    .taqni-footer-bottom {
        border-top: 1px solid rgba(255, 255, 255, 0.05);
        padding: 30px 0;
    }

    .bottom-bar-flex {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .copyright p {
        font-size: 13px;
        color: rgba(255, 255, 255, 0.3);
        margin: 0;
    }

    .bottom-links {
        display: flex;
        gap: 30px;
    }

    .bottom-links a {
        font-size: 13px;
        color: rgba(255, 255, 255, 0.3);
        text-decoration: none !important;
        transition: color 0.3s ease;
    }

    .bottom-links a:hover {
        color: #fff;
    }

    @media (max-width: 991px) {
        .taqni-footer-grid {
            grid-template-columns: 1fr;
            gap: 50px;
        }

        .nav-groups-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .bottom-bar-flex {
            flex-direction: column-reverse;
            gap: 20px;
            text-align: center;
        }
        
        .taqni-footer-bio p {
            max-width: 100%;
        }
    }
</style>
