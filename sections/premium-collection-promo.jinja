                        </svg>

                    </button>

                    <a href="/products/{{ item.product.slug }}" class="product-popup">
                        <div class="popup-thumb">
                            <img src="{{ image_url(item.product.main_image.image.small, w=160, q=80) }}" alt="{{ item.product.name }}">
                        </div>
                        <div class="popup-info">
                            <h4 class="popup-title">{{ item.product.name }}</h4>
                            <div class="popup-price">{{ item.product.formatted_price }}</div>
                        </div>
                        <div class="popup-cart-icon">
                            <svg width="24" height="24" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
