                            </svg>
                        </div>
                    </a>
                {% endif %}
            </div>
            {% endfor %}
        </div>

        <div class="promo-footer">
            {% if settings.title %}
                <h2 class="promo-title">{{ settings.title }}</h2>
            {% endif %}
            {% if settings.description %}
                <p class="promo-desc">{{ settings.description }}</p>
            {% endif %}
        </div>
    </div>
</section>
