<section class="sticky-category-promo" id="{{ sectionId }}" 
    style="--bg-color: {{ settings.bg_color | default('#fff') }}; 
           --text-color: {{ settings.text_color | default('#111') }};">
    
    <style>
        .sticky-category-promo {
            background-color: var(--bg-color);
            color: var(--text-color);
            overflow: clip;
        }

        .promo-container {
            display: flex;
            align-items: flex-start;
            width: 100%;
            gap: 0;
        }

        .sticky-image-box {
            flex: 0 0 45%;
            position: sticky;
            top: 0;
            overflow: hidden;
            aspect-ratio: auto;
            height: 100vh;
        }

        .sticky-image-box img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .content-products-wrapper {
            flex: 1;
            display: flex;
            gap: 40px;
            align-items: flex-start;
            padding: 0 50px;
            box-sizing: border-box;
        }

        .sticky-content-box {
            flex: 0 0 62%;
            position: sticky;
            top: 80px;
            padding-top: 20px;
        }

        .content-block {
            margin-bottom: 48px;
        }

        .content-block h3 {
            font-size: 28px;
            font-weight: 700;
            margin-bottom: 16px;
            line-height: 1.2;
        }

        .content-block p {
            font-size: 16px;
            line-height: 1.6;
            opacity: 0.8;
        }

        .products-scroll-box {
            padding: 20px 0;
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 24px;
        }

        .products-scroll-box .product-card {
            width: 100%;
            max-width: 400px;
        }

        @media (max-width: 1024px) {
            .promo-container {
                flex-direction: column;
                display: flex;
            }

            .sticky-image-box {
                flex: 0 0 100% !important;
                width: 100% !important;
                height: auto;
                position: relative;
                top: 0;
            }

            .content-products-wrapper {
                flex: 0 0 100%;
                display: flex;
                flex-wrap: nowrap; 
                gap: 10px;
                padding: 0;
                width: 100%;
                align-items: flex-start;
            }

            .sticky-content-box {
                flex: 0 0 38%; /* Fixed percentage */
                position: sticky;
                top: 80px;
                padding: 15px 0 15px 15px;
                z-index: 10;
                box-sizing: border-box;
            }

            .products-scroll-box {
                flex: 1; /* Take remaining space */
                gap: 12px;
                padding: 15px 15px 15px 0;
                box-sizing: border-box;
                min-width: 0; /* Allow shrinking */
            }

            .products-scroll-box .product-card {
                width: 100% !important;
                max-width: 100% !important;
                margin: 0 !important;
            }

            .content-block {
                margin-bottom: 20px;
            }

            .content-block h3 {
                font-size: 16px;
                margin-bottom: 8px;
            }
            .content-block p {
                font-size: 12px;
                line-height: 1.3;
            }
        }

        @media (max-width: 576px) {
            .sticky-content-box {
                flex: 0 0 calc(40% - 8px);
            }
            .products-scroll-box {
                flex: 0 0 calc(60% - 8px);
            }
        }
    </style>

   
    <div class="promo-container">
        <div class="sticky-image-box">
            {% if settings.main_image %}
                <img src="{{ image_url(settings.main_image, w=1000, q=90) }}" alt="Sticky Promo" loading="lazy">
            {% endif %}
        </div>

        <div class="content-products-wrapper">
            <div class="sticky-content-box">
                {% for block in settings.content_blocks %}
                    <div class="content-block">
                        {% if block.title %}
                            <h3>{{ block.title }}</h3>
                        {% endif %}
                        {% if block.description %}
                            <p>{{ block.description }}</p>
                        {% endif %}
                    </div>
                {% endfor %}
            </div>

            <div class="products-scroll-box">
                {% for product in safeget(settings, "category.products.results", []) %}
                    {% set index=loop.index0 %}{% include 'components/product-card.jinja' %}
                {% endfor %}
            </div>
        </div>
    </div>

</section>
