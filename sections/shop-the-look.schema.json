{
  "section_id": "uuid",
  "template": "sections/shop-the-look.jinja",
  "icon": "fal fa-eye",
  "name": {
    "ar": "تسوق المظهر",
    "en": "Shop the Look"
  },
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": {
        "ar": "العنوان الرئيسي",
        "en": "Main Title"
      }
    },
    {
      "type": "textarea",
      "id": "description",
      "label": {
        "ar": "الوصف",
        "en": "Description"
      }
    },
    {
      "type": "color",
      "id": "background_color",
      "label": {
        "ar": "لون خلفية القسم",
        "en": "Section Background Color"
      },
      "default": "#f3f3f5"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": {
        "ar": "لون العنوان",
        "en": "Title Color"
      },
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "description_color",
      "label": {
        "ar": "لون الوصف",
        "en": "Description Color"
      },
      "default": "#555555"
    },
    {
      "type": "number",
      "id": "slides_desktop",
      "label": {
        "ar": "عدد الشرائح (سطح المكتب)",
        "en": "Slides per view (Desktop)"
      },
      "default": 4
    },
    {
      "type": "number",
      "id": "slides_tablet",
      "label": {
        "ar": "عدد الشرائح (التابلت)",
        "en": "Slides per view (Tablet)"
      },
      "default": 2
    },
    {
      "type": "number",
      "id": "slides_mobile",
      "label": {
        "ar": "عدد الشرائح (الجوال)",
        "en": "Slides per view (Mobile)"
      },
      "default": 1.2
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": {
        "ar": "تشغيل تلقائي",
        "en": "Autoplay"
      },
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_pagination",
      "label": {
        "ar": "إظهار نقاط التنقل",
        "en": "Show Pagination"
      },
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_navigation",
      "label": {
        "ar": "إظهار أزرار التنقل (Next/Prev)",
        "en": "Show Navigation Arrows"
      },
      "default": true
    },
    {
      "type": "list",
      "id": "looks_list",
      "label": {
        "ar": "قائمة الإطلالات",
        "en": "Looks List"
      },
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": {
            "ar": "المنتج",
            "en": "Product"
          }
        },
        {
          "type": "video",
          "id": "video",
          "label": {
            "ar": "فيديو",
            "en": "Video"
          }
        },
        {
          "type": "image",
          "id": "image",
          "label": {
            "ar": "صورة",
            "en": "Image"
          }
        }
      ]
    }
  ]
}
