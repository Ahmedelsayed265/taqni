{% set gallery_items = safeget(settings, 'gallery', []) %}
{% if gallery_items is none %}{% set gallery_items = [] %}{% endif %}

<section id="{{ sectionId }}"
         class="hotspot-nested-gallery-section"
         style="
           {% if settings.primary_color %}--primary-color: {{ settings.primary_color }};{% endif %}
           {% if settings.hotspot_color %}--hotspot-color: {{ settings.hotspot_color }};{% endif %}
         ">
  
  <div class="hotspot-gallery-grid layout-count-{{ gallery_items | length }}">
    {% for item in gallery_items %}
        {% set bg_image = item.image %}
        {% set bg_url = (bg_image if bg_image is string else (safeget(bg_image, 'url') or safeget(bg_image, 'image') or '')) %}
        {% set hotspots = safeget(item, 'hotspots', []) %}
        {% if hotspots is none %}{% set hotspots = [] %}{% endif %}

        <div class="hotspot-item-wrap" id="wrap-{{ sectionId }}-{{ loop.index }}">
            {% if bg_url %}
                <img src="{{ image_url(bg_url, w=1200) }}" class="hotspot-bg" alt="Gallery Image {{ loop.index }}">
            {% else %}
                <div class="placeholder-bg">Upload Image {{ loop.index }}</div>
            {% endif %}

            {% for hotspot in hotspots %}
                {% set product = safeget(hotspot, 'product') %}
                {% if product %}
                    {% set prod_img = safeget(product.main_image, 'image.small') or safeget(product.main_image, 'image.medium') or safeget(product, 'image_url') or '' %}
                    {% set prod_price = safeget(product, 'formatted_sale_price') or safeget(product, 'formatted_price') or format_price(product.price) %}
                    <button type="button"
                            class="hotspot-dot"
                            data-product-name="{{ product.name | e }}"
                            data-product-price="{{ prod_price | e }}"
                            data-product-image="{{ image_url(prod_img, w=400) | e }}"
                            data-product-url="{{ product_url(product) | e }}"
                            style="left: {{ hotspot.x | default(50) }}%; top: {{ hotspot.y | default(50) }}%;">
                        <span class="hotspot-dot-inner">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path fill-rule="evenodd" clip-rule="evenodd" d="M12 3.25C12.4142 3.25 12.75 3.58579 12.75 4V11.25H20C20.4142 11.25 20.75 11.5858 20.75 12C20.75 12.4142 20.4142 12.75 20 12.75H12.75V20C12.75 20.4142 12.4142 20.75 12 20.75C11.5858 20.75 11.25 20.4142 11.25 20V12.75H4C3.58579 12.75 3.25 12.4142 3.25 12C3.25 11.5858 3.58579 11.25 4 11.25H11.25V4C11.25 3.58579 11.5858 3.25 12 3.25Z" fill="#161616"/>
                            </svg>
                        </span>
                    </button>
                {% endif %}
            {% endfor %}

            {% if settings.show_helper %}
                <div class="hotspot-helper">IMG {{ loop.index }}: Coords Mode</div>
            {% endif %}
        </div>
    {% endfor %}

    <!-- Shared Floating Card -->
    <div class="hotspot-card" id="card-{{ sectionId }}" aria-hidden="true" hidden>
        <div class="hotspot-card-inner">
            <a class="hotspot-card-link" href="#" data-card-link>
                <img class="hotspot-card-img" src="" alt="" data-card-img>
                <div class="hotspot-card-content">
                    <h3 class="hotspot-card-title" data-card-title></h3>
                    <p class="hotspot-card-price" data-card-price></p>
                    <span class="hotspot-card-tag">Explore details</span>
                </div>
            </a>
        </div>
    </div>
  </div>

  <style>
    .hotspot-nested-gallery-section {
      --primary-color: #1a1a1a;
      --hotspot-color: #fff;
    }

    .hotspot-gallery-grid {
      display: grid;
      gap: 0;
      width: 100%;
      margin: 0 auto;
      position: relative;
    }

    /* Auto responsive grid */
    .layout-count-1 { grid-template-columns: 1fr; }
    .layout-count-2 { grid-template-columns: 1fr 1fr; }
    .layout-count-3, .layout-count-4 { grid-template-columns: 1fr 1fr; }
    @media (min-width: 992px) {
        .layout-count-3 { grid-template-columns: 1fr 1fr 1fr; }
        .layout-count-4 { grid-template-columns: 1fr 1fr 1fr 1fr; }
    }

    .hotspot-item-wrap {
      position: relative;
      width: 100%;
      aspect-ratio: 1 / 1;
      overflow: hidden;
      background: #f8f8f8;
      box-shadow: 0 10px 30px rgba(0,0,0,0.06);
    }

    .hotspot-bg {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.5s ease;
    }

    .placeholder-bg {
        width: 100%; height: 100%; display: flex; align-items: center; justify-content: center;
        background: #eee; color: #999; font-weight: 700;
    }

    .hotspot-dot {
      position: absolute;
      width: 54px;
      height: 54px;
      padding: 0;
      border: none;
      border-radius: 50%;
      cursor: pointer;
      background: transparent;
      transform: translate(-50%, -50%);
      z-index: 10;
    }

    .hotspot-dot-inner {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      height: 100%;
      border-radius: 50%;
      background: var(--hotspot-color);
      box-shadow: 0 4px 15px rgba(0,0,0,0.3);
      position: relative;
      z-index: 2;
      transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    .hotspot-dot-inner svg {
        width: 20px;
        height: 20px;
    }


    .hotspot-dot::before {
      content: '';
      position: absolute;
      inset: 0;
      background: var(--hotspot-color);
      border-radius: 50%;
      opacity: 0.5;
      animation: hotspot-pulse 2s infinite;
    }

    @keyframes hotspot-pulse {
      0% { transform: scale(1); opacity: 0.5; }
      100% { transform: scale(3.5); opacity: 0; }
    }

    /* Card Styling */
    .hotspot-card {
      position: absolute;
      z-index: 100;
      width: 280px;
      opacity: 0;
      visibility: hidden;
      transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
      pointer-events: none;
    }

    .hotspot-card[aria-hidden="false"] {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
    }

    .hotspot-card-inner {
      background: rgba(255, 255, 255, 0.98);
      backdrop-filter: blur(10px);
      border-radius: 12px;
      padding: 10px;
      box-shadow: 0 20px 50px rgba(0,0,0,0.2);
      border: 1px solid rgba(0,0,0,0.05);
    }

    .hotspot-card-link { display: flex; gap: 12px; text-decoration: none; color: inherit; }
    .hotspot-card-img { width: 70px; height: 70px; object-fit: cover; border-radius: 8px; }
    .hotspot-card-content { flex: 1; display: flex; flex-direction: column; justify-content: center; }
    .hotspot-card-title { font-size: 14px; font-weight: 700; margin: 0 0 2px; color: #1a1a1a; line-height: 1.2; }
    .hotspot-card-price { font-size: 14px; font-weight: 600; color: var(--primary-color); }
    .hotspot-card-tag { font-size: 10px; color: #999; text-transform: uppercase; margin-top: 4px; }

    .hotspot-helper {
        position: absolute;
        top: 10px;
        left: 10px;
        background: rgba(0,0,0,0.85);
        color: #fff;
        padding: 6px 10px;
        border-radius: 6px;
        font-size: 10px;
        z-index: 50;
        display: none;
    }

    @media (max-width: 768px) {
      .hotspot-nested-gallery-section { margin: 30px 0; padding: 0 15px; }
      .layout-count-2, .layout-count-3, .layout-count-4 { grid-template-columns: 1fr; }
      .hotspot-item-wrap { aspect-ratio: 4 / 3; }
      .hotspot-card { width: calc(100vw - 60px); max-width: 280px; }
    }
  </style>

  <script>
    (function() {
      const section = document.getElementById('{{ sectionId }}');
      if (!section) return;

      const grid = section.querySelector('.hotspot-gallery-grid');
      const card = section.querySelector('.hotspot-card');
      const trigger = '{{ settings.trigger_type | default("click") }}';
      const showHelper = {{ settings.show_helper | lower }};

      section.querySelectorAll('.hotspot-item-wrap').forEach(wrap => {
          const dots = wrap.querySelectorAll('.hotspot-dot');
          const helper = wrap.querySelector('.hotspot-helper');

          if (showHelper && helper) {
              helper.style.display = 'block';
              wrap.addEventListener('mousemove', (e) => {
                  const rect = wrap.getBoundingClientRect();
                  const x = ((e.clientX - rect.left) / rect.width * 100).toFixed(2);
                  const y = ((e.clientY - rect.top) / rect.height * 100).toFixed(2);
                  helper.innerHTML = `X: ${x} | Y: ${y}`;
              });
          }

          dots.forEach(dot => {
              const openHandler = (e) => {
                  if (e) e.stopPropagation();
                  card.querySelector('[data-card-title]').textContent = dot.getAttribute('data-product-name');
                  const price = dot.getAttribute('data-product-price');
                  const priceEl = card.querySelector('[data-card-price]');
                  priceEl.textContent = price;
                  priceEl.style.display = price ? 'block' : 'none';

                  card.querySelector('[data-card-img]').src = dot.getAttribute('data-product-image');
                  card.querySelector('[data-card-link]').href = dot.getAttribute('data-product-url');
                  card.removeAttribute('hidden');
                  card.setAttribute('aria-hidden', 'false');

                   const gridRect = grid.getBoundingClientRect();
                  const dotRect = dot.getBoundingClientRect();
                  const cardRect = card.getBoundingClientRect();

                  // Calculate preferred position (Top Center)
                  let left = dotRect.left - gridRect.left + (dotRect.width / 2) - (cardRect.width / 2);
                  let top = dotRect.top - gridRect.top - cardRect.height - 15;

                  // 1. Vertical Flip: If no space on top, move to bottom
                  if (top < 10) {
                      top = dotRect.top - gridRect.top + dotRect.height + 15;
                  }

                  // 2. Horizontal Adjustment: If cut on right, move left. If cut on left, move right.
                  if (left + cardRect.width > gridRect.width - 10) {
                      left = gridRect.width - cardRect.width - 10;
                  }
                  if (left < 10) {
                      left = 10;
                  }

                  card.style.left = left + 'px';
                  card.style.top = top + 'px';
              };

              if (trigger === 'hover') {
                  dot.addEventListener('mouseenter', openHandler);
                  wrap.addEventListener('mouseleave', () => {
                      card.setAttribute('aria-hidden', 'true');
                      setTimeout(() => card.setAttribute('hidden', ''), 400);
                  });
              } else {
                  dot.addEventListener('click', openHandler);
              }
          });
      });

      document.addEventListener('click', (e) => {
        if (!card.contains(e.target) && !e.target.closest('.hotspot-dot')) {
          card.setAttribute('aria-hidden', 'true');
          setTimeout(() => card.setAttribute('hidden', ''), 400);
        }
      });
    })();
  </script>
</section>
