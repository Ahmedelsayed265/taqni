<section class="category-products s_block" id="{{ sectionId }}" section-id="{{ sectionId }}">
    <div class="container">
        <div class="view-all-header">
            <h2>{{ settings.title }}</h2>

            {% if settings.view_all_url %}
            <a href="{{ settings.view_all_url }}">{{ settings.view_all_text }}</a>
            {% endif %}
        </div>

        <div class="swiper category-products-slider"
             data-autoplay="{{ settings.slider_autoplay | default(false) }}"
             data-delay="{{ settings.slider_autoplay_delay | default(3000) }}"
             data-arrows="{{ settings.slider_show_arrows | default(false) }}"
             data-pagination="{{ settings.slider_show_pagination | default(false) }}">
            <div class="swiper-wrapper">
                {% for product in safeget(settings, "category.products.results", []) %}
                <div class="swiper-slide">
                    {% set index=loop.index0 %}{% include 'components/product-card.jinja' %}
                </div>
                {% endfor %}
            </div>

            {% if settings.slider_show_pagination | default(false) %}
            <div class="swiper-pagination custom-swiper-pagination"></div>
            {% endif %}

            {% if settings.slider_show_arrows | default(false) %}
            <div class="swiper-button-prev"></div>
            <div class="swiper-button-next"></div>
            {% endif %}
        </div>
    </div>
</section>

<script>
    (function () {
        function initCategorySlider() {
            var section = document.querySelector('[section-id="{{ sectionId }}"]');
            if (!section) return;

            var sliderEl = section.querySelector('.category-products-slider');
            if (!sliderEl) return;

            var isAutoplay = sliderEl.getAttribute('data-autoplay') === 'true';
            var autoplayDelay = parseInt(sliderEl.getAttribute('data-delay')) || 3000;
            var isArrows = sliderEl.getAttribute('data-arrows') === 'true';
            var isPagination = sliderEl.getAttribute('data-pagination') === 'true';

            if (window.Swiper) {
                new Swiper(sliderEl, {
                    slidesPerView: 1.5,
                    spaceBetween: 10,
                    loop: false,
                    rtl: document.documentElement.dir === 'rtl',
                    autoplay: isAutoplay ? {
                        delay: autoplayDelay,
                        disableOnInteraction: false
                    } : false,
                    pagination: isPagination ? {
                        el: sliderEl.querySelector('.swiper-pagination'),
                        clickable: true
                    } : false,
                    navigation: isArrows ? {
                        nextEl: sliderEl.querySelector('.swiper-button-next'),
                        prevEl: sliderEl.querySelector('.swiper-button-prev')
                    } : false,
                    breakpoints: {
                        640: { slidesPerView: 1.5, spaceBetween: 12 },
                        768: { slidesPerView: 3, spaceBetween: 16 },
                        1024: { slidesPerView: 5.5, spaceBetween: 20 }
                    }
                });
            }
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initCategorySlider);
        } else {
            setTimeout(initCategorySlider, 100);
        }
    })();
</script>