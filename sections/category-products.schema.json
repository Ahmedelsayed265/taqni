{
  "section_id": "uuid",
  "template": "sections/category-products.jinja",
  "icon": "fal fa-home",
  "name": {
    "ar": "منتجات حسب القسم",
    "en": "Products by Category"
  },
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": { "ar": "العنوان", "en": "Title" }
    },
    {
      "type": "url",
      "id": "view_all_url",
      "label": { "ar": "رابط عرض الكل", "en": "View All URL" }
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": { "ar": "نص عرض الكل", "en": "View All Text" }
    },
    {
      "type": "category_products",
      "id": "category",
      "label": { "ar": "القسم", "en": "Category" }
    },
    {
      "id": "slider_autoplay",
      "type": "checkbox",
      "label": { "ar": "تشغيل تلقائي", "en": "Autoplay" },
      "default": false
    },
    {
      "id": "slider_autoplay_delay",
      "type": "number",
      "label": { "ar": "سرعة التشغيل التلقائي (بالمللي ثانية)", "en": "Autoplay Delay (ms)" },
      "default": 3000
    },
    {
      "id": "slider_show_arrows",
      "type": "checkbox",
      "label": { "ar": "إظهار أسهم التنقل", "en": "Show Navigation Arrows" },
      "default": false
    },
    {
      "id": "slider_show_pagination",
      "type": "checkbox",
      "label": { "ar": "إظهار نقاط الترقيم", "en": "Show Pagination" },
      "default": false
    }
  ]
}
