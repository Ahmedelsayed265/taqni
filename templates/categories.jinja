{% extends "layout.jinja" %}

{% block header %} {% include 'header.jinja' %} {% endblock %}


{% block top_links %}
    <link rel="stylesheet" href="{{ 'category-style.css?v=1.13' | asset_url }}">
{% endblock %}

{% block main_content %}

    {% macro category_tile(cat) %}
        {% if cat and cat.cover_image %}
            <div class="all-cat-col">
                <a class="card-categories-wrapper category-tile"
                   href="{{ url_for('category_details', category_id=cat.id or 'a', slug=cat.slug or cat.id) }}"
                   aria-label="{{ cat.name }}">
                    <div class="card-categories">
                        <div class="ratio21_9">
                            <img class="categories-image" src="{{ cat.cover_image }}" alt="{{ cat.img_alt_text or cat.name }}">
                        </div>
                    </div>
                </a>
            </div>
        {% endif %}
    {% endmacro %}

    <section class="breadcrumb-section">
        <nav aria-label="{{ _('Breadcrumb') }}">
        
            <ol class="breadcrumb">
                <div class="container d-flex flex-wrap align-items-center" style="gap: 12px;">
                    <li class="breadcrumb-item" aria-current="page"><a href="/">{{ _("Home") }}</a></li>
                    <svg width="8" height="14" viewBox="0 0 8 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M0.750047 0.750046C0.750047 0.750046 6.74999 5.16898 6.75 6.75009C6.75001 8.33121 0.75 12.75 0.75 12.75" stroke="#404040" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <li class="breadcrumb-item active " aria-current="page">{{ _("All categories") }}</li>
                </div>
            </ol>
        </nav>
    </section>

    <div class="container mb-5">
        <div class="row categories-row">
            {% for category in categories %}
                {{ category_tile(category) }}

                {% if category.sub_categories and (category.sub_categories | length > 0) %}
                    {% for sub_category in category.sub_categories %}
                        {{ category_tile(sub_category) }}

                        {% if sub_category.sub_categories and (sub_category.sub_categories | length > 0) %}
                            {% for subTwo_category in sub_category.sub_categories %}
                                {{ category_tile(subTwo_category) }}
                            {% endfor %}
                        {% endif %}
                    {% endfor %}
                {% endif %}
            {% endfor %}
        </div>
    </div>

{% endblock %}

{% block footer_scripts %}
    <script src="{{ 'masonry.pkgd.min.js' | asset_url }}" defer></script>
    <script>

        document.addEventListener("DOMContentLoaded", function () {
            var rowEl = document.querySelector('.categories-row');
            if (!rowEl || typeof Masonry === 'undefined') return;

            var msnry = new Masonry(rowEl, {
                itemSelector: '.all-cat-col',
                percentPosition: true
            });

            var scheduleLayout = function () {
                if (!msnry) return;
                requestAnimationFrame(function () { msnry.layout(); });
            };

            // Re-layout after images load (prevents big gaps)
            var imgs = rowEl.querySelectorAll('img.categories-image');
            imgs.forEach(function (img) {
                if (img.complete) return;
                img.addEventListener('load', scheduleLayout, { once: true });
                img.addEventListener('error', scheduleLayout, { once: true });
            });

            // Also layout after full page load just in case
            window.addEventListener('load', scheduleLayout, { once: true });
        });


    </script>
{% endblock %}


{% block footer %} {% include 'footer.jinja' %} {% endblock %}
