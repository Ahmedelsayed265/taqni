{% extends "layout.jinja" %}

{% block header %} {% include 'header.jinja' %} {% endblock %}

{% block top_links %}
	<link rel="stylesheet" type="text/css" href="{{ 'toastr.min.css' | asset_url }}"/>
{% endblock %}

{% block main_content %}

    <section class="breadcrumb-section">
        <nav aria-label="{{ _('Breadcrumb') }}">

            <ol class="breadcrumb">
                <div class="container-fluid d-flex flex-wrap">

                    <li class="breadcrumb-item" aria-current="page"><a href="/">{{ _("Home") }}</a></li>

                    {% if category.parent_category.parent_category %}
                        <li class="breadcrumb-item" aria-current="page"><a href="{{ category.parent_category.parent_category.url }}">{{ category.parent_category.parent_category.name }}</a></li>
                    {% endif %}

                    {% if category.parent_category %}
                        <li class="breadcrumb-item" aria-current="page"><a href="{{ category.parent_category.url }}">{{ category.parent_category.name }}</a></li>
                    {% endif %}

                    <li class="breadcrumb-item active " aria-current="page">{{ category.name }}</li>

                </div>

            </ol>

        </nav>
    </section>

    {% set title=category.name %}{% set description=category.description %}{% include 'components/breadcrumb-subTitle-detail.jinja' %}
    
    <div class="container-fluid d-flex flex-row">
        {% if  products.filters|length > 0 %}
            {% set async=true %} {% include 'vitrin:products/filters.jinja' %}
            
        {% endif %}
        <div class="products-container-fluid flex-grow-1 pt-4">
            <div>
                {% set count=products.count %}{% set has_products_filtration=(products.filters|length > 0) %}{% include 'components/products-filter.jinja' %}
            </div>
            <div id="products-list" class="row products-list products-list--grid {% if products.filters|length > 0 %}products-list--with-filters{% endif %}" role="list">
                {% for product in products.results %}

                    <div class="prod-col {% if products.filters|length > 0 %}prod-col-attr{% endif %} prod-col-tb" role="listitem">
                        {% set product=product %}{% set index=key %}{% include 'components/product-card.jinja' %}
                    </div>

                {% endfor %}
            </div>
        </div>
    </div>

    <div class="products-pagination-wrapper products-pagination-wrapper--infinite">
        {% set totalPages=products.pages_count %}{% set currentPage=products.page %}{% include 'components/pagination.jinja' %}
    </div>

    <div class="container-fluid">
      {% set entity = category %}
      {% include 'vitrin:shared/metafields.jinja' %}
    </div>

{% endblock %}

{% block footer %} {% include 'footer.jinja' %} {% endblock %}


{% block footer_scripts %}
    <script type="text/javascript" src="{{ 'toastr.min.js' | asset_url }}" defer></script>
    <script>
        function initSidebarPriceRangeFilter() {
            var form = document.querySelector('.products-filters-attribute-form form#attribute_form');
            if (!form) { return; }

            var priceBody = form.querySelector('.attribute-price-body');
            if (!priceBody) { return; }

            var fromInput = form.querySelector('input[name="from_price"]');
            var toInput = form.querySelector('input[name="to_price"]');
            if (!fromInput || !toInput) { return; }

            // Avoid duplicating UI if it is already initialized
            if (priceBody.querySelector('.price-range-slider-wrapper')) { return; }

            // Label "من X إلى Y ريال" فوق رينجين (حد أدنى وحد أقصى)
            var labelWrapper = document.createElement('div');
            labelWrapper.className = 'price-range-label text-right mb-2';
            labelWrapper.dir = 'rtl';

            var labelSpan = document.createElement('span');
            labelSpan.id = 'price_range_text';

            var valueMinSpan = document.createElement('span');
            valueMinSpan.id = 'price_range_value_min';

            var valueMaxSpan = document.createElement('span');
            valueMaxSpan.id = 'price_range_value_max';

            labelSpan.appendChild(document.createTextNode('من '));
            labelSpan.appendChild(valueMinSpan);
            labelSpan.appendChild(document.createTextNode(' إلى '));
            labelSpan.appendChild(valueMaxSpan);
            labelSpan.appendChild(document.createTextNode(' ' + (window.outlitCurrencyCode || '{{ session.currency.code or "ريال" }}')));

            labelWrapper.appendChild(labelSpan);

            // Slider wrapper + two range inputs (min / max على نفس التراك)
            var sliderWrapper = document.createElement('div');
            sliderWrapper.className = 'price-range-slider-wrapper';

            var sliderTrack = document.createElement('div');
            sliderTrack.className = 'price-range-track';
            sliderWrapper.appendChild(sliderTrack);

            var minVal = parseInt(fromInput.getAttribute('min') || '0', 10);
            var maxAttr = toInput.getAttribute('max') || '';
            var placeholder = toInput.getAttribute('placeholder') || '';
            var maxFromPlaceholder = parseInt(placeholder.replace(/[^0-9]/g, ''), 10);
            var maxVal = parseInt(maxAttr || maxFromPlaceholder || '1000', 10);

            var currentMin = parseInt(fromInput.value || minVal, 10);
            if (isNaN(currentMin)) { currentMin = minVal; }
            currentMin = Math.max(minVal, Math.min(maxVal, currentMin));

            var currentMax = parseInt(toInput.value || maxVal, 10);
            if (isNaN(currentMax)) { currentMax = maxVal; }
            currentMax = Math.max(minVal, Math.min(maxVal, currentMax));
            if (currentMin > currentMax) { currentMin = currentMax; }

            var sliderMin = document.createElement('input');
            sliderMin.type = 'range';
            sliderMin.className = 'price-range-input price-range-input-min';
            sliderMin.min = String(minVal);
            sliderMin.max = String(maxVal);
            sliderMin.step = '1';
            sliderMin.value = String(currentMin);

            var sliderMax = document.createElement('input');
            sliderMax.type = 'range';
            sliderMax.className = 'price-range-input price-range-input-max';
            sliderMax.min = String(minVal);
            sliderMax.max = String(maxVal);
            sliderMax.step = '1';
            sliderMax.value = String(currentMax);

            sliderWrapper.appendChild(sliderMin);
            sliderWrapper.appendChild(sliderMax);

            // Insert label + slider before existing inputs row
            var firstRow = priceBody.querySelector('.form-row') || priceBody.firstChild;
            if (firstRow) {
                priceBody.insertBefore(sliderWrapper, firstRow);
                priceBody.insertBefore(labelWrapper, sliderWrapper);
            } else {
                priceBody.appendChild(labelWrapper);
                priceBody.appendChild(sliderWrapper);
            }

            // Style existing inputs ككبسولة (CSS جاهز)
            fromInput.classList.add('products-filter-price-input');
            toInput.classList.add('products-filter-price-input');

            function updateLabel(minValNow, maxValNow) {
                valueMinSpan.textContent = String(minValNow);
                valueMaxSpan.textContent = String(maxValNow);
            }

            function syncFromSliders() {
                var minNow = parseInt(sliderMin.value || minVal, 10);
                var maxNow = parseInt(sliderMax.value || maxVal, 10);
                if (isNaN(minNow)) { minNow = minVal; }
                if (isNaN(maxNow)) { maxNow = maxVal; }

                if (minNow > maxNow) {
                    if (this === sliderMin) {
                        maxNow = minNow;
                        sliderMax.value = String(maxNow);
                    } else {
                        minNow = maxNow;
                        sliderMin.value = String(minNow);
                    }
                }

                fromInput.value = String(minNow);
                toInput.value = String(maxNow);
                updateLabel(minNow, maxNow);
            }

            function syncFromInputs() {
                var minNow = parseInt(fromInput.value || minVal, 10);
                var maxNow = parseInt(toInput.value || maxVal, 10);

                if (isNaN(minNow)) { minNow = minVal; }
                if (isNaN(maxNow)) { maxNow = maxVal; }

                minNow = Math.max(minVal, Math.min(maxVal, minNow));
                maxNow = Math.max(minVal, Math.min(maxVal, maxNow));
                if (minNow > maxNow) { minNow = maxNow; }

                sliderMin.value = String(minNow);
                sliderMax.value = String(maxNow);
                fromInput.value = String(minNow);
                toInput.value = String(maxNow);
                updateLabel(minNow, maxNow);
            }

            sliderMin.addEventListener('input', syncFromSliders);
            sliderMax.addEventListener('input', syncFromSliders);
            sliderMin.addEventListener('change', syncFromSliders);
            sliderMax.addEventListener('change', syncFromSliders);
            fromInput.addEventListener('input', syncFromInputs);
            toInput.addEventListener('input', syncFromInputs);
            fromInput.addEventListener('change', syncFromInputs);
            toInput.addEventListener('change', syncFromInputs);

            // Initialize label + slider position
            syncFromInputs();
        }

        window.onProductAttributesTriggered = function(){
            $('#products-list').css('opacity', '0.4');
            $('#product-pagination').css('opacity', '0');

        }

        window.onProductAttributesChanged = function(htmlStr){
            var html = $.parseHTML( htmlStr );
            $('#products-list').html($('#products-list', html).html());
            $('#products-list').css('opacity', '1');
            $('#product-filter-count').html($('#product-filter-count', html).html());
            $('#product-filter-count').css('opacity', '1');

            if($('#product-pagination', html).length>0){
                $('#product-pagination').replaceWith($('#product-pagination', html));
                $('#product-pagination').css('opacity', '1');
            }

            if (window.initInfiniteCategoryProducts) {
                window.initInfiniteCategoryProducts();
            }
        }

        // Infinite scroll for products list (category page)
        window.initInfiniteCategoryProducts = function() {
            var $ = window.jQuery;
            if (!$) { return; }

            var $list = $('#products-list');
            var $pagination = $('#product-pagination');
            if (!$list.length || !$pagination.length) { return; }

            var $win = $(window);
            var $doc = $(document);
            var isLoading = false;
            var currentPage = parseInt($pagination.data('current-page'), 10) || 1;
            var totalPages = parseInt($pagination.data('total-pages'), 10) || 1;

            // Remove previous handlers to avoid duplicates
            $win.off('.infiniteCategoryProducts');

            function getNextUrlFromPagination() {
                var nextHref = null;
                $pagination.find('a.page-link[href]').each(function() {
                    var href = this.getAttribute('href') || $(this).attr('href');
                    if (!href) { return; }
                    var match = href.match(/[?&]page=(\d+)/);
                    if (match) {
                        var pageNum = parseInt(match[1], 10);
                        if (pageNum === currentPage + 1) {
                            nextHref = href;
                            return false;
                        }
                    }
                });
                return nextHref;
            }

            function maybeLoadMore() {
                if (isLoading) { return; }
                if (currentPage >= totalPages) { return; }

                var scrollPosition = $win.scrollTop() + $win.height();
                var threshold = $doc.height() - 400;
                if (scrollPosition < threshold) { return; }

                var nextUrl = getNextUrlFromPagination();
                if (!nextUrl) { return; }

                isLoading = true;

                $.get(nextUrl, function(html) {
                    var $html = $.parseHTML(html);
                    var $newList = $('#products-list', $html);
                    if ($newList.length) {
                        $list.append($newList.children());
                    }
                    var $newPagination = $('#product-pagination', $html);
                    if ($newPagination.length) {
                        currentPage = parseInt($newPagination.data('current-page'), 10) || (currentPage + 1);
                        totalPages = parseInt($newPagination.data('total-pages'), 10) || totalPages;
                        $pagination.replaceWith($newPagination);
                        $pagination = $('#product-pagination');
                    } else {
                        currentPage += 1;
                    }

                    if (window.bundleOffersLoader) {
                        window.bundleOffersLoader.reload();
                    }
                }).always(function() {
                    isLoading = false;
                });
            }

            $win.on('scroll.infiniteCategoryProducts resize.infiniteCategoryProducts', maybeLoadMore);
        };

        document.addEventListener('DOMContentLoaded', function() {
            if (window.initInfiniteCategoryProducts) {
                window.initInfiniteCategoryProducts();
            }

            try {
                initSidebarPriceRangeFilter();
            } catch (e) {
                // ignore
            }
        });

    </script>
{% endblock %}