<script>
    (function () {
        var CART_CATEGORY_SVG_OPTIONS = {{ _cart_svg_options_icon | tojson
    }};
    var CART_CATEGORY_SVG_ADD = {{ _cart_svg_add_icon | tojson }};

    const container = document.getElementById('cart-custom-category-products');
    const selectedCategoryId = {{ (settings.cart_category_products_list.id if settings.cart_category_products_list.id else settings.cart_category_products_list) | tojson }};

    function waitForZid(maxWaitMs) {
        maxWaitMs = maxWaitMs || 8000;
        return new Promise(function (resolve) {
            if (typeof zid !== 'undefined' && zid.products && typeof zid.products.list === 'function') {
                resolve();
                return;
            }
            var start = Date.now();
            var t = setInterval(function () {
                if (typeof zid !== 'undefined' && zid.products && typeof zid.products.list === 'function') {
                    clearInterval(t);
                    resolve();
                } else if (Date.now() - start >= maxWaitMs) {
                    clearInterval(t);
                    resolve();
                }
            }, 250);
        });
    }

    async function loadCategoryProducts() {
        if (!container) return;
        const loader = container.querySelector('.loading-spinner');
        try {
            console.log('Cart: loadCategoryProducts started. Category:', selectedCategoryId);
            if (!selectedCategoryId || selectedCategoryId === "" || selectedCategoryId === "None" || (typeof selectedCategoryId === 'object' && Object.keys(selectedCategoryId).length === 0)) {
                console.warn('Cart: No valid category ID found.', selectedCategoryId);
                container.style.display = 'none';
                return;
            }
            if (loader) loader.textContent = "{{ _('Loading...') }}";

            // Wait for zid object
            let zidApi = null;
            for (let i = 0; i < 40; i++) {
                var z = window.zid || (typeof zid !== 'undefined' ? zid : null);
                if (z && z.products && typeof z.products.list === 'function') {
                    zidApi = z; break;
                }
                await new Promise(r => setTimeout(r, 200));
            }

            if (!zidApi) {
                console.error('Cart: zid API not available.');
                if (loader) loader.textContent = "{{ _('Failed to load products') }}";
                return;
            }

            const fetchP = async (id) => {
                try {
                    return await zidApi.products.list({ categories: id, page_size: 20 }, { showErrorNotification: false });
                } catch (e) { return null; }
            };

            var categoryId = selectedCategoryId;
            if (categoryId && typeof categoryId === 'object' && categoryId.id) categoryId = categoryId.id;

            let response = await Promise.race([
                fetchP(categoryId),
                new Promise((_, r) => setTimeout(() => r(new Error('timeout')), 15000))
            ]).catch(() => null);

            if (!response) {
                if (loader) loader.textContent = "{{ _('Failed to load products') }}";
                return;
            }

            var products = [];
            if (response && response.status === 'success' && response.data) {
                var d = response.data;
                if (d.products) {
                    products = d.products.results || d.products.data || (Array.isArray(d.products) ? d.products : []);
                } else {
                    products = d.results || d.data || (Array.isArray(d) ? d : []);
                }
            } else if (response && Array.isArray(response.results)) {
                products = response.results;
            } else if (response && Array.isArray(response.products)) {
                products = response.products;
            } else if (Array.isArray(response)) {
                products = response;
            } else if (response && response.data) {
                if (Array.isArray(response.data.results)) products = response.data.results;
                else if (Array.isArray(response.data.products)) products = response.data.products;
                else if (Array.isArray(response.data)) products = response.data;
            }

            // Final fallback if still empty and we haven't tried array ID
            if ((!products || products.length === 0) && !Array.isArray(categoryId)) {
                console.log('Cart: Products empty with string ID, trying array ID...');
                response = await fetchP([categoryId]);
                if (response && response.status === 'success' && response.data) {
                    var d = response.data;
                    products = (d.products ? (d.products.results || d.products.data || d.products) : (d.results || d.data || d)) || [];
                }
            }

            console.log('Cart: Processed products count:', products ? (Array.isArray(products) ? products.length : 'NaN') : 0);
            if (!Array.isArray(products) || products.length === 0) {
                if (loader) loader.textContent = "{{ _('No products in this category') }}";
                return;
            }

            if (loader) loader.remove();

            const sliderWrapper = container.querySelector('.products-slider-wrapper');
            let productsSlider = container.querySelector('.cart-category-products-slider');

            if (!productsSlider) {
                console.error('Cart: slider element not found');
                return;
            }

            let swiperWrapper = productsSlider.querySelector('.swiper-wrapper');
            if (!swiperWrapper) {
                swiperWrapper = document.createElement('div');
                swiperWrapper.className = 'swiper-wrapper';
                productsSlider.appendChild(swiperWrapper);
            }

            swiperWrapper.innerHTML = '';
            productsSlider.style.display = 'block';
            console.log('Cart: Building product cards HTML...');

            const defaultImage = {{ image_url(("product-img.svg" | asset_url), w = 235, q = 100, f = "auto") | tojson
        }};
    const spinnerUrl = {{ ("spinner.gif" | asset_url) | tojson }};
    const uBellUrl = {{ ("u_bell.svg" | asset_url) | tojson }};
    const wishlistEnabled = {{ 'true' if store.settings.products.wishlist_enabled else 'false' }};
    const reviewsEnabled = {{ 'true' if store.settings.products.reviews_enabled else 'false' }};
    const addToFavoritesLabel = {{ _("Add to favorites") | tojson }};
    const addToCartLabel = {{ _("Add to cart") | tojson }};
    const qtyLabel = {{ _("Quantity") | tojson }};
    const increaseQtyLabel = {{ _("Increase quantity") | tojson }};
    const decreaseQtyLabel = {{ _("Decrease quantity") | tojson }};
    const notifyWhenAvailableText = {{ _("Notify me when available") | tojson }};

    products.forEach(product => {
        const productImages = Array.isArray(product.images) ? product.images : [];
        const mainImgObj = product.main_image && product.main_image.image ? product.main_image.image : null;
        const firstImgObj = productImages[0] && productImages[0].image ? productImages[0].image : null;
        const mainImg = (mainImgObj && (mainImgObj.small || mainImgObj.medium || mainImgObj.large)) ||
            (firstImgObj && (firstImgObj.small || firstImgObj.medium || firstImgObj.large)) ||
            defaultImage;

        const badge = product.badge || null;
        const badgeBody = (badge && badge.body && (badge.body.ar || badge.body.en)) || '';
        const badgeIcon = (badge && badge.icon && badge.icon.code) || '';

        const productName = (product.name || '');
        const productSlug = (product.slug || '');
        const productId = String(product.id || '');

        const formattedPrice = product.formatted_sale_price || product.formatted_price || '';
        const hasSalePrice = !!product.formatted_sale_price;

        const hasOptions = product.has_options || product.has_fields || product.product_class === 'dynamic_bundle' ||
            (product.options && product.options.length > 0) ||
            (product.variants && product.variants.length > 0);
        const outOfStock = !product.is_infinite && product.quantity <= 0;

        let badgeHtml = '';

        let wishlistHtml = '';
        if (wishlistEnabled) {
            wishlistHtml = `
                <div class="outlit-product-card__wishlist">
                    <span zid-visible-customer="true">
                        <button type="button" zid-visible-wishlist="${productId}" class="outlit-product-card__wishlist-btn icon-heart-mask filled" onclick="addToWishlist(this, '${productId}')"></button>
                        <button type="button" zid-hidden-wishlist="${productId}" class="outlit-product-card__wishlist-btn icon-heart-mask" onclick="addToWishlist(this, '${productId}')"></button>
                    </span>
                    <a zid-visible-guest="true" class="outlit-product-card__wishlist-btn icon-heart-mask" href="/auth/login?redirect_to={{ session.url.path }}" onclick="event.preventDefault(); handleLoginAction('', false); return false;"></a>
                </div>`;
        }

        let categoryHtml = '';
        if (Array.isArray(product.categories) && product.categories.length > 0) {
            const lastCat = product.categories[product.categories.length - 1];
            const catName = (lastCat && lastCat.name) ? (typeof lastCat.name === 'string' ? lastCat.name : (lastCat.name.ar || lastCat.name.en || '')) : '';
            if (catName) {
                categoryHtml = `<p class="outlit-product-card__category">${catName}</p>`;
            }
        } else if (product.category && product.category.name) {
            categoryHtml = `<p class="outlit-product-card__category">${product.category.name}</p>`;
        }

        let priceHtml = '';
        if (hasSalePrice) {
            priceHtml = `
                <span class="price-current">${product.formatted_sale_price}</span>
                <span class="price-old">${product.formatted_price}</span>`;
        } else {
            priceHtml = `<span class="price-current">${product.formatted_price}</span>`;
        }

        let actionHtml = '';
        if (!outOfStock) {
            if (hasOptions) {
                actionHtml = `
                    <a href="/products/${productSlug}" class="outlit-product-card__cart-btn" aria-label="${addToCartLabel}">
                        ${CART_CATEGORY_SVG_OPTIONS}
                    </a>`;
            } else {
                actionHtml = `
                    <div class="outlit-product-card__ajax-cart" data-product-id="${productId}">
                        <button type="button" class="outlit-product-card__cart-btn outlit-product-card__add-btn-ajax" onclick="event.preventDefault(); event.stopPropagation(); productCartAddToCart(this, '${productId}')">
                            <span class="cart-btn-icon">${CART_CATEGORY_SVG_ADD}</span>
                            <span class="cart-btn-loader d-none"></span>
                        </button>
                        <div class="outlit-product-card__qty-bar d-none">
                            <button type="button" class="qty-control minus" onclick="event.stopPropagation()">-</button>
                            <span class="qty-val" data-qty>1</span>
                            <button type="button" class="qty-control plus" onclick="event.stopPropagation()">+</button>
                        </div>
                    </div>`;
            }
        } else {
            actionHtml = `<span class="outlit-product-card__badge-oos">${notifyWhenAvailableText}</span>`;
        }

        const slideHtml = `
            <div class="swiper-slide">
                <article class="outlit-product-card product-item ${outOfStock ? 'outlit-product-card--out-of-stock' : ''}" itemscope itemtype="https://schema.org/Product">
                    <div class="outlit-product-card__img-wrap">
                        <a href="/products/${productSlug}" class="outlit-product-card__img-link" aria-label="${productName}">
                            <div class="outlit-product-card__img-inner">
                                <img id="product-card-img-${productId}" class="outlit-product-card__img" src="${mainImg}" loading="lazy" decoding="async" alt="${productName}">
                            </div>
                        </a>
                        ${badgeHtml}
                        ${wishlistHtml}
                    </div>
                    <div class="outlit-product-card__body">
                        <div class="outlit-product-card__info">
                            ${categoryHtml}
                            <h3 class="outlit-product-card__title">
                                <a href="/products/${productSlug}">${productName}</a>
                            </h3>
                        </div>
                        <div class="outlit-product-card__footer">
                            <div class="outlit-product-card__price-wrap">
                                ${priceHtml}
                            </div>
                            <div class="outlit-product-card__actions">
                                ${actionHtml}
                            </div>
                        </div>
                    </div>
                </article>
            </div>`;
        
        swiperWrapper.insertAdjacentHTML('beforeend', slideHtml);
    });



    // Initialize bundle offers if available
    if (typeof window.initBundleOffers === 'function') {
        window.initBundleOffers();
    }

    // Initialize Swiper
    if (typeof Swiper !== 'undefined') {
        new Swiper(productsSlider, {
            slidesPerView: 2.2,
            spaceBetween: 10,
            loop: false,
            breakpoints: {
                380: { slidesPerView: 1.5, spaceBetween: 10 },
                576: { slidesPerView: 1.5, spaceBetween: 12 },
                768: { slidesPerView: 3.5, spaceBetween: 15 },
                992: { slidesPerView: 4.5, spaceBetween: 20 },
                1200: { slidesPerView: 5.5, spaceBetween: 20 }
            }
        });
    }

        } catch (err) {
        if (loader) {
            loader.textContent = err && err.message === 'timeout'
                ? "{{ _('Failed to load products') }}"
                : "{{ _('Failed to load products') }}";
        }
    }
    }

    loadCategoryProducts();
}) ();
</script>
</div>
</div>
{% endblock %}

{% block footer_scripts %}
<script type="text/javascript" src="{{ 'toastr.min.js' | asset_url }}" defer></script>
<script type="text/javascript" src="{{ ('gift-card.js?=v' ~ ver) | asset_url }}" defer></script>

<script>

    function buildCartFromDom() {
        var products = [];
        $('.template_for_cart_products_list .cart-product-row-wrapper').each(function () {
            var $row = $(this);
            var id = $row.attr('data-cart-product-id');
            var name = ($row.find('h1 a').first().text() || $row.find('.product-title-row a').text() || $row.find('.cart-product-image-link').first().text() || $row.find('.cart-product-col-details a').first().text() || '').trim();
            var href = $row.find('.cart-product-image-link, .product-title-row a, h1 a').first().attr('href') || '';
            if (id) products.push({ id: id, name: name, url: href });
        });
        return products.length ? { products: products } : null;
    }

    function runCartOptionsEnhance() {
        var cartFromDom = buildCartFromDom();
        if (cartFromDom && cartFromDom.products && cartFromDom.products.length) {
            enhanceProductDisplay(cartFromDom);
        }
    }

    $(document).ready(function () {
        addDeleteProgressImage();
        convertQuantityDropdowns();
        movePriceIntoDetails();
        var $list = $('.template_for_cart_products_list');
        if ($list.length) {
            runCartOptionsEnhance();
            [100, 300, 600, 1200].forEach(function (ms) {
                setTimeout(runCartOptionsEnhance, ms);
            });
            if (typeof zid !== 'undefined' && zid.cart && zid.cart.get) {
                zid.cart.get().then(function (r) { if (r && r.cart && r.cart.products && r.cart.products.length) enhanceProductDisplay(r.cart); });
            }
            var obs = new MutationObserver(function () { runCartOptionsEnhance(); });
            try { obs.observe($list[0], { childList: true, subtree: true }); } catch (e) { }
        }
    });

    document.addEventListener('click', function (e) {
        if (e.target.closest && e.target.closest('[data-apply-coupon]')) { e.preventDefault(); sendCoupon(); return; }
        var del = e.target.closest('[data-delete-coupon]'); if (del) { e.preventDefault(); deleteCoupon(); }
        var removeLink = e.target.closest('.cart-product-delete a'); if (removeLink) { e.preventDefault(); if (typeof cartProductRemove === 'function') cartProductRemove(removeLink); }
    });

    function addDeleteProgressImage() {
        $('.cart-product-delete a .prefix', document).addClass('d-none');
        $('.cart-product-delete a .prefix', document).html('<img class="send-coupon-progress" src="{{ 'spinner.gif' | asset_url }}" width="15" height="15" loading="lazy" decoding="async"/>');
    }

    $(document).on('click', '.cart-product-delete a', function (event) {
        $('.icon-delete', event.currentTarget).addClass('d-none');
        $('.prefix', event.currentTarget).removeClass('d-none');
    });

    $(".cities-search-input").on('keyup', function (e) {
        const searchVal = e.target.value
        const mappedCities = cartObj.free_shipping_rule.shipping_cities_condition.map((city) => city.name);
        let filteredCities = mappedCities.slice(0, 50).join(' ، ');
        if (searchVal.length > 2) {
            filteredCities = mappedCities.filter((name) => name.trim().toLowerCase().includes(searchVal.trim().toLowerCase())).join(' ، ');
        }
        if (filteredCities.length) {
            $(".cities-result").html(filteredCities);
        } else {
            $(".cities-result").html('{{ _("No Result Found") }}');
        }
    });

    function sendCoupon() {
        if (!$('.send-coupon-progress').hasClass('d-none'))
            return;

        $('.send-coupon-progress').removeClass('d-none');
        zid.cart.applyCoupon({ coupon_code: $('.send-coupon').val() }, { showErrorNotification: true })
            .then(function (response) {
                window.zid?.toaster?.showSuccess('{{ _("Send Successfully") }}');
                $('.send-coupon-progress').addClass('d-none');
                if (window.cartEngine && response && response.cart) window.cartEngine.update(response.cart);
                else if (typeof zid !== 'undefined' && zid.cart && zid.cart.get) { zid.cart.get().then(function (r) { if (r && r.cart && window.cartEngine) window.cartEngine.update(r.cart); }); }
            }).catch(function (err) {
                $('.send-coupon-progress').addClass('d-none');
            })
    }

    function deleteCoupon() {
        if (!$('.delete-coupon-progress').hasClass('d-none'))
            return;

        $('.delete-coupon-progress').removeClass('d-none');

        zid.cart.removeCoupons({ showErrorNotification: true }).then(function (response) {
            $('.delete-coupon-progress').addClass('d-none');
            if (window.cartEngine && response && response.cart) window.cartEngine.update(response.cart);
            else if (typeof zid !== 'undefined' && zid.cart && zid.cart.get) { zid.cart.get().then(function (r) { if (r && r.cart && window.cartEngine) window.cartEngine.update(r.cart); }); }
        })
    }



    function convertQuantityDropdowns() {
        $('.cart-product-quantity-dropdown').each(function () {
            var $wrapper = $(this);
            var $select = $wrapper.find('select');

            if ($select.length === 0) return;

            // Check if already converted
            if ($wrapper.find('.cart-product-quantity-controls').length > 0) {
                return;
            }

            var currentValue = parseInt($select.val()) || 1;

            // cart.js (line 27) reads getAttribute from a parent - copy select data attributes to possible parents
            var dataAttrs = ['data-cart-product-id', 'data-product-id', 'data-share-token', 'data-template'];
            var $rowWrapper = $select.closest('.cart-product-row-wrapper');
            if ($rowWrapper.length) {
                dataAttrs.forEach(function (attr) {
                    var val = $select.attr(attr);
                    if (val !== undefined) $rowWrapper.attr(attr, val);
                });
            }
            dataAttrs.forEach(function (attr) {
                var val = $select.attr(attr);
                if (val !== undefined) $wrapper.attr(attr, val);
            });

            // Hide the original select but keep it in DOM (cart.js reads from it)
            $select.addClass('d-none').attr('aria-hidden', 'true');

            // Create quantity controls and insert before the select
            var minusLabel = {{ _("Decrease quantity") | tojson
        }};
    var plusLabel = {{ _("Increase quantity") | tojson }};
    var qtyLabel = {{ _("Quantity") | tojson }};
    var controlsHtml = '<div class="cart-product-quantity-controls">' +
        '<button type="button" class="cart-quantity-btn cart-quantity-minus" aria-label="' + minusLabel + '">-</button>' +
        '<input type="number" class="cart-quantity-input" value="' + currentValue + '" min="1" max="100" readonly aria-label="' + qtyLabel + '">' +
        '<button type="button" class="cart-quantity-btn cart-quantity-plus" aria-label="' + plusLabel + '">+</button>' +
        '</div>';

    $wrapper.prepend(controlsHtml);
            });

    document.querySelectorAll('.cart-product-delete a').forEach(function (a) {
        a.removeAttribute('onclick');
        a.setAttribute('data-remove-product', a.getAttribute('data-cart-product-id') || '');
    });

    // Handle quantity button clicks - update the real select and trigger its change
    $(document).off('click', '.cart-quantity-btn').on('click', '.cart-quantity-btn', function (e) {
        e.preventDefault();
        var $btn = $(this);
        var $wrapper = $btn.closest('.cart-product-quantity-dropdown');
        var $select = $wrapper.find('select');
        var $input = $wrapper.find('.cart-quantity-input');

        if ($select.length === 0) return;

        var currentValue = parseInt($input.val()) || 1;
        var newValue = currentValue;

        if ($btn.hasClass('cart-quantity-minus')) {
            newValue = Math.max(1, currentValue - 1);
        } else if ($btn.hasClass('cart-quantity-plus')) {
            newValue = Math.min(100, currentValue + 1);
        }

        if (newValue !== currentValue) {
            $input.val(newValue);
            $select.val(newValue);
            // cart.js uses event.currentTarget (not target) - pass both
            if (typeof cartProductQuantityChanged === 'function') {
                var ev = { target: $select[0], currentTarget: $select[0] };
                cartProductQuantityChanged(ev);
            } else {
                $select.trigger('change');
            }
        }
    });
        }

    function getProductIdsInDom() {
        var ids = [];
        document.querySelectorAll('.template_for_cart_products_list .cart-product-row-wrapper[data-cart-product-id]').forEach(function (row) {
            var id = row.getAttribute('data-cart-product-id');
            if (id) ids.push(id);
        });
        return ids;
    }

    function canPatchProducts(cart) {
        if (!cart || !cart.products || !cart.products.length) return false;
        var currentIds = getProductIdsInDom();
        var newIds = cart.products.map(function (p) { return String(p.id); });
        if (currentIds.length !== newIds.length) return false;
        return currentIds.every(function (id) { return newIds.indexOf(id) !== -1; });
    }

    function CartEngine(initialCart) {
        this.state = initialCart || {};
    }
    CartEngine.prototype.update = function (cart) {
        this.state = cart || this.state;
        this.patchProducts();
        this.patchTotals();
        this.patchFreeShipping();
        if (typeof setCartTotalAndBadge === 'function') setCartTotalAndBadge(this.state);
        addDeleteProgressImage();
    };
    CartEngine.prototype.patchProducts = function () {
        var state = this.state;
        if (!state.products) return;
        state.products.forEach(function (product) {
            var row = document.querySelector('.template_for_cart_products_list [data-cart-product-id="' + product.id + '"]');
            if (!row) return;
            var totalEl = row.querySelector('.cart-product-total-price');
            if (totalEl && product.total_string) totalEl.textContent = product.total_string;
            var qtyInput = row.querySelector('.cart-product-quantity-input');
            var qtySelect = row.querySelector('.cart-product-quantity-dropdown select');
            var qty = parseInt(product.quantity, 10) || 1;
            if (qtyInput && qtyInput.value !== String(qty)) qtyInput.value = qty;
            if (qtySelect && qtySelect.value !== String(qty)) qtySelect.value = qty;
        });
    };
    CartEngine.prototype.patchTotals = function () {
        var state = this.state;
        if (!state.totals) return;
        state.totals.forEach(function (t) {
            var el = document.querySelector('.cart-totals-div [data-total="' + t.code + '"]');
            if (el) el.textContent = t.value_string;
        });
    };
    CartEngine.prototype.patchFreeShipping = function () {
        var rule = this.state.free_shipping_rule;
        if (!rule || !rule.code) {
            document.querySelectorAll('.free-shipping-rule-section').forEach(function (s) { s.classList.add('d-none'); });
            return;
        }
        var condition = rule.subtotal_condition || {};
        var status = condition.status;
        var progress = Math.min(100, Math.max(0, condition.products_subtotal_percentage_from_min || 0));
        var section = document.querySelector('.free-shipping-rule-section');
        if (!section) return;
        section.classList.remove('d-none');
        var msgEl = section.querySelector('.free-shipping-rule-message');
        var progressContainer = section.querySelector('.free-shipping-progress-container');
        var progressFill = section.querySelector('.free-shipping-rule-progress');
        var truckCircle = section.querySelector('.free-shipping-truck-circle');
        var doneEl = section.querySelector('.free-shipping-rule-done');
        var readMore = section.querySelector('.free-shipping-rule-read-more');
        var currentSub = section.querySelector('.free-shipping-current-subtotal');
        var minTotal = section.querySelector('.free-shipping-min-total');
        if (currentSub) currentSub.textContent = condition.products_subtotal_formatted || condition.products_subtotal || '';
        if (minTotal) minTotal.textContent = condition.min_total_formatted || condition.min_string || '';
        if (progressFill) progressFill.style.width = progress + '%';
        if (truckCircle) { truckCircle.style.right = progress + '%'; truckCircle.style.left = 'auto'; }
        var msgMin = '{{ _("Add products with total of %(total)s to get free shipping") }}'.replace('%(total)s', condition.remaining || condition.remaining_to_min_total_formatted || condition.remaining_to_min_total || '0');
        var msgMax = '{{ _("Free shipping applies for cart total between %(min)s and %(max)s") }}'.replace('%(min)s', condition.min_total_formatted || condition.min_string || '0').replace('%(max)s', condition.max_total_formatted || condition.max_string || '0');
        var msgApplied = '{{ _("Free shipping applied") }}';
        if (msgEl) {
            if (status === 'min_not_reached') msgEl.textContent = msgMin;
            else if (status === 'max_exceed' || status === 'max_exceeded') msgEl.textContent = msgMax;
            else if (status === 'applied') msgEl.textContent = msgApplied;
        }
        if (status === 'applied') {
            if (doneEl) { doneEl.classList.remove('d-none'); doneEl.classList.add('d-flex'); }
            if (progressContainer) { progressContainer.classList.add('d-none'); progressContainer.classList.remove('d-flex'); }
            if (readMore) { readMore.classList.add('d-none'); readMore.classList.remove('d-block'); }
        } else if (status === 'max_exceed' || status === 'max_exceeded') {
            if (doneEl) { doneEl.classList.add('d-none'); doneEl.classList.remove('d-flex'); }
            if (progressContainer) { progressContainer.classList.remove('d-none'); progressContainer.classList.add('d-flex'); if (progressFill) progressFill.style.width = '100%'; if (truckCircle) { truckCircle.style.left = '97%'; truckCircle.style.right = 'auto'; } }
            if (readMore) { readMore.classList.add('d-none'); readMore.classList.remove('d-block'); }
        } else {
            if (doneEl) { doneEl.classList.add('d-none'); doneEl.classList.remove('d-flex'); }
            if (progressContainer) { progressContainer.classList.remove('d-none'); progressContainer.classList.add('d-flex'); }
            if (readMore) { if (status === 'min_not_reached') { readMore.classList.remove('d-none'); readMore.classList.add('d-block'); } else { readMore.classList.add('d-none'); readMore.classList.remove('d-block'); } }
        }
    };

    function cartProductsHtmlChanged(html, cart) {
        if (cart.products_count <= 0) {
            $('.cart-products-with-totals').addClass('d-none');
            $('.cart-empty').removeClass('d-none');
            if (window.cartEngine) window.cartEngine.state = cart;
            return;
        }
        $('.cart-products-with-totals').removeClass('d-none');
        $('.cart-empty').addClass('d-none');

        if (!window.cartEngine) window.cartEngine = new CartEngine(cart);

        if (canPatchProducts(cart)) {
            window.cartEngine.update(cart);
            enhanceProductDisplay(cart);
            return;
        }

        $('.template_for_cart_products_list').html(html);
        setTimeout(function () {
            convertQuantityDropdowns();
            movePriceIntoDetails();
            window.cartEngine.state = cart;
            window.cartEngine.patchTotals();
            window.cartEngine.patchFreeShipping();
            if (typeof setCartTotalAndBadge === 'function') setCartTotalAndBadge(cart);
            addDeleteProgressImage();
            enhanceProductDisplay(cart);
        }, 100);
    }

    function movePriceIntoDetails() {
        $('.cart-product-row-wrapper').each(function () {
            var $row = $(this);
            var $details = $row.find('.cart-product-col-details');
            var $prices = $row.find('.cart-product-prices').first();
            var $titleRow = $details.find('.product-title-row').first();
            if ($prices.length && $details.length && $titleRow.length && !$details.find('.cart-product-prices').length) {
                $prices.insertAfter($titleRow);
            }
        });
    }

    function escapeHtml(s) {
        if (s == null) return '';
        var str = String(s);
        return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

    var CART_COLOR_MAP = (typeof window !== 'undefined' && window.PRODUCT_COLOR_CODES) ? window.PRODUCT_COLOR_CODES : {
        'اسود': '#000000', 'ابيض': '#FFFFFF', 'سكري': '#F4F4E4', 'رمادي': '#6D6D6D', 'بني': '#875C39', 'بيج': '#EAD9B9',
        'لحمي': '#E8B6A0', 'ذهبي': '#D4AF37', 'فضي': '#C9C8C7', 'أحمر': '#D31E1E', 'احمر': '#D31E1E', 'عودي': '#5B0000',
        'برغندي': '#800020', 'بنك': '#F8BBD0', 'فوشي': '#AF005C', 'بنفسجي': '#7D63AB', 'موف': '#4F294F', 'ليلكي': '#472976',
        'ازرق': '#0032AB', 'كحلي': '#01015B', 'سماوي': '#94DCF2', 'تيفاني': '#56BAB3', 'عشبي': '#97AF82', 'زيتي': '#254117',
        'أخضر': '#228B22', 'اخضر': '#228B22', 'برتقالي': '#F1B15B', 'اصفر': '#FFDE21', 'ليموني': '#FFF171', 'كموني': '#C5A02E',
        'خربزي': '#FFB4A3', 'طوبي': '#C14A09', 'بترولي': '#004d4d', 'زيتوني': '#A0A030', 'وردي': '#D030A0',
        'كحلاء': '#01015B', 'أسود': '#000000', 'أبيض': '#FFFFFF', 'أزرق': '#0032AB', 'أخضر': '#228B22', 'أصفر': '#FFDE21'
    };

    function renderOptionsFallback($productRow, productId, parts, $details) {
        var sizeLabels = ['xxl', 'xxxl', 'xl', 'l', 'm', 's', 'xs'];
        var sizeLabel = {{ _("Size") | tojson
    }};
    var colorLabel = {{ _("Color") | tojson }};
    var $wr = $('<div class="cart-product-options-wrapper"></div>');
    var customValues = {};
    var $customSum = $details.find('.custom-options-summary');
    if ($customSum.length && $customSum.find('.custom-field-row').length) {
        $customSum.find('.custom-field-row').each(function () {
            var $row = $(this);
            var name = $row.find('.custom-field-name').text().replace(/\s*\*\s*$/, '').trim();
            var val = $row.find('.custom-field-value').text().trim();
            if (name) {
                customValues[val] = true;
                $wr.append('<div class="cart-product-option-row"><span class="cart-product-option-label">' + escapeHtml(name) + ' :</span><span class="cart-product-option-value"><span class="cart-product-size-badge">' + escapeHtml(val || '-') + '</span></span></div>');
            }
        });
        $customSum.addClass('d-none');
    }
    parts.forEach(function (p) {
        if (customValues[p]) return;
        var hex = getHexForColorName(p);
        var isSize = sizeLabels.some(function (s) { return p.toLowerCase() === s; }) || /^\d+$/.test(p);
        var lbl = isSize ? sizeLabel : (hex ? colorLabel : CATEGORY_FILTER_LABEL);
        if (lbl === CATEGORY_FILTER_LABEL) return;
        var valHtml = hex ? '<span class="cart-product-color-swatch" style="background-color:' + escapeHtml(hex) + '" title="' + escapeHtml(p) + '" aria-hidden="true"></span>' : '<span class="cart-product-size-badge">' + escapeHtml(p) + '</span>';
        $wr.append('<div class="cart-product-option-row"><span class="cart-product-option-label">' + escapeHtml(lbl) + ' :</span><span class="cart-product-option-value">' + valHtml + '</span></div>');
    });
    if ($wr.children().length) {
        var $pr = $details.find('.cart-product-prices').first();
        if ($pr.length) $pr.after($wr); else $details.append($wr);
    }
        }

    function getHexForColorName(name) {
        if (!name || typeof name !== 'string') return null;
        var k = name.replace(/\s+/g, ' ').trim().toLowerCase();
        return CART_COLOR_MAP[k] || CART_COLOR_MAP[name.trim()] || null;
    }

    function getCustomFieldsList(product) {
        var out = [];
        var fields = product.custom_fields || product.custom_user_input_fields || product.custom_data;
        if (!Array.isArray(fields) || fields.length === 0) return out;
        fields.forEach(function (f) {
            var name = (f.name != null) ? String(f.name).trim() : ((f.field_name != null) ? String(f.field_name).trim() : '');
            var value = (f.value != null) ? String(f.value).trim() : ((f.user_input != null) ? String(f.user_input).trim() : '');
            if (name) out.push({ name: name, value: value, type: 'default', type_value: '' });
        });
        return out;
    }

    function normalizeUuidForStorage(id) {
        if (!id || typeof id !== 'string') return id;
        var s = String(id).replace(/-/g, '');
        if (s.length === 32) return s.slice(0, 8) + '-' + s.slice(8, 12) + '-' + s.slice(12, 16) + '-' + s.slice(16, 20) + '-' + s.slice(20);
        return id;
    }
    function getCartDisplayKey(variantId) {
        var k = 'cart_display_' + variantId;
        if (typeof sessionStorage !== 'undefined' && sessionStorage.getItem(k)) return k;
        var k2 = 'cart_display_' + normalizeUuidForStorage(variantId);
        if (typeof sessionStorage !== 'undefined' && sessionStorage.getItem(k2)) return k2;
        return k;
    }

    function fetchProductBySlugOrId(slugOrId) {
        if (!slugOrId) return Promise.reject();
        if (typeof zid !== 'undefined' && zid.products && zid.products.get) {
            return zid.products.get(slugOrId).then(function (data) {
                return data.product || data.data || data;
            });
        }
        return fetch('/api/v1/products/' + encodeURIComponent(slugOrId)).then(function (r) { return r.json(); }).then(function (res) {
            return (res.data && res.data.product) ? res.data.product : (res.product || res.data || res);
        });
    }

    function getSelectedAttributesList(product) {
        var out = [];
        var attrs = product.attributes || product.option_attributes || product.selected_options;
        if (!Array.isArray(attrs) || attrs.length === 0) { attrs = []; }

        attrs.forEach(function (attr) {
            var name = (attr.name != null) ? String(attr.name).trim() : ((attr.slug != null) ? String(attr.slug).trim() : '');
            if (!name) return;

            var value, type, typeValue;
            if (attr.value != null || attr.type != null || attr.type_value != null) {
                value = (attr.value != null) ? String(attr.value).trim() : '';
                type = (attr.type != null) ? String(attr.type) : 'default';
                typeValue = (attr.type_value != null) ? String(attr.type_value).trim() : '';
                out.push({ name: name, value: value, type: type, type_value: typeValue });
            } else if (attr.data && Array.isArray(attr.data) && attr.data.length > 0) {
                var selected = attr.data[0];
                value = (selected.value != null) ? String(selected.value).trim() : '';
                type = (selected.type != null) ? String(selected.type) : 'default';
                typeValue = (selected.type_value != null) ? String(selected.type_value).trim() : '';
                out.push({ name: name, value: value, type: type, type_value: typeValue });
            }
        });
        return out;
    }

    var CATEGORY_FILTER_LABEL = {{ _("Filter by category") | tojson }};

    function enhanceProductDisplay(cart) {
        if (!cart || !cart.products) return;
        var variantDisplayIndex = {};
        cart.products.forEach(function (product) {
            var productId = product.id != null ? String(product.id) : '';
            var $productRow = $('.template_for_cart_products_list .cart-product-row-wrapper[data-cart-product-id="' + productId + '"]');
            if ($productRow.length === 0) return;
            var $details = $productRow.find('.cart-product-col-details');
            if ($details.length === 0) return;
            if ($details.find('.cart-product-options-wrapper').length > 0) return;
            var productUrl = product.url || $productRow.find('.cart-product-image-link, .product-title-row a, h1 a').first().attr('href') || '';
            var slug = productUrl ? (productUrl.split('/products/')[1] || productUrl).split('?')[0].split('#')[0] : '';
            // Only consume stored display name when this row has no options yet (e.g. added from Quick View / card sheet)
            var variantId = product.product_id != null ? product.product_id : ($productRow.attr('data-product-id') || product.id);
            try {
                var storageKey = getCartDisplayKey(variantId);
                var raw = typeof sessionStorage !== 'undefined' && sessionStorage.getItem(storageKey);
                if (raw) {
                    var arr = [];
                    try { arr = JSON.parse(raw); } catch (e) { }
                    if (!Array.isArray(arr)) arr = arr ? [raw] : [];
                    if (arr.length > 0) {
                        var idx = variantDisplayIndex[variantId] || 0;
                        product.name = arr[idx] || arr[0];
                        variantDisplayIndex[variantId] = idx + 1;
                        // لا نحذف من sessionStorage حتى تبقى الخيارات بعد تحديث الصفحة/السلة
                    }
                }
            } catch (e) { }

            var $optionsWrapper = $('<div class="cart-product-options-wrapper"></div>');
            var list = getSelectedAttributesList(product);

            if (list.length > 0) {
                list.forEach(function (attr) {
                    var name = attr.name;
                    if (name === CATEGORY_FILTER_LABEL) return;
                    var value = attr.value;
                    var type = attr.type;
                    var typeValue = attr.type_value || '';

                    var labelHtml = '<span class="cart-product-option-label">' + escapeHtml(name) + ' :</span>';
                    var valueHtml;
                    if (type === 'color' && typeValue) {
                        var hex = typeValue.indexOf('#') === 0 ? typeValue : ('#' + typeValue);
                        valueHtml = '<span class="cart-product-option-value">' +
                            '<span class="cart-product-color-swatch" style="background-color:' + escapeHtml(hex) + '" title="' + escapeHtml(value) + '" aria-hidden="true"></span>' +
                            '</span>';
                    } else {
                        valueHtml = '<span class="cart-product-option-value">' +
                            '<span class="cart-product-size-badge">' + escapeHtml(value || '-') + '</span>' +
                            '</span>';
                    }
                    $optionsWrapper.append('<div class="cart-product-option-row">' + labelHtml + valueHtml + '</div>');
                });
            } else if (product.sku) {
                var sizeMatch = product.sku.match(/-([A-Z0-9]+)$/);
                if (sizeMatch) {
                    $optionsWrapper.append(
                        '<div class="cart-product-option-row">' +
                        '<span class="cart-product-option-label">{{ _("Sizes") }}:</span>' +
                        '<span class="cart-product-option-value"><span class="cart-product-size-badge">' + escapeHtml(sizeMatch[1]) + '</span></span>' +
                        '</div>'
                    );
                }
            }

            if ($optionsWrapper.children().length === 0 && product.name) {
                var parts = String(product.name).split(/\s*-\s*/).slice(1).map(function (s) { return s.trim(); }).filter(Boolean);
                var productUrl = product.url || $productRow.find('.cart-product-image-link, .product-title-row a, h1 a').first().attr('href') || '';
                var slug = productUrl ? (productUrl.split('/products/')[1] || productUrl).split('?')[0].split('#')[0] : '';
                if (parts.length > 0 && slug && typeof zid !== 'undefined' && zid.products && zid.products.get) {
                    var pid = productId;
                    var sizeLabel = {{ _("Size") | tojson }};
                    var colorLabel = {{ _("Color") | tojson }};
                    var sizeLabels = ['xxl', 'xxxl', 'xl', 'l', 'm', 's', 'xs'];
                    var currentLang = {{ (session.locale.language.code if session.locale else 'ar') | tojson }};
                    zid.products.get(slug).then(function (data) {
                        var pd = data.product || data.data || data;
                        var valueToLabel = {};
                        if (pd && pd.options && pd.options.length) {
                            pd.options.forEach(function (opt) {
                                var optName = opt.name ? (typeof opt.name === 'object' ? (opt.name[currentLang] || opt.name.ar || opt.name.en || '') : opt.name) : '';
                                var choices = opt.choices || opt.values || [];
                                choices.forEach(function (c) {
                                    var vals = [];
                                    if (typeof c === 'object') {
                                        if (c.ar) vals.push(String(c.ar).trim());
                                        if (c.en) vals.push(String(c.en).trim());
                                        if (c.value) vals.push(String(c.value).trim());
                                        if (vals.length === 0) vals.push(String(c[currentLang] || c.name || '').trim());
                                    } else {
                                        vals.push(String(c).trim());
                                    }
                                    vals.filter(Boolean).forEach(function (v) { valueToLabel[v] = optName; });
                                });
                            });
                        }
                        var $r = $('.template_for_cart_products_list .cart-product-row-wrapper[data-cart-product-id="' + pid + '"]');
                        var $det = $r.find('.cart-product-col-details');
                        if ($det.find('.cart-product-options-wrapper').length > 0) return;
                        var $wr = $('<div class="cart-product-options-wrapper"></div>');
                        var $pr = $det.find('.cart-product-prices').first();
                        var customValues = {};
                        var $customSum = $det.find('.custom-options-summary');
                        if ($customSum.length && $customSum.find('.custom-field-row').length) {
                            $customSum.find('.custom-field-row').each(function () {
                                var $row = $(this);
                                var name = $row.find('.custom-field-name').text().replace(/\s*\*\s*$/, '').trim();
                                var val = $row.find('.custom-field-value').text().trim();
                                if (name) {
                                    customValues[val] = true;
                                    $wr.append('<div class="cart-product-option-row"><span class="cart-product-option-label">' + escapeHtml(name) + ' :</span><span class="cart-product-option-value"><span class="cart-product-size-badge">' + escapeHtml(val || '-') + '</span></span></div>');
                                }
                            });
                            $customSum.addClass('d-none');
                        }
                        parts.forEach(function (p) {
                            if (customValues[p]) return;
                            var lbl = valueToLabel[p] || (sizeLabels.some(function (s) { return p.toLowerCase() === s; }) || /^\d+$/.test(p) ? sizeLabel : (getHexForColorName(p) ? colorLabel : CATEGORY_FILTER_LABEL));
                            if (lbl === CATEGORY_FILTER_LABEL) return;
                            var hex = getHexForColorName(p);
                            var valHtml = hex ? '<span class="cart-product-color-swatch" style="background-color:' + escapeHtml(hex) + '" title="' + escapeHtml(p) + '" aria-hidden="true"></span>' : '<span class="cart-product-size-badge">' + escapeHtml(p) + '</span>';
                            $wr.append('<div class="cart-product-option-row"><span class="cart-product-option-label">' + escapeHtml(lbl) + ' :</span><span class="cart-product-option-value">' + valHtml + '</span></div>');
                        });
                        if ($wr.children().length) {
                            if ($pr.length) $pr.after($wr); else $det.append($wr);
                        }
                    }).catch(function () {
                        renderOptionsFallback($productRow, productId, parts, $details);
                    });
                    return;
                }
    if (parts.length > 0) {
        renderOptionsFallback($productRow, productId, parts, $details);
        return;
    }
                }

    // No options yet but we have variant id and slug: fetch product and use variant.attributes (لون، مقاس)
    if ($optionsWrapper.children().length === 0 && (slug || variantId)) {
        (function (pid, vid, s) {
            var key = s || vid;
            if (!key) return;
            function renderVariantOptions(variant) {
                if (!variant || !variant.attributes || !variant.attributes.length) return;
                var vList = getSelectedAttributesList(variant);
                var $wr = $('<div class="cart-product-options-wrapper"></div>');
                vList.forEach(function (attr) {
                    var name = attr.name;
                    if (name === CATEGORY_FILTER_LABEL) return;
                    var value = attr.value;
                    var type = attr.type;
                    var typeValue = attr.type_value || '';
                    var labelHtml = '<span class="cart-product-option-label">' + escapeHtml(name) + ' :</span>';
                    var valueHtml;
                    var hex = (type === 'color' && typeValue) ? (typeValue.indexOf('#') === 0 ? typeValue : ('#' + typeValue)) : getHexForColorName(value);
                    if (hex) {
                        valueHtml = '<span class="cart-product-option-value"><span class="cart-product-color-swatch" style="background-color:' + escapeHtml(hex) + '" title="' + escapeHtml(value || '') + '" aria-hidden="true"></span></span>';
                    } else {
                        valueHtml = '<span class="cart-product-option-value"><span class="cart-product-size-badge">' + escapeHtml(value || '-') + '</span></span>';
                    }
                    $wr.append('<div class="cart-product-option-row">' + labelHtml + valueHtml + '</div>');
                });
                var $r = $('.template_for_cart_products_list .cart-product-row-wrapper[data-cart-product-id="' + pid + '"]');
                var $det = $r.find('.cart-product-col-details');
                if ($det.length && $det.find('.cart-product-options-wrapper').length === 0 && $wr.children().length) {
                    var $pr = $det.find('.cart-product-prices').first();
                    if ($pr.length) $pr.after($wr); else $det.append($wr);
                    var $customSum = $det.find('.custom-options-summary');
                    if ($customSum.length) $customSum.addClass('d-none');
                }
            }
            function tryWith(pd) {
                if (!pd) return false;
                var variant = null;
                if (pd.attributes && pd.attributes.length) variant = pd;
                else if (pd.selected_variant && pd.selected_variant.attributes && pd.selected_variant.attributes.length) variant = pd.selected_variant;
                else {
                    var variants = pd.variants || pd.variations || [];
                    variant = variants.find(function (v) { return String(v.id) === String(vid); });
                }
                if (variant && variant.attributes && variant.attributes.length) {
                    renderVariantOptions(variant);
                    return true;
                }
                return false;
            }
            fetchProductBySlugOrId(key).then(function (pd) {
                if (tryWith(pd)) return;
                if (s && String(vid) !== String(s)) fetchProductBySlugOrId(vid).then(tryWith).catch(function () { });
            }).catch(function () { });
        })(productId, variantId, slug);
    }

    var $customSummary = $details.find('.custom-options-summary');
    var addedFromDom = false;
    if ($customSummary.length && $customSummary.find('.custom-field-row').length) {
        $customSummary.find('.custom-field-row').each(function () {
            var $row = $(this);
            var name = $row.find('.custom-field-name').text().replace(/\s*\*\s*$/, '').trim();
            var val = $row.find('.custom-field-value').text().trim();
            if (name) {
                addedFromDom = true;
                $optionsWrapper.append(
                    '<div class="cart-product-option-row">' +
                    '<span class="cart-product-option-label">' + escapeHtml(name) + ' :</span>' +
                    '<span class="cart-product-option-value"><span class="cart-product-size-badge">' + escapeHtml(val || '-') + '</span></span>' +
                    '</div>'
                );
            }
        });
    }
    if (!addedFromDom && product.has_fields) {
        getCustomFieldsList(product).forEach(function (f) {
            $optionsWrapper.append(
                '<div class="cart-product-option-row">' +
                '<span class="cart-product-option-label">' + escapeHtml(f.name) + ' :</span>' +
                '<span class="cart-product-option-value"><span class="cart-product-size-badge">' + escapeHtml(f.value || '-') + '</span></span>' +
                '</div>'
            );
        });
    }

    if ($optionsWrapper.children().length) {
        var $prices = $details.find('.cart-product-prices').first();
        if ($prices.length) $prices.after($optionsWrapper); else $details.append($optionsWrapper);
        if ($customSummary.length) $customSummary.addClass('d-none');
    }
            });

    /* Totals: CartEngine.patchTotals() */

    if (cart.free_shipping_rule) {
        var condition = cart.free_shipping_rule.subtotal_condition;
        var status = condition.status;
        var progress = condition.products_subtotal_percentage_from_min || 0;
        if (progress > 100) progress = 100;
        if (progress < 0) progress = 0;

        $('.free-shipping-rule-section').removeClass('d-none');
        $('.free-shipping-rule-progress').css('width', progress + '%');
        $('.free-shipping-truck-circle').css({ right: progress + '%', left: 'auto' });
        $('.free-shipping-current-subtotal').text(condition.products_subtotal_formatted || condition.products_subtotal || '');
        $('.free-shipping-min-total').text(condition.min_total_formatted || condition.min_string || '');

        if (status === 'min_not_reached') {
            var msg = '{{ _("Add products with total of %(total)s to get free shipping") }}'.replace('%(total)s', condition.remaining || condition.remaining_to_min_total_formatted || condition.remaining_to_min_total || '0');
            $('.free-shipping-rule-message').text(msg);
        } else if (status === 'max_exceed' || status === 'max_exceeded') {
            var msg = '{{ _("Free shipping applies for cart total between %(min)s and %(max)s") }}'.replace('%(min)s', condition.min_total_formatted || condition.min_string || '0').replace('%(max)s', condition.max_total_formatted || condition.max_string || '0');
            $('.free-shipping-rule-message').text(msg);
        } else if (status === 'applied') {
            $('.free-shipping-rule-message').text('{{ _("Free shipping applied") }}');
        }

        if (status === 'applied') {
            $('.free-shipping-rule-done').removeClass('d-none').addClass('d-flex');
            $('.free-shipping-progress-container').addClass('d-none').removeClass('d-flex');
            $('.free-shipping-rule-read-more').addClass('d-none').removeClass('d-block');
        } else if (status === 'max_exceed' || status === 'max_exceeded') {
            $('.free-shipping-rule-done').addClass('d-none').removeClass('d-flex');
            $('.free-shipping-progress-container').removeClass('d-none').addClass('d-flex');
            $('.free-shipping-rule-progress').css('width', '100%');
            $('.free-shipping-truck-circle').css({ left: '97%', right: 'auto' });
            $('.free-shipping-rule-read-more').addClass('d-none').removeClass('d-block');
        } else {
            $('.free-shipping-rule-done').addClass('d-none').removeClass('d-flex');
            $('.free-shipping-progress-container').removeClass('d-none').addClass('d-flex');
            if (status === 'min_not_reached') {
                $('.free-shipping-rule-read-more').removeClass('d-none').addClass('d-block');
            } else {
                $('.free-shipping-rule-read-more').addClass('d-none').removeClass('d-block');
            }
        }
    } else {
        $('.free-shipping-rule-section').addClass('d-none');
    }

        }

</script>

{% endblock %}

