{% extends "layout.jinja" %}

{% block header %} {% include 'header.jinja' %} {% endblock %}


{% block top_links %}
<link rel="stylesheet" type="text/css" href="{{ 'toastr.min.css' | asset_url }}" />
<link rel="stylesheet" type="text/css" href="{{ ('cart.css?v=24') | asset_url }}" />
{% endblock %}

{% block main_content %}

<section class="breadcrumb-section">
    <nav aria-label="{{ _('Breadcrumb') }}">
        <ol class="breadcrumb">
            <div class="container d-flex flex-wrap align-items-center" style="gap: 12px;">
                <li class="breadcrumb-item" aria-current="page">
                    <a href="/">{{ _("Home") }}</a>
                </li>
                <svg width="8" height="14" viewBox="0 0 8 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M0.750047 0.750046C0.750047 0.750046 6.74999 5.16898 6.75 6.75009C6.75001 8.33121 0.75 12.75 0.75 12.75" stroke="#404040" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <li class="breadcrumb-item active" aria-current="page">
                    {{ _("Cart") }}
                </li>
            </div>
        </ol>
    </nav>
</section>

<div class="modal" id="searchCitiesModal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-body" style="padding: 10px 20px 20px">
                <button type="button" class="close" data-dismiss="modal" aria-label="{{ _('Close') }}">
                    <span aria-hidden="true">&times;</span>
                </button>

                <h5 class="text-center py-3 mb-0 text-color-primary">
                    {{ _("Enjoy free shipping for the cities") }}
                </h5>

                <div class="p-2 d-lg-flex align-items-center bd-highlight search-input lg-search-div flex-grow-1">
                    <div class="form-group" style="position: relative; margin: 0px">
                        <span class="icon-search search-input-icon" style="z-index: 1"></span>
                        <div class="autocomplete" style="position: relative">
                            <input type="text" data-cat-id="" class="form-control cities-search-input pl-5"
                                placeholder="{{ _(" Search") }}">
                        </div>
                    </div>
                </div>

                <div>
                    <p class="cities-result lead">
                        {% for city in safeget(cart, "free_shipping_rule.shipping_cities_condition", []) %}
                        {{ city.name }}
                        {% if not loop.last %} {{ _(",") }} {% endif %}
                        {% endfor %}
                    </p>
                </div>

                <div class="d-flex justify-content-center mt-3">
                    <button type="button" class="btn btn-outline-secondary" data-dismiss="modal" style="width: 120px">{{
                        _("Cancel") }}</button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container mb-5">
   
    <div class="cart-view">
        <div class="row cart-products-with-totals {% if cart.products_count <= 0 %}d-none{% endif %}">
            <div class="col-12 col-lg-8" style="padding: 0;">
                <div class="cart-header-main d-flex justify-content-start gap-5 align-items-center mb-5 mt-5" style="gap: 8px;">
                    <h1 class="cart-main-title mb-0">
                        {{ _("My shopping bag") }}
                    </h1>
                    {% if cart.products_count > 0 %}
                    <span class="cart-products-count text-muted">
                        ({{ cart.products_count }} {{ _("products") }})
                    </span>
                    {% endif %}
                </div>
                <div class="section-cart-products">
                    <div class="template_for_cart_products_list">
                        {% include 'vitrin:cart/products_list.jinja' %}
                    </div>

                    <div class="cart-gift-card" data-gift-removed-success="{{ _('Gift card removed successfully') }}"
                        data-gift-added-success="{{ _('Send Successfully') }}"
                        style="display: {% if cart.gift_card_details and cart.gift_card_details | length > 0 %}block{% else %}none{% endif %};">
                        <div class="d-flex align-items-start">
                            <span class="gift-card-icon-wrapper">
                                <span class="icon-gift gift-icon-fallback"></span>
                                <img src="{% if cart.gift_card_details and cart.gift_card_details.card_design %}{{ cart.gift_card_details.card_design }}{% endif %}"
                                    class="gift-card-image {% if not cart.gift_card_details or not cart.gift_card_details.card_design %}d-none{% endif %}"
                                    alt="{{ _('Gift card design') }}" loading="lazy" decoding="async" />
                            </span>
                            <div class="gift-card-content flex-grow-1">
                                <div class="d-flex justify-content-between align-items-center">
                                    <p class="mb-0 gift-title">{{ _('Gift') }}</p>
                                    <p class="mb-0 gift-price-label">{{ _('Free') }}</p>
                                </div>
                                <div class="d-flex justify-content-between align-items-start gift-card-details-row">
                                    <div class="gift-card-info">
                                        <p class="mb-0 gift-sender-recipient">
                                            <span class="sender-label">{{ _("Sender") }}:</span> <span
                                                class="sender-name">{{cart.gift_card_details.sender_name if
                                                cart.gift_card_details else ''}}</span>;
                                            <span class="recipient-label">{{ _("Recipient") }}:</span> <span
                                                class="receiver-name">{{cart.gift_card_details.receiver_name if
                                                cart.gift_card_details else ''}}</span>
                                        </p>
                                        <p class="mb-0 message-info"
                                            style="display: {% if cart.gift_card_details and cart.gift_card_details.gift_message and cart.gift_card_details.gift_message | length > 0 %}block{% else %}none{% endif %};">
                                            <span class="gift-message">{{ cart.gift_card_details.gift_message if
                                                cart.gift_card_details else '' }}</span>
                                        </p>
                                        <p class="mb-0 media-link-info"
                                            style="display: {% if cart.gift_card_details and cart.gift_card_details.media_link and cart.gift_card_details.media_link | length > 0 %}block{% else %}none{% endif %};">
                                            <span class="gift-media-link">{{ cart.gift_card_details.media_link if
                                                cart.gift_card_details else '' }}</span>
                                        </p>
                                    </div>
                                    <div class="gift-card-actions">
                                        <button type="button" class="btn btn-sm btn-link gift-card-edit-btn"
                                            onclick="editGiftCard()" title="{{ _('Edit') }}">
                                            <img src="{{ 'edit-icon.svg' | asset_url }}" alt="{{ _('Edit') }}"
                                                class="gift-card-edit-icon" loading="lazy" decoding="async" />
                                        </button>
                                        <button type="button" class="btn btn-sm btn-link gift-card-delete-btn"
                                            onclick="deleteGiftCard()" title="{{ _('Delete') }}">
                                            <span class="icon-trash-alt"></span>
                                            <img class="delete-gift-progress d-none"
                                                src="{{ 'spinner.gif' | asset_url }}" width="15" height="15"
                                                loading="lazy" decoding="async" />
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>

            <div class="col-12 col-lg-4 cart-sidebar-column">
                <div class="cart-sidebar-wrapper">

                    <div class="cart-sidebar-card order-summary-card mb-4">
                        <h4 class="cart-sidebar-title">{{ _("Order Summary") }}</h4>

                        {% if cart.free_shipping_rule and cart.free_shipping_rule.code %}
                        {% set status = cart.free_shipping_rule.subtotal_condition.status | default('') %}
                        {% set condition = cart.free_shipping_rule.subtotal_condition %}
                        {% set progress = (condition.products_subtotal_percentage_from_min | default(0, true)) | int %}
                        <div class="summary-free-shipping-section mb-4">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <div class="free-shipping-message-text">
                                    {% if status == 'min_not_reached' %}
                                        {% set remaining = '<strong>' ~ (condition.remaining | default("0")) ~ '</strong>' %}
                                        {{ _("Would you like free shipping? Add products %(total)s") | format(total=remaining) | safe }}
                                    {% elif status == 'applied' %}
                                        {{ _("Free shipping applied") }}
                                    {% endif %}
                                </div>
                                <div class="free-shipping-read-more">
                                    <a data-toggle="modal" data-target="#searchCitiesModal" href="#">{{ _("Add more") }}</a>
                                </div>
                            </div>
                            <div class="free-shipping-track">
                                <div class="free-shipping-track-bg"></div>
                                <div class="free-shipping-track-fill free-shipping-rule-progress"
                                    style="width: {% if status == 'max_exceeded' or status == 'max_exceed' %}100%{% else %}{{ [progress, 100] | min | int }}%{% endif %}">
                                    <div class="free-shipping-truck-circle">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                            <path d="M17 17C15.8954 17 15 17.8954 15 19C15 20.1046 15.8954 21 17 21C18.1046 21 19 20.1046 19 19C19 17.8954 18.1046 17 17 17Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                            <path d="M7 17C5.89543 17 5 17.8954 5 19C5 20.1046 5.89543 21 7 21C8.10457 21 9 20.1046 9 19C9 17.8954 8.10457 17 7 17Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                            <path d="M5 17H3V5C3 4.44772 3.44772 4 4 4H13V17H11" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                            <path d="M13 9H18L21 12V17H19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                        </svg>
                                    </div>
                                </div>
                            </div>
                        </div>
                        {% endif %}
    
                        <div class="cart-totals-div" role="status" aria-live="polite" aria-atomic="true">
                            {% for cartTotal in cart.totals %}
                            <div class="cart-totals-row-wrapper" data-total-row="{{ cartTotal.code }}">
                                <div class="flex-grow-1">
                                    {{ cartTotal.title }}
                                    {% if cartTotal.code == 'total' and
                                    store.settings.general.tax_settings.tax_percentage_formatted %}&nbsp;<small>{{
                                        _('Includes TAX %(percentage)s') |
                                        format(percentage=store.settings.general.tax_settings.tax_percentage_formatted)
                                        }}</small>{% endif %}
                                </div>
                                <div class="flex-shrink-0 cart-total-value {% if cartTotal.code == 'total' %}cart-total-final{% endif %}"
                                    data-total="{{ cartTotal.code }}">{{ cartTotal.value_string }}</div>
                            </div>
                            {% endfor %}
                        </div>

                        <div class="cart-checkout-section mt-3" style="flex-direction: column; gap: 12px;">
                            <div class="coupon-card mb-3" style="width: 100%">
                     
                                <div class="coupon-form">
                                    <form style="width: 100%;">
                                        <div class="form-group mb-0 d-flex" style="width: 100%; gap: 12px;">
                                            <div class="coupon-capsule" style="width: 100%;">

                                                <svg width="22" height="22" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg">
<path d="M6.44171 18.3661C7.03274 18.3661 7.32825 18.3661 7.59747 18.466C7.63486 18.4798 7.67172 18.4951 7.70797 18.5117C7.96897 18.6315 8.17793 18.8404 8.59585 19.2583C9.55775 20.2202 10.0387 20.7012 10.6305 20.7455C10.71 20.7515 10.79 20.7515 10.8695 20.7455C11.4613 20.7012 11.9423 20.2202 12.9041 19.2583C13.3221 18.8404 13.531 18.6315 13.792 18.5117C13.8283 18.4951 13.8651 18.4798 13.9025 18.466C14.1718 18.3661 14.4673 18.3661 15.0583 18.3661H15.1673C16.6752 18.3661 17.4292 18.3661 17.8976 17.8976C18.3661 17.4292 18.3661 16.6752 18.3661 15.1673V15.0583C18.3661 14.4673 18.3661 14.1718 18.466 13.9025C18.4798 13.8651 18.4951 13.8283 18.5117 13.792C18.6315 13.531 18.8404 13.3221 19.2583 12.9041C20.2202 11.9423 20.7012 11.4613 20.7455 10.8695C20.7515 10.79 20.7515 10.71 20.7455 10.6305C20.7012 10.0387 20.2202 9.55775 19.2583 8.59585C18.8404 8.17793 18.6315 7.96897 18.5117 7.70797C18.4951 7.67172 18.4798 7.63486 18.466 7.59747C18.3661 7.32825 18.3661 7.03274 18.3661 6.44171V6.33269C18.3661 4.82479 18.3661 4.07083 17.8976 3.60239C17.4292 3.13394 16.6752 3.13394 15.1673 3.13394H15.0583C14.4673 3.13394 14.1718 3.13394 13.9025 3.03405C13.8651 3.02018 13.8283 3.00491 13.792 2.98828C13.531 2.86855 13.3221 2.65959 12.9041 2.24167C11.9423 1.27977 11.4613 0.798821 10.8695 0.754473C10.79 0.74851 10.71 0.74851 10.6305 0.754473C10.0387 0.798821 9.55775 1.27977 8.59585 2.24167C8.17793 2.65959 7.96897 2.86855 7.70797 2.98828C7.67172 3.00491 7.63486 3.02018 7.59747 3.03405C7.32825 3.13394 7.03274 3.13394 6.44171 3.13394H6.33269C4.82479 3.13394 4.07083 3.13394 3.60239 3.60239C3.13394 4.07083 3.13394 4.82479 3.13394 6.33269V6.44171C3.13394 7.03274 3.13394 7.32825 3.03405 7.59747C3.02018 7.63486 3.00491 7.67172 2.98828 7.70797C2.86855 7.96897 2.65959 8.17793 2.24167 8.59585C1.27977 9.55775 0.798821 10.0387 0.754473 10.6305C0.74851 10.71 0.74851 10.79 0.754473 10.8695C0.798821 11.4613 1.27977 11.9423 2.24167 12.9041C2.65959 13.3221 2.86855 13.531 2.98828 13.792C3.00491 13.8283 3.02018 13.8651 3.03405 13.9025C3.13394 14.1718 3.13394 14.4673 3.13394 15.0583V15.1673C3.13394 16.6752 3.13394 17.4292 3.60239 17.8976C4.07083 18.3661 4.82479 18.3661 6.33269 18.3661H6.44171Z" stroke="#808080" stroke-width="1.5"/>
<path d="M13.75 7.75L7.75 13.75" stroke="#808080" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
<path d="M13.75 13.75H13.7392M7.76076 7.75H7.75" stroke="#808080" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
</svg>


                                                <input class="form-control send-coupon" type="text" placeholder="{{ _("Add discount coupon") }}" />
                                               
                                            </div>

                                             <button type="button" class="btn coupon-activate-btn" data-apply-coupon
                                                    aria-label="{{ _("Apply discount coupon") }}">
                                                    <img class="send-coupon-progress d-none"
                                                        src="{{ 'spinner.gif' | asset_url }}" width="15" height="15"
                                                        loading="lazy" decoding="async" />
                                                    {{ _("Apply") }}
                                                </button>
                                        </div>
                                    </form>

                                    {% if cart.coupon.code %}
                                    <div class="message-coupon alert alert-primary mt-2" role="alert">
                                        <span>{{ cart.coupon.code }}</span>&nbsp;
                                        <a href="#" role="button" data-delete-coupon
                                            aria-label="{{ _('Remove coupon') }}"
                                            style="color: inherit; cursor: pointer">
                                            <span class="icon-trash-alt"></span>
                                            <img class="delete-coupon-progress d-none"
                                                src="{{ 'spinner.gif' | asset_url }}" width="15" height="15"
                                                loading="lazy" decoding="async" />
                                        </a>
                                    </div>
                                    {% endif %}
                                </div>
                            </div>
                            {% if store.settings.general.availability.closed_now %}
                            <a href="#" class="btn btn-lg btn-block btn-disabled">
                                {{ _("Complete Purchase") }}
                            </a>
                            {% else %}
                            {% if session.is_guest %}
                            <a href="/auth/login?redirect_to=/checkout"
                                class="btn btn-primary btn-lg btn-block cart-checkout-btn"
                                onclick="event.preventDefault(); handleLoginAction('/checkout'); return false;">
                                {{ _("Complete Purchase") }}
                            </a>
                            {% else %}
                            <a href="/checkout" class="btn btn-primary btn-lg btn-block cart-checkout-btn">
                                {{ _("Complete Purchase") }}
                            </a>
                            {% endif %}
                            <div>
                                {% include 'vitrin:checkout/apple-pay-quick-checkout.jinja' %}
                            </div>

                            {% endif %}

                            {% if store.settings.checkout.gift_order_settings.is_gift_order_enabled == '1' %}
                            <div class="mt-2">
                                <button id="gift-btn" type="button"
                                    class="btn btn-lg btn-block gift-card-toggle-btn gift-pill-btn d-flex align-items-center justify-content-between {% if cart.gift_card_details and cart.gift_card_details | length > 0 %}gift-added{% else %}gift-send{% endif %}"
                                    onclick="handleGiftCardClick()">
                                    <span class="gift-back-icon">

                                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
                                            xmlns="http://www.w3.org/2000/svg">
                                            <path
                                                d="M15 6.00015C15 6.00015 9.00001 10.4191 9 12.0002C8.99999 13.5813 15 18.0002 15 18.0002"
                                                stroke="#001529" stroke-width="1.5" stroke-linecap="round"
                                                stroke-linejoin="round" />
                                        </svg>

                                    </span>
                                    <span class="flex-grow-1 text-center mx-2">{{ _("Send as a gift") }}</span>
                                    <span class="gift-icon-wrapper">
                                        <svg width="24" height="24" viewBox="0 0 32 32" fill="none"
                                            xmlns="http://www.w3.org/2000/svg">
