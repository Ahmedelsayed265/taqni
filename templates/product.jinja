                                            + {{ _("Add Comment") }}
                                        </a>
                                        {% else %}
                                        <a href="{{ url_for('add_product_review', slug=product.slug) }}" class="btn add-review-btn" id="add-review-btn">
                                            + {{ _("Add Comment") }}
                                        </a>
