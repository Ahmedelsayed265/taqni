                            slidesPerView: 3,
                            slidesPerGroup: 3,
                        },
                        1240: {
                            slidesPerView: 4,
                            slidesPerGroup: 4,
                        }
                    },
                    autoplay: {
                        delay: 3000,
                    }
                });

    const maxChars = 105;
    const descEl = document.querySelector('.text-short-description');
    if (!descEl) return;

    const readMoreLink = descEl.querySelector('#product-description-a');
    const fullText = descEl.childNodes[0]
        ? descEl.childNodes[0].textContent.trim()
        : '';

    if (!fullText) return;

    if (fullText.length <= maxChars) {
        // No truncation needed, just keep the read more anchor as-is
        return;
    }

    const truncated = fullText.slice(0, maxChars).trimEnd() + '... ';

    const textNode = document.createTextNode(truncated);

    descEl.innerHTML = '';
    descEl.appendChild(textNode);

    if (readMoreLink) {
        descEl.appendChild(readMoreLink);
        readMoreLink.style.display = 'inline';
    }

    let expanded = false;

    if (readMoreLink) {
        readMoreLink.addEventListener('click', function (e) {
            e.preventDefault();

            if (!expanded) {
                descEl.childNodes[0].textContent = fullText + ' ';
                readMoreLink.textContent = '{{ _("Less") }}';
                expanded = true;
            } else {
                descEl.childNodes[0].textContent = truncated;
                readMoreLink.textContent = '{{ _("Read More") }}';
                expanded = false;
            }
        });
    }

                // Tab switching
            document.querySelectorAll('.product-tab-btn').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    document.querySelectorAll('.product-tab-btn').forEach(b => b.classList.remove('active'));
                    document.querySelectorAll('.product-tab-content').forEach(c => c.classList.remove('active'));
                    this.classList.add('active');
                    document.getElementById('tab-' + this.getAttribute('data-tab')).classList.add('active');
                });
            });

            function toggleQuestionForm() {
                var wrap = document.getElementById('question-form-wrap');
                if (wrap) wrap.classList.toggle('d-none');
            }

            async function submitProductQuestion() {
                var input = document.getElementById('question-input');
                var text = input ? input.value.trim() : '';
                if (!text) return;

                var productId = document.getElementById('product-id') ? document.getElementById('product-id').value : '';
                var progress = document.querySelector('.question-submit-progress');
                if (progress) progress.classList.remove('d-none');

                try {
                    var res = await fetch('{{ store.permalink }}api/v1/products/' + encodeURIComponent(productId) + '/questions', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ question: text })
                    });
                    if (res.ok) {
                        window.zid?.toaster?.showSuccess('{{ _("Question sent successfully") }}');
                        input.value = '';
                        document.getElementById('question-form-wrap').classList.add('d-none');
                    } else {
                        window.zid?.toaster?.showError('{{ _("Failed to send question") }}');
                    }
                } catch(e) {
                    window.zid?.toaster?.showError('{{ _("Failed to send question") }}');
                } finally {
                    if (progress) progress.classList.add('d-none');
                }
            }

            var viewingNumberEl = document.querySelector(".product-viewing-now-number");
            if (viewingNumberEl) {
                function setRandomViewingCount() {
                    viewingNumberEl.textContent = Math.floor(Math.random() * 250) + 1;
                }
                setRandomViewingCount();
                setInterval(setRandomViewingCount, 10000);
            }

            document.querySelectorAll(".product-share-native-btn").forEach(function(btn) {
                btn.addEventListener("click", function() {
                    var url = this.getAttribute("data-product-url") || "";
                    var title = this.getAttribute("data-product-name") || document.title || "";
                    var text = title;
                    if (navigator.share) {
                        navigator.share({ title: title, text: text, url: url }).then(function() {}).catch(function(err) {
                            if (err.name !== "AbortError") { fallbackShare(url, title); }
                        });
                    } else {
                        fallbackShare(url, title);
                    }
                });
            });
        });

        function fallbackShare(url, title) {
            if (navigator.clipboard && navigator.clipboard.writeText) {
                navigator.clipboard.writeText(url).then(function() {
                    if (typeof window.showToast === "function") { window.showToast("{{ _('Link copied') }}"); }
                    else { alert("{{ _('Link copied') }}"); }
                }).catch(function() { window.open("mailto:?subject=" + encodeURIComponent(title) + "&body=" + encodeURIComponent(url), "_blank"); });
            } else {
                window.open("mailto:?subject=" + encodeURIComponent(title) + "&body=" + encodeURIComponent(url), "_blank");
            }
        }

        $(document).on('click', '.accordion-header', function () {
            var $body = $(this).next('.accordion-body');
            var $plusIcon = $(this).find('.plus-icon');
            var $minusIcon = $(this).find('.minus-icon');

            $body.toggleClass("active");

            // Toggle + / -
                $plusIcon.toggleClass('d-none');
                $minusIcon.toggleClass('d-none');
        });

       
