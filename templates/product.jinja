{% extends "layout.jinja" %}

{% block header %} {% include 'header.jinja' %} {% endblock %}

{% block top_links %}
    <link rel="stylesheet" type="text/css" href="{{ 'toastr.min.css' | asset_url }}" />
    <link rel="stylesheet" type="text/css" href="{{ 'ekko-lightbox.css' | asset_url }}" />

    <link rel="stylesheet" type="text/css" href="{{ ('product-details.css?v=' ~ ver)  | asset_url }}" />
    <script>window.__playLabel = {{ _('Play') | tojson }}; window.__pauseLabel = {{ _('Pause') | tojson }};</script>
{% endblock %}


{% block main_content %}

    <section class="breadcrumb-section product-breadcrumb-section">
        <div class="container">
            <nav aria-label="{{ _('Breadcrumb') }}">
                <ol class="breadcrumb">
                        <li class="breadcrumb-item">
                            <a href="/">{{ _("Home") }}</a>
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M9.00005 6C9.00005 6 15 10.4189 15 12C15 13.5812 9 18 9 18" stroke="#404040" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </li>
                        {% if product.categories and product.categories|length > 0 %}
                        {% set main_cat = product.categories[0] %}
                        {% set main_cat_name = main_cat.name if main_cat.name is string else (safeget(main_cat.name, session.lang) or safeget(main_cat.name, 'ar') or safeget(main_cat.name, 'en') or '') %}
                        <li class="breadcrumb-item">
                            <a href="/categories/{{ main_cat.id }}/{{ main_cat.slug }}">{{ main_cat_name }}</a>
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M9.00005 6C9.00005 6 15 10.4189 15 12C15 13.5812 9 18 9 18" stroke="#404040" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </li>
                        {% endif %}
                        <li class="breadcrumb-item active" aria-current="page">{{ product.name | safe }}</li>
                </ol>
            </nav>
        </div>
    </section>

    <section class="product products-details-page">
                                        <!-- Carousel -->
        <div class="container">
            <section class="products-details">
                    <div class="products-details-row">
                            <div id="wrap" class="product-gallery-wrap">
                                        <div class="product-images-swiper {% if product.selected_product.media | length <= 0 %}d-none{% endif %}">
                                            <div class="swiper mySwiper-26" style="width: 100%;">
                                                <div class="swiper-wrapper">
                                                    {% for image in product.selected_product.media %}
                                                    <div class="swiper-slide">
                                                        <a class="image-link"
                                                                           style="display:block; width: 100%; height: 100%;">
                                                                            <img src="{{ image.image.full_size }}" class="carousel-img" alt="{{ image.alt_text }}">
                                                                            {% if image.provider and image.link %}
                                                                                <img id="main-video-icon"
                                                                                  class="play-icon"
                                                                                  src="{{ 'video-play.svg' | asset_url }}"
                                                                                  alt="play"
                                                                                  width="25"
                                                                                  onClick="showIframe(this, '{{ image.link }}')"
                                                                                />
                                                                            {% endif %}
                                                                        </a>
                                                                        {% if image.provider and image.link %}
                                                                            <div class="iframe-video pt-1 d-none">
                                                                                <a
                                                                                  id="iframe-close-btn"
                                                                                  type="button"
                                                                                  class="text-white btn btn-none grow"
                                                                                  onClick="hideIframe(this)"
                                                                                >
                                                                                  X
                                                                                </a>
                                                                                <iframe
                                                                                  width="100%"
                                                                                  height="100%"
                                                                                  src=""
                                                                                  frameborder="0"
                                                                                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
                                                                                  allowfullscreen
                                                                                  style="max-width: 100%"
                                                                                >
                                                                                </iframe>
                                                                            </div>
                                                                        {% endif %}
                                                    </div>
                                                    {% endfor %}
                                                </div>
                                            </div>
                                            <div class="swiper mySwiper-25" style="width: 100%;">
                                                <div class="swiper-wrapper">
                                                    {% for image in product.selected_product.media %}
                                                    <div class="swiper-slide">
                                                        <a class="image-link"
                                                                           style="display:block; width: 100%; height: 100%;">
                                                                            <img src="{{ image.image.full_size }}" class="carousel-img" alt="{{ image.alt_text }}">
                                                                            {% if image.provider and image.link %}
                                                                                <img id="main-video-icon"
                                                                                  class="play-icon"
                                                                                  src="{{ 'video-play.svg' | asset_url }}"
                                                                                  alt="play"
                                                                                  width="25"
                                                                                  onClick="showIframe(this, '{{ image.link }}')"
                                                                                />
                                                                            {% endif %}
                                                        </a>
                                                                        {% if image.provider and image.link %}
                                                                            <div class="iframe-video pt-1 d-none">
                                                                                <a
                                                                                  id="iframe-close-btn"
                                                                                  type="button"
                                                                                  class="text-white btn btn-none grow"
                                                                                  onClick="hideIframe(this)"
                                                                                >
                                                                                  X
                                                                                </a>
                                                                                <iframe
                                                                                  width="100%"
                                                                                  height="100%"
                                                                                  src=""
                                                                                  frameborder="0"
                                                                                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
                                                                                  allowfullscreen
                                                                                  style="max-width: 100%"
                                                                                >
                                                                                </iframe>
                                                                            </div>
                                                                        {% endif %}
                                                    </div>
                                                    {% endfor %}
                                                </div>
                                                <div class="swiper-pagination"></div>
                                            </div>
                                        </div>

                                        <!-- No image -->
                                        <div class="box-1-1 product-images-empty {% if product.selected_product.media | length > 0 %}d-none{% endif %}">
                                            <div class="content">
                                                <div class="d-flex" style="width: 100%; height: 100%;">
                                                    <img src="{{ 'product-img.svg' | asset_url }}" width="100%" height="auto" />
                                                </div>
                                            </div>
                                        </div>
                            </div>

                        <div class="col-product-info {% if product.selected_product.media | length <= 1 %}col-product-info-single-image{% endif %}">

                            <section class="product-info-section">
                                {% if product.badge %}
                                   {% include 'vitrin:products/badge.jinja' %}
                                {% endif %}
                                <div class="product-top-title">
                                    <h1 class="product-name">{{ product.name | safe }}</h1>

                                    <div class="product-rating-share-row-desktop d-flex align-items-center justify-content-between flex-wrap">
                                        <div class="product-actions-icons d-flex align-items-center">
                                            {# {% if product.rating %}
                                            <div class="product-rating-block d-flex align-items-center">
                                                {% if product.rating.total_count > 0 %}<span class="product-card-rating-count">({{ product.rating.total_count }}) <span style="color: black;">{{ product.rating.average }}</span></span>{% endif %}
                                                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                                                    <path d="M7.99744 0C8.77819 0 9.39318 0.589753 9.7858 1.38552L11.0969 4.02962C11.1367 4.11146 11.2309 4.22669 11.3726 4.3321C11.5141 4.4374 11.6527 4.49549 11.7439 4.51082L14.1173 4.90842C14.9745 5.0525 15.6931 5.47275 15.9264 6.20455C16.1594 6.93573 15.8179 7.69558 15.2015 8.31324L15.2009 8.31384L13.3571 10.173C13.284 10.2467 13.2021 10.3855 13.1508 10.5663C13.0998 10.746 13.0953 10.9096 13.1184 11.0153L13.1187 11.0167L13.6462 13.3166C13.865 14.2739 13.7925 15.2231 13.1175 15.7193C12.4401 16.2172 11.5144 15.9965 10.6735 15.4956L8.4487 14.1677C8.35527 14.1118 8.19482 14.0666 8.00116 14.0666C7.80892 14.0666 7.64509 14.1112 7.54559 14.1691L7.54418 14.1699L5.32379 15.4953C4.48385 15.998 3.55932 16.2148 2.88188 15.7163C2.20728 15.22 2.13112 14.2726 2.35061 13.3161L2.878 11.0167L2.87833 11.0153C2.90145 10.9096 2.89692 10.746 2.84593 10.5663C2.79459 10.3855 2.71273 10.2467 2.63966 10.173L0.794534 8.31249C0.182002 7.69485 -0.158371 6.93566 0.0728464 6.20555C0.304737 5.47331 1.02191 5.05255 1.87976 4.90838L4.25115 4.51111L4.2519 4.51097C4.33884 4.49589 4.4754 4.43845 4.61661 4.33288C4.75808 4.22711 4.85257 4.11162 4.8924 4.02962L4.8944 4.02554L6.20385 1.38482L6.20436 1.38378C6.6007 0.588669 7.2176 0 7.99744 0Z" fill="#D7A600"/>
                                                </svg>
                                            </div>
                                            {% endif %} #}
                                            <button type="button" class="product-icon-btn product-icon-share product-share-native-btn" aria-label="{{ _('share product') }}" data-product-url="{{ product.html_url }}" data-product-name="{{ product.name | e }}">
                                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                                    <path d="M21 6.5C21 8.15685 19.6569 9.5 18 9.5C16.3431 9.5 15 8.15685 15 6.5C15 4.84315 16.3431 3.5 18 3.5C19.6569 3.5 21 4.84315 21 6.5Z" stroke="#0A0A0A" stroke-width="1.5"/>
                                                    <path d="M9 12C9 13.6569 7.65685 15 6 15C4.34315 15 3 13.6569 3 12C3 10.3431 4.34315 9 6 9C7.65685 9 9 10.3431 9 12Z" stroke="#0A0A0A" stroke-width="1.5"/>
                                                    <path d="M21 17.5C21 19.1569 19.6569 20.5 18 20.5C16.3431 20.5 15 19.1569 15 17.5C15 15.8431 16.3431 14.5 18 14.5C19.6569 14.5 21 15.8431 21 17.5Z" stroke="#0A0A0A" stroke-width="1.5"/>
                                                    <path d="M8.72852 10.7498L15.2285 7.75031M8.72852 13.2503L15.2285 16.2498" stroke="#0A0A0A" stroke-width="1.5"/>
                                                </svg>
                                            </button>
                                            {% if store.settings.products.wishlist_enabled == true %}
                                            <span class="product-icon-btn add-to-wishlist position-relative product-page-wishlist" data-wishlist-id="{{ product.id }}">
                                                {% if not session.is_guest %}
                                                <a style="display: none;" class="product-icon-btn product-icon-favorite icon-heart-mask filled" zid-visible-wishlist="{{ product.id }}" onclick="addToWishlist(this, '{{ product.id }}')" href="javascript:void(0)" aria-label="{{ _('Add to wishlist') }}"></a>
                                                <a class="product-icon-btn product-icon-favorite" zid-hidden-wishlist="{{ product.id }}" onclick="addToWishlist(this, '{{ product.id }}')" href="javascript:void(0)" aria-label="{{ _('Add to wishlist') }}">
                                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                                        <path d="M19.4626 3.99415C16.7809 2.34923 14.4404 3.01211 13.0344 4.06801C12.4578 4.50096 12.1696 4.71743 12 4.71743C11.8304 4.71743 11.5422 4.50096 10.9656 4.06801C9.55962 3.01211 7.21909 2.34923 4.53744 3.99415C1.01807 6.15294 0.221721 13.2749 8.33953 19.2834C9.88572 20.4278 10.6588 21 12 21C13.3412 21 14.1143 20.4278 15.6605 19.2834C23.7783 13.2749 22.9819 6.15294 19.4626 3.99415Z" stroke="#0A0A0A" stroke-width="1.5" stroke-linecap="round"/>
                                                    </svg>
                                                </a>
                                                {% else %}
                                                <a class="product-icon-btn product-icon-favorite" href="{{ url_for('login_page', query_params={"redirect_to": session.path} ) }}" aria-label="{{ _('Add to wishlist') }}">
                                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                                        <path d="M19.4626 3.99415C16.7809 2.34923 14.4404 3.01211 13.0344 4.06801C12.4578 4.50096 12.1696 4.71743 12 4.71743C11.8304 4.71743 11.5422 4.50096 10.9656 4.06801C9.55962 3.01211 7.21909 2.34923 4.53744 3.99415C1.01807 6.15294 0.221721 13.2749 8.33953 19.2834C9.88572 20.4278 10.6588 21 12 21C13.3412 21 14.1143 20.4278 15.6605 19.2834C23.7783 13.2749 22.9819 6.15294 19.4626 3.99415Z" stroke="#0A0A0A" stroke-width="1.5" stroke-linecap="round"/>
                                                    </svg>
                                                </a>
                                                {% endif %}
                                                <img class="loader d-none" src="{{ 'spinner.gif' | asset_url }}" width="20" height="20"/>
                                            </span>
                                            {% endif %}
                                        </div>
                                    </div>
                                </div>
                                {% if product.short_description %}
                                    <p class="text-short-description">{{ product.short_description | replace('<br>', ' ') | replace('<br/>', ' ') | replace('</p>', ' ') | replace('<p>', ' ') | striptags | trim }} <a id="product-description-a" href="#product-description-{{ product.id }}" class="text-color-primary">{{ _("Read More") }}</a></p>
                                {% endif %}
                                {# <div class="d-flex flex-column flex-lg-row product-features">
                                  
                                    {% if product.sold_products_count %}
                                        <div class="product-count d-flex align-items-center">
                                            <span class="icon-military_tech" style="color: #FFCF57; font-size: 16px"></span>&nbsp;
                                            <span class="lang">{{ _("Sold more than %s times") | format(product.sold_products_count) }}</span>
                                        </div>
                                    {% elif product.selected_product.sold_products_count %}
                                        <div class="product-count d-flex align-items-center">
                                            <span class="icon-military_tech" style="color: #FFCF57; font-size: 16px"></span>&nbsp;
                                            <span class="lang">{{ _("Sold more than %s times") | format(product.selected_product.sold_products_count) }}</span>
                                        </div>
                                    {% endif %}


                                    {% if product.low_stock_quantity %}
                                        <div class="low-quantity-section d-inline-block">
                                            <span class="icon-flag_black" style="color: #EC5550; font-size: 16px"></span>&nbsp;
                                            <span class="low-quantity">{{ _("Remaining %s only") | format(product.low_stock_quantity) }}</span>
                                        </div>
                                    {% endif %}

                                    {% if product.bundle_offer %}
                                    <div class="bundle-offer-section">
                                        <span class="icon-gift" style="color: red; font-size: 14px"></span>&nbsp;
                                        <span class="bundle-offer-title" style="unicode-bidi: isolate">{{ product.bundle_offer.name }}</span>
                                    </div>
                                    {% endif %}


                                </div> #}
                                <div class="d-flex align-items-center justify-content-between">
                                    <div class="product-price-block">
                                        {% if product.selected_product.formatted_sale_price %}
                                        <div class="product-price-current-row d-flex align-items-center flex-wrap">
                                            <h2 class="product-formatted-price product-formatted-price-current mb-0">{{ product.selected_product.formatted_sale_price }}</h2>
                                        </div>
                                        <p class="product-price-old-line mb-0"><del class="product-formatted-price-old">{{ product.selected_product.formatted_price }}</del></p>
                                        {% else %}
                                        <div class="product-price-current-row">
                                            <h2 class="product-formatted-price product-formatted-price-current mb-0">{{ product.selected_product.formatted_price }}</h2>
                                        </div>
                                        {% endif %}
                                    </div>
                                </div>

                                <div>
                                    {% include 'vitrin:products/loyalty_points_widget.jinja' %}
                                </div>

                                <div>
                                    {% include 'vitrin:products/payment_widgets.jinja' %}
                                </div>
                            </section>

                            <form id="product-form">
                                <input id="product-id" type="hidden" value="{{ product.selected_product.id }}">

                                <div class="size-box">

                                    {% include 'vitrin:products/variants_list.jinja' %}

                                    <!-- new custom fields update -->
                                    {% if product.custom_input_fields  %}
                                        {% include 'vitrin:products/custom_input_fields.jinja' %}
                                    {% endif %}
                                </div>

                                <div class="section-out-of-stock-notify-me {% if not product.selected_product.in_stock %}d-block{% else %}d-none{% endif %}">
                                    <div>
                                        <h4 class="product-title">{{ _("This product is out of stock") }}</h4>
                                        <form>
                                            <input type="hidden" class="send-notify-product-id" value="{{ product.selected_product.id }}">
                                            <div class="form-group form-notify-me">
                                                <h4>{{ _("Notify me when product is available") }}</h4>
                                                
                                                <input class="form-control send-notify-name" value="" type="text" placeholder="{{ _('Enter your name') }}" />
                                                <input class="form-control send-notify-email" type="email" value="" placeholder="{{ _('Enter your email') }}" />
                                                <div class="d-flex form-notify-me-phone-row">
                                                    <input class="form-control send-notify-country-key"
                                                        type="number"
                                                        placeholder="966" maxlength="4" />
                                                    <input class="form-control send-notify-phone" type="number"  value="" placeholder="{{ _('Enter your phone (Optional)') }}" maxlength="10" />
                                                </div>
                                                <div class="form-notify-me-submit-button-row">
                                                    <button type="button" class="btn btn-primary btn-send-notify" onclick="sendProductNotifyMe()">
                                                    <img class="send-notify-progress d-none" src="{{ 'spinner.gif' | asset_url }}" width="15" height="15"/>
                                                    {{ _("Send") }}
                                                    </button>
                                                </div>
                                            
                                            </div>
                                        </form>
                                    </div>
                                </div>


                            </form>
        
                            <!-- Bundle Product Selection container-fluid -->
                            {% if product.product_class == 'dynamic_bundle' %}
                                {% include 'vitrin:products/bundle-products.jinja' %}
                            {% endif %}

                            <div class="product-buttons {% if not product.selected_product.in_stock %}d-none{% else %}d-block{% endif %}">
                                    <div class="d-flex align-center add-to-cart-container" style="gap: 16px; margin-top: 24px;">
                                    {% if product.selected_product.is_infinite or product.selected_product.quantity > 0 %}
                                    <div class="select-quantity-div">
                                            <div class="form-group">
                                                <div class="quantity-selector-wrap">
                                                    <button type="button" class="quantity-btn minus" aria-label="{{ _('Decrease quantity') }}">
                                                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                                            <path d="M20 12L4 12" stroke="#212529" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                                        </svg>
                                                    </button>
                                                    <input 
                                                        type="number"
                                                        id="product-quantity"
                                                        name="quantity"
                                                        value="1"
                                                        min="1"
                                                        max="{{ maxQuantity }}"
                                                        class="qty-input"
                                                    >
                                                    <button type="button" class="quantity-btn plus" aria-label="{{ _('Increase quantity') }}">
                                                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                                            <path d="M12 4V20" stroke="#212529" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                                            <path d="M4 12H20" stroke="#212529" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                                        </svg>
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                        {% endif %}
                                        <button class="btn btn-add-to-cart" type="button" onclick="productAddToCart()">
                                            <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
