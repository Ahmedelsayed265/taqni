       <script>
/**
 * ========================================
 * Product Page - Optimized & Clean Code
 * ========================================
 * جميع الوظائف محسّنة ومنظمة بدون تكرار
 */

(function() {
    'use strict';

    // ============================================
    // 1️⃣ GLOBAL STATE & CONFIG
    // ============================================
    const STATE = {
        intervals: [],
        observers: [],
        slickInitialized: false,
        eventListenersAttached: false,
        availabilityUpdaterAttached: false,
        imagesToOptionsAdded: false,
        addImagesToOptionsInProgress: false,
        resizeHandlerAttached: false
    };

    const CONFIG = {
        quantityDebounceDelay: 150,
        mutationObserverDelay: 100
    };

    // ============================================
    // 2️⃣ UTILITY FUNCTIONS
    // ============================================
    const Utils = {
        debounce(func, wait) {
            let timeout;
            return function executedFunction(...args) {
                const later = () => {
                    clearTimeout(timeout);
                    func(...args);
                };
                clearTimeout(timeout);
                timeout = setTimeout(later, wait);
            };
        },

        getCurrencySymbol() {
            return window.productData?.currency_symbol || 'ر.س';
        },

        formatPrice(price) {
            return parseFloat(price).toFixed(2);
        },

        safeQuerySelector(selector) {
            try {
                return document.querySelector(selector);
            } catch (e) {
                console.warn('Invalid selector:', selector);
                return null;
            }
        },

        parsePrice(priceText) {
            if (!priceText) return 0;
            const match = String(priceText).match(/[\d,]+\.?\d*/);
            return match ? parseFloat(match[0].replace(/,/g, '')) : 0;
        }
    };

    // ============================================
    // 3️⃣ STICKY BAR MODULE
    // ============================================
    const StickyBar = {
        init() {
            const stickyBar = document.getElementById('product-sticky-bar');
            if (stickyBar) {
                stickyBar.classList.add('sticky-bar-visible');
            }
        },

        update(selectedProduct) {
            if (!selectedProduct) return;

            const updates = {
                image: () => {
                    const img = document.getElementById('sticky-product-img');
                    if (img && selectedProduct.media?.[0]?.image) {
                        img.src = selectedProduct.media[0].image.medium || selectedProduct.media[0].image.full_size;
                    }
                },
                name: () => {
                    const name = document.getElementById('sticky-product-name');
                    if (name && window.productData) {
                        name.textContent = window.productData.name || '';
                    }
                },
                price: () => {
                    const priceEl = document.getElementById('sticky-product-price');
                    const priceOldEl = document.getElementById('sticky-product-price-old');
                    
                    if (priceEl) {
                        priceEl.textContent = selectedProduct.formatted_sale_price || selectedProduct.formatted_price;
                        
                        if (priceOldEl) {
                            if (selectedProduct.formatted_sale_price) {
                                priceOldEl.textContent = selectedProduct.formatted_price;
                                priceOldEl.style.display = 'inline';
                            } else {
                                priceOldEl.style.display = 'none';
                            }
                        }
                    }
                },
                buttons: () => {
                    const addToCart = document.getElementById('sticky-add-to-cart');
                    const buyNow = document.getElementById('sticky-buy-now');
                    
                    if (selectedProduct.in_stock) {
                        if (addToCart) {
                            addToCart.style.display = 'flex';
                            addToCart.disabled = false;
                        }
                        // Show buy now button for both guests and customers when in stock
                        if (buyNow) {
                            buyNow.classList.remove('d-none');
                        }
                    } else {
                        if (addToCart) addToCart.style.display = 'none';
                        if (buyNow) buyNow.classList.add('d-none');
                    }
                }
            };

            Object.values(updates).forEach(fn => fn());
        }
    };


    // ============================================
    // 5.5️⃣ PRICE UPDATER MODULE
    // ============================================
    const PriceUpdater = {
        basePrice: null,
        baseSalePrice: null,
        baseFormattedPrice: null,
        baseFormattedSalePrice: null,
        hasDiscount: false,

        init(product) {
            if (product) {
                this.setBasePrice(product);
            }
        },

        setBasePrice(product) {
            // Store numeric prices if available
            this.basePrice = product.price || null;
            this.baseSalePrice = product.sale_price || null;
            
            // Store formatted prices as fallback
            this.baseFormattedPrice = product.formatted_price || '';
            this.baseFormattedSalePrice = product.formatted_sale_price || '';
            this.hasDiscount = !!product.formatted_sale_price;
        },

        updatePriceByQuantity() {
            const quantityInput = document.getElementById('product-quantity');
            if (!quantityInput) return;

            const quantity = parseInt(quantityInput.value) || 1;
            
            // Get current product
            const currentProduct = window.productData?.selected_product || window.productData;
            if (!currentProduct) return;

            // Update base price if product changed
            if (!this.baseFormattedPrice || 
                (currentProduct.formatted_price !== this.baseFormattedPrice && 
                 currentProduct.formatted_sale_price !== this.baseFormattedSalePrice)) {
                this.setBasePrice(currentProduct);
            }

            // Calculate total price
            let totalPrice = '';
            let totalOldPrice = '';
            
            if (this.hasDiscount && this.baseFormattedSalePrice) {
                // Use numeric price if available, otherwise parse formatted price
                let unitPrice = this.baseSalePrice;
                if (!unitPrice) {
                    unitPrice = Utils.parsePrice(this.baseFormattedSalePrice);
                }
                
                let unitOldPrice = this.basePrice;
                if (!unitOldPrice) {
                    unitOldPrice = Utils.parsePrice(this.baseFormattedPrice);
                }

                const total = unitPrice * quantity;
                const totalOld = unitOldPrice * quantity;

                // Format the prices
                totalPrice = this.formatTotalPrice(total, this.baseFormattedSalePrice);
                totalOldPrice = this.formatTotalPrice(totalOld, this.baseFormattedPrice);
            } else if (this.baseFormattedPrice) {
                let unitPrice = this.basePrice;
                if (!unitPrice) {
                    unitPrice = Utils.parsePrice(this.baseFormattedPrice);
                }

                const total = unitPrice * quantity;
                totalPrice = this.formatTotalPrice(total, this.baseFormattedPrice);
            }

            // Update price display
            if (totalPrice) {
                const priceEl = document.querySelector('.product-formatted-price');
                if (priceEl) {
                    priceEl.textContent = totalPrice;
                }

                const priceOldEl = document.querySelector('.product-formatted-price-old');
                if (priceOldEl) {
                    if (totalOldPrice && this.hasDiscount) {
                        priceOldEl.textContent = totalOldPrice;
                        priceOldEl.style.display = 'inline';
                    } else {
                        priceOldEl.textContent = '';
                        priceOldEl.style.display = 'none';
                    }
                }

                // Update sticky bar price
                const stickyPriceEl = document.getElementById('sticky-product-price');
                if (stickyPriceEl) {
                    stickyPriceEl.textContent = totalPrice;
                }

                const stickyPriceOldEl = document.getElementById('sticky-product-price-old');
                if (stickyPriceOldEl) {
                    if (totalOldPrice && this.hasDiscount) {
                        stickyPriceOldEl.textContent = totalOldPrice;
                        stickyPriceOldEl.style.display = 'inline';
                    } else {
                        stickyPriceOldEl.style.display = 'none';
                    }
                }
            }
        },

        formatTotalPrice(total, originalFormatted) {
            if (!originalFormatted) {
                const currencySymbol = Utils.getCurrencySymbol();
                return total.toFixed(2) + ' ' + currencySymbol;
            }

            // Extract the number part from original formatted price
            const numberMatch = String(originalFormatted).match(/[\d,]+\.?\d*/);
            if (!numberMatch) {
                const currencySymbol = Utils.getCurrencySymbol();
                return total.toFixed(2) + ' ' + currencySymbol;
            }

            // Get the original number to calculate the format
            const originalNumber = parseFloat(numberMatch[0].replace(/,/g, ''));
            if (!originalNumber || originalNumber === 0) {
                const currencySymbol = Utils.getCurrencySymbol();
                return total.toFixed(2) + ' ' + currencySymbol;
            }

            // Determine decimal places from original
            const decimalPlaces = numberMatch[0].includes('.') ? 
                (numberMatch[0].split('.')[1]?.length || 2) : 0;

            // Format the total number
            let formattedNumber;
            if (originalFormatted.includes(',')) {
                // Use locale formatting with commas
                formattedNumber = total.toLocaleString('en-US', {
                    minimumFractionDigits: decimalPlaces,
                    maximumFractionDigits: decimalPlaces
                });
            } else {
                // Simple format without commas
                formattedNumber = total.toFixed(decimalPlaces || 2);
            }

            // Replace the number in the original string
            return String(originalFormatted).replace(/[\d,]+\.?\d*/, formattedNumber);
        }
    };

    // 6️⃣ QUANTITY CONTROLS MODULE
    // ============================================
    const QuantityControls = {
        init() {
            window.increaseQuantity = () => this.changeQuantity(1);
            window.decreaseQuantity = () => this.changeQuantity(-1);
            window.validateQuantity = () => this.validate();
            
            // Add input event listener for real-time price updates
            const quantityInput = document.getElementById('product-quantity');
            if (quantityInput) {
                quantityInput.addEventListener('input', () => {
                    this.validate();
                });
            }
            
            // Initial validation
            setTimeout(() => this.validate(), 100);
        },

        changeQuantity(delta) {
            const input = document.getElementById('product-quantity');
            if (!input) return;

            const current = parseInt(String(input.value).replace(/[^0-9-]/g, '')) || 1;
            const max = parseInt(input.getAttribute('max')) || 100;
            const min = parseInt(input.getAttribute('min')) || 1;
            
            const newValue = Math.max(min, Math.min(current + delta, max));
            input.value = newValue;
            this.validate();
        },

        validate() {
            const input = document.getElementById('product-quantity');
            if (!input) return;

            let value = parseInt(String(input.value).replace(/[^0-9-]/g, '')) || 1;
            const min = parseInt(input.getAttribute('min')) || 1;
            const max = parseInt(input.getAttribute('max')) || 100;

            value = Math.max(min, Math.min(value, max));
            input.value = value;

            // Update hidden form field for cart submission
            const formQuantityInput = document.getElementById('form-quantity');
            if (formQuantityInput) {
                formQuantityInput.value = value;
            }

            this.updateButtonStates(value, min, max);
            
            // Update price based on quantity
            PriceUpdater.updatePriceByQuantity();
        },

        updateButtonStates(value, min, max) {
            const minusBtn = document.querySelector('.quantity-minus-modern');
            const plusBtn = document.querySelector('.quantity-plus-modern');

            if (minusBtn) {
                minusBtn.disabled = (value <= min);
                minusBtn.style.opacity = (value <= min) ? '0.5' : '1';
                minusBtn.style.cursor = (value <= min) ? 'not-allowed' : 'pointer';
            }

            if (plusBtn) {
                plusBtn.disabled = (value >= max);
                plusBtn.style.opacity = (value >= max) ? '0.5' : '1';
                plusBtn.style.cursor = (value >= max) ? 'not-allowed' : 'pointer';
            }
        }
    };

    // ============================================
    // 7️⃣ CART OPERATIONS MODULE
    // ============================================
    const CartOperations = {
        init() {
            window.productAddToCart = () => this.addToCart();
            window.zidProductBuyNow = () => this.buyNow();
        },

        async addToCart() {
            const btn = document.querySelector('.btn-add-to-cart');
            if (btn?.disabled) return;

            if (typeof $ === 'undefined' || !window.zid?.cart?.addProduct) {
                this.showError('{{ _("Cart service not available") }}');
                return;
            }

            this.setLoading(true, 'add');

            // Get quantity from visible input field
            const quantityInput = document.getElementById('product-quantity');
            const quantity = quantityInput ? parseInt(quantityInput.value) || 1 : 1;
            
            // CRITICAL: Update hidden form field BEFORE submitting to ensure form reads correct quantity
            const formQuantityInput = document.getElementById('form-quantity');
            if (formQuantityInput) {
                formQuantityInput.value = quantity;
            } else {
                // If hidden field doesn't exist, create it inside the form
                const form = document.getElementById('product-form');
                if (form) {
                    const hiddenQty = document.createElement('input');
                    hiddenQty.type = 'hidden';
                    hiddenQty.id = 'form-quantity';
                    hiddenQty.name = 'quantity';
                    hiddenQty.value = quantity;
                    form.appendChild(hiddenQty);
                }
            }

            // Get product ID from form
            const productIdInput = document.getElementById('product-id');
            const productId = productIdInput ? productIdInput.value : null;

            // Build options - ALWAYS pass quantity explicitly as number
            // This ensures API uses our quantity, not form's default
            const bundlePayload = window.bundleCartPayload;
            let options;
            
            if (bundlePayload) {
                // For bundle products, override quantity in payload
                options = { ...bundlePayload };
                options.quantity = parseInt(quantity) || 1;
            } else if (productId) {
                // For regular products, pass product_id and quantity explicitly
                options = { 
                    product_id: productId,
                    quantity: parseInt(quantity) || 1
                };
                
                // Read form data manually for variants/custom fields if needed
                const form = document.getElementById('product-form');
                if (form) {
                    // Check if form has variants
                    const variantSelects = form.querySelectorAll('#product-variants-options select, #product-variants-options input[type="radio"]:checked');
                    if (variantSelects.length > 0) {
                        variantSelects.forEach(select => {
                            const name = select.name || select.getAttribute('name');
                            const value = select.value || select.getAttribute('value');
                            if (name && value) {
                                // Add variant option to options
                                if (!options.variants) options.variants = {};
                                options.variants[name] = value;
                            }
                        });
                    }
                    
                    // Check for custom input fields
                    const customFields = form.querySelectorAll('[name^="custom_input_field"]');
                    if (customFields.length > 0) {
                        customFields.forEach(field => {
                            const name = field.name;
                            const value = field.value;
                            if (name && value) {
                                if (!options.custom_input_fields) options.custom_input_fields = {};
                                options.custom_input_fields[name] = value;
                            }
                        });
                    }
                    
                    // If no variants/custom fields, we can skip form_id entirely
                    // Only use form_id as last resort if manual reading fails
                    if (!options.variants && !options.custom_input_fields) {
                        // No variants/custom fields, quantity is all we need
                    } else {
                        // We read manually, but keep form_id as backup
                        options.form_id = 'product-form';
                    }
                }
            } else {
                // Fallback: use form_id but force quantity
                options = { 
                    quantity: parseInt(quantity) || 1
                };
                
                const form = document.getElementById('product-form');
                if (form) {
                    options.form_id = 'product-form';
                }
            }

            // CRITICAL: Ensure quantity is always a number and always present
            if (!options.quantity) {
                options.quantity = parseInt(quantity) || 1;
            } else {
                options.quantity = parseInt(options.quantity) || 1;
            }

            // Debug log to verify quantity

            try {
                const response = await window.zid.cart.addProduct(options, { showErrorNotification: true });

                if (response?.item && response?.cart_items_quantity) {
                    this.handleSuccess(response);
                } else {
                    this.showError(response?.message || '{{ _("Failed to add to cart") }}');
                }
            } catch (error) {
                console.error('Add to cart error:', error);
            } finally {
                this.setLoading(false, 'add');
            }
        },

        async buyNow() {
            this.setLoading(true, 'buy');

            // Get quantity from visible input field
            const quantityInput = document.getElementById('product-quantity');
            const quantity = quantityInput ? parseInt(quantityInput.value) || 1 : 1;
            
            // CRITICAL: Update hidden form field BEFORE submitting to ensure form reads correct quantity
            const formQuantityInput = document.getElementById('form-quantity');
            if (formQuantityInput) {
                formQuantityInput.value = quantity;
            } else {
                // If hidden field doesn't exist, create it inside the form
                const form = document.getElementById('product-form');
                if (form) {
                    const hiddenQty = document.createElement('input');
                    hiddenQty.type = 'hidden';
                    hiddenQty.id = 'form-quantity';
                    hiddenQty.name = 'quantity';
                    hiddenQty.value = quantity;
                    form.appendChild(hiddenQty);
                }
            }

            // Get product ID from form
            const productIdInput = document.getElementById('product-id');
            const productId = productIdInput ? productIdInput.value : null;

            // Build options - prioritize explicit quantity
            const bundlePayload = window.bundleCartPayload;
            let options;
            
            if (bundlePayload) {
                options = { ...bundlePayload, quantity: quantity };
            } else if (productId) {
                options = { 
                    product_id: productId,
                    quantity: quantity
                };
                
                // Add form_id only if variants/custom fields exist
                const form = document.getElementById('product-form');
                if (form) {
                    const hasVariants = form.querySelector('#product-variants-options select, #product-variants-options input[type="radio"]:checked');
                    const hasCustomFields = form.querySelector('[name^="custom_input_field"]');
                    
                    if (hasVariants || hasCustomFields) {
                        options.form_id = 'product-form';
                    }
                }
            } else {
                options = { quantity: quantity };
                const form = document.getElementById('product-form');
                if (form) {
                    options.form_id = 'product-form';
                }
            }

            // Ensure quantity is always a number
            options.quantity = parseInt(quantity) || 1;

            try {
                await window.zid.cart.buyNow(options, { showErrorNotification: true });
            } catch (error) {
                console.error('Buy now error:', error);
            } finally {
                this.setLoading(false, 'buy');
            }
        },

        setLoading(isLoading, type) {
            if (typeof $ === 'undefined') return;
            
            const selectors = type === 'add' ? 
                { btn: '.btn-add-to-cart', loader: '.add-to-cart-progress', icon: '.add-to-cart-icon' } :
                { btn: '.btn-buy-now', loader: '.buy-now-progress', icon: '.buy-now-icon' };

            $(selectors.btn).prop('disabled', isLoading);
            $(selectors.loader).toggleClass('d-none', !isLoading);
            $(selectors.icon).toggleClass('d-none', isLoading);
        },

        handleSuccess(response) {
            if (typeof $ !== 'undefined') {
                $('.cart-badge').removeClass('d-none').text(response.cart_items_quantity);
                
                $('.added-notification').addClass('show');
                setTimeout(() => {
                    if (typeof $ !== 'undefined') {
                        $('.added-notification').removeClass('show');
                    }
                }, 5000);

                const image = $('#product-images-slick .slick-slide.slick-active img');
                const cart = $('.a-shopping-cart');
                if (image.length && cart.length && typeof addToCartAnimation === 'function') {
                    addToCartAnimation(cart, image);
                }
            }
            
            if (typeof fetchCart === 'function') fetchCart();

            if (typeof toastr !== 'undefined') {
                toastr.success('{{ _("Added to cart successfully") }}', '{{ _("Success") }}');
            }
        },

        showError(message) {
            if (typeof toastr !== 'undefined') {
                toastr.error(message, '{{ _("Sorry") }}');
            }
        }
    };

    // ============================================
    // 7.5️⃣ WHATSAPP ORDER MODULE
    // ============================================
    window.orderViaWhatsApp = function() {
        {% set whatsapp_number = settings.whatsapp_number if settings.whatsapp_number else (store.settings.contact.phone | replace('+', '') | replace(' ', '') | replace('-', '') if store.settings.contact.phone else '') %}
        {% if whatsapp_number %}
        const whatsappNumber = '{{ whatsapp_number }}';
        const productName = '{{ product.name | replace("'", "\\'") | replace('"', '\\"') }}';
        const productUrl = '{{ product.html_url }}';
        const quantity = document.getElementById('product-quantity') ? document.getElementById('product-quantity').value : 1;
        
        // Get selected variant options
        let variantInfo = '';
        const variantSelects = document.querySelectorAll('#product-variants-options select, #product-variants-options input[type="radio"]:checked');
        if (variantSelects.length > 0) {
            const options = [];
            variantSelects.forEach(select => {
                const label = select.closest('.form-group')?.querySelector('label')?.textContent || '';
                const value = select.value || select.getAttribute('data-value') || '';
                if (value) {
                    options.push(`${label.trim()}: ${value}`);
                }
            });
            if (options.length > 0) {
                variantInfo = '\n' + options.join('\n');
            }
        }
        
        // Get product price
        let price = '';
        const priceElement = document.querySelector('.product-price-modern, #sticky-product-price');
        if (priceElement) {
            price = priceElement.textContent.trim();
        }
        
        // Build WhatsApp message
        let message = '{{ _("Hello, I would like to order:") }}\n\n';
        message += '{{ _("Product") }}: ' + productName + '\n';
        if (variantInfo) {
            message += variantInfo + '\n';
        }
        message += '{{ _("Quantity") }}: ' + quantity + '\n';
        if (price) {
            message += '{{ _("Price") }}: ' + price + '\n';
        }
        message += '\n{{ _("Product Link") }}: ' + productUrl;
        
        // Encode message for URL
        const encodedMessage = encodeURIComponent(message);
        const whatsappUrl = 'https://wa.me/' + whatsappNumber + '?text=' + encodedMessage;
        
        // Open WhatsApp
        window.open(whatsappUrl, '_blank');
        {% else %}
        if (typeof toastr !== 'undefined') {
            toastr.error('{{ _("WhatsApp number is not configured") }}', '{{ _("Error") }}');
        }
        {% endif %}
    };

    // ============================================
    // 8️⃣ PRODUCT VARIANTS MODULE
    // ============================================
    const ProductVariants = {
        init() {
            window.productOptionsChanged = (selectedProduct) => this.onChange(selectedProduct);
            this.attachAvailabilityUpdater();
            // Wait for variant options to be available in DOM
            this.waitForOptionsAndAddImages();
        },

        waitForOptionsAndAddImages() {
            const maxAttempts = 10;
            let attempts = 0;
            
            const tryAddImages = () => {
                attempts++;
                const optionLists = document.querySelectorAll('#product-variants-options ul');
                
                if (optionLists.length > 0 && window.productData?.variants) {
                    this.addImagesToOptions();
                } else if (attempts < maxAttempts) {
                    setTimeout(tryAddImages, 200);
                }
            };
            
            // Start trying immediately, then retry if needed
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', tryAddImages);
            } else {
                setTimeout(tryAddImages, 100);
            }
        },

        onChange(selectedProduct) {
            if (!selectedProduct) {
                this.handleInvalidVariant();
                return;
            }

            if (typeof $ !== 'undefined') {
                $('#product-id').val(selectedProduct.id);
                $('.send-notify-product-id').val(selectedProduct.id);
            }

            if (selectedProduct.in_stock) {
                this.handleInStock(selectedProduct);
            } else {
                this.handleOutOfStock(selectedProduct);
            }

            // Update all dependent modules
            StickyBar.update(selectedProduct);
            this.updateProductImages(selectedProduct);
        },

        handleInStock(product) {
            // Update price
            this.updatePrice(product);

            // Update weight
            if (typeof $ !== 'undefined') {
                if (product.weight?.value) {
                    $('.div-product-weight').removeClass('d-none');
                    $('.product-weight').html(`${product.weight.value} ${product.weight.unit}`);
                } else {
                    $('.div-product-weight').addClass('d-none');
                }

                // Update SKU
                if (product.sku) {
                    $('.div-product-sku').removeClass('d-none');
                    $('.product-sku').html(product.sku);
                } else {
                    $('.div-product-sku').addClass('d-none');
                }

                // Update low stock
                const storeLowStockLimit = {{ store.settings.products.low_stock_quantity_threshold }};
                if (!product.is_infinite && product.quantity < storeLowStockLimit) {
                    $('.low-quantity-section').removeClass('d-none').addClass('d-inline-block');
                    $('.low-quantity').html('{{ _("Remaining %s only") }}'.replace('%s', product.quantity));
                } else {
                    $('.low-quantity-section').removeClass('d-inline-block').addClass('d-none');
                }

                // Update sold count
                if (product.sold_products_count) {
                    $('.product-count').removeClass('d-none').addClass('d-flex');
                    $('.product-count .lang').html('{{ _("Sold more than %s times") }}'.replace('%s', product.sold_products_count));
                } else {
                    $('.product-count').removeClass('d-flex').addClass('d-none');
                }

                // Show quantity selector
                const actualQuantity = product.is_infinite ? 100 : (parseInt(product.quantity, 10) || 0);
                if (actualQuantity > 0) {
                    $('.select-quantity-div').removeClass('d-none');
                } else {
                    $('.select-quantity-div').addClass('d-none');
                }

                // Show buttons
                $('.product-buttons').removeClass('d-none');
                $('.section-out-of-stock-notify-me').addClass('d-none');
                $('.btn-add-to-cart span').html('{{ _("add to cart") }}');
            }
        },

        handleOutOfStock(product) {
            this.updatePrice(product);

            if (typeof $ !== 'undefined') {
                if (product.sku) {
                    $('.div-product-sku').removeClass('d-none');
                    $('.product-sku').html(product.sku);
                } else {
                    $('.div-product-sku').addClass('d-none');
                }

                $('.select-quantity-div').addClass('d-none');
                $('.product-buttons').addClass('d-none');
                $('.section-out-of-stock-notify-me').removeClass('d-none');
                $('.btn-add-to-cart span').html('{{ _("Option not available") }}');
            }
        },

        handleInvalidVariant() {
            if (typeof $ !== 'undefined') {
                $('.select-quantity-div').addClass('d-none');
                $('.product-buttons').addClass('d-none');
                $('.section-out-of-stock-notify-me').removeClass('d-none');
                $('.btn-add-to-cart span').html('{{ _("Option not available") }}');
            }
        },

        updatePrice(product) {
            // Initialize price updater with new product
            PriceUpdater.init(product);
            
            if (typeof $ !== 'undefined') {
                if (product.formatted_sale_price) {
                    $('.product-formatted-price').html(product.formatted_sale_price);
                    $('.product-formatted-price-old').html(product.formatted_price);
                    $('.product-formatted-price-discount').html(`{{ _("Discount") }} ${product.discount_percentage}%`);
                } else {
                    $('.product-formatted-price').html(product.formatted_price);
                    $('.product-formatted-price-old').html('');
                    $('.product-formatted-price-discount').html('');
                }
            }
            
            // Update price based on current quantity
            PriceUpdater.updatePriceByQuantity();
        },

        updateProductImages(selectedProduct) {
            if (typeof $ === 'undefined') return;
            
            if (!selectedProduct?.media?.length) {
                $('.product-images-carousel').addClass('d-none');
                $('.product-images-carousel-thumbs').addClass('d-none-important');
                $('.product-images-empty').removeClass('d-none');
                return;
            }

            $('.product-images-carousel').removeClass('d-none');
            $('.product-images-carousel-thumbs').removeClass('d-none-important');
            $('.product-images-empty').addClass('d-none');

            const newImages = selectedProduct.media;
            const currentImages = window.productImages || [];
            
            const imagesChanged = newImages.length !== currentImages.length ||
                newImages.some((img, idx) => {
                    const current = currentImages[idx];
                    return !current || img.image?.full_size !== current.image?.full_size;
                });

            if (imagesChanged) {
                window.productImages = newImages;
                SlickCarousel.rebuild(newImages);
            }
        },


        attachAvailabilityUpdater() {
            if (STATE.availabilityUpdaterAttached) return;

            const updateAvailability = Utils.debounce(() => {
                if (!window.productData?.variants) return;

                const variants = window.productData.variants;
                const variantsData = variants.map(v => {
                    const quantity = parseInt(v.quantity, 10) || 0;
                    const isInfinite = v.is_infinite === true || v.is_infinite === 'true';
                    const inStock = v.in_stock !== false;
                    // A variant is out of stock if: in_stock is false OR (quantity is 0 and not infinite)
                    const isOutOfStock = !inStock || (!isInfinite && quantity <= 0);
                    
                    return {
                        attributes: (v.attributes || []).map(attr => 
                            (typeof attr === 'object' && attr?.value) ? attr.value : attr
                        ),
                        inStock: !isOutOfStock
                    };
                });

                const optionGroups = document.querySelectorAll('.size-box .form-group');
                if (!optionGroups.length) return;

                const currentSelections = [];
                
                optionGroups.forEach((group, idx) => {
                    const selected = group.querySelector('li.selected, li.active, li[aria-selected="true"]');
                    currentSelections[idx] = selected?.getAttribute('value') || null;
                });

                optionGroups.forEach((group, groupIndex) => {
                    group.querySelectorAll('li').forEach(li => {
                        const value = li.getAttribute('value');
                        if (!value) return;

                        // Method 1: Check variants matching current selections (for dependent options)
                        const testSelections = [...currentSelections];
                        testSelections[groupIndex] = value;

                        const matchedVariants = variantsData.filter(v => {
                            if (v.attributes[groupIndex] !== value) return false;
                            for (let i = 0; i < testSelections.length; i++) {
                                if (i === groupIndex) continue;
                                if (testSelections[i] && v.attributes[i] !== testSelections[i]) {
                                    return false;
                                }
                            }
                            return true;
                        });

                        // Method 2: Check ALL variants with this option value (regardless of other selections)
                        const allVariantsWithThisValue = variantsData.filter(v => 
                            v.attributes[groupIndex] === value
                        );

                        // An option is out of stock if:
                        // 1. There are no variants with this value at all, OR
                        // 2. ALL variants with this value are out of stock, OR
                        // 3. When considering current selections, all matched variants are out of stock
                        const allOutOfStock = 
                            (allVariantsWithThisValue.length === 0) ||
                            (allVariantsWithThisValue.length > 0 && allVariantsWithThisValue.every(v => !v.inStock)) ||
                            (matchedVariants.length > 0 && matchedVariants.every(v => !v.inStock));

                        li.classList.toggle('out-of-stock-option', allOutOfStock);
                    });
                });
            }, CONFIG.quantityDebounceDelay);

            // Initial update
            setTimeout(updateAvailability, 50);

            // Listen to option changes - use debounced handler to prevent multiple calls
            const self = this;
            const debouncedAddImages = Utils.debounce(() => {
                // Only add images if not already added
                if (!STATE.imagesToOptionsAdded) {
                    self.addImagesToOptions();
                }
            }, 200);
            
            const handleOptionChange = () => {
                updateAvailability();
                debouncedAddImages();
            };
            
            document.addEventListener('vitrin:product-option:changed', handleOptionChange);
            
            const sizeBox = document.querySelector('.size-box');
            if (sizeBox) {
                sizeBox.addEventListener('click', e => {
                    // Update color name display on click
                if (clickedLi) {
                        handleOptionChange();
                    const parentUl = clickedLi.closest('ul');
                    if (parentUl) {
                        const parentGroup = parentUl.closest('.form-group');
                        if (parentGroup && parentGroup.classList.contains('is-color-option')) {
                            const colorNameSpan = parentGroup.querySelector('.selected-color-name');
                            if (colorNameSpan) {
                                colorNameSpan.textContent = clickedLi.getAttribute('value') || '';
                            }
                        }
                    }
                }
                }, true);
            }

            STATE.availabilityUpdaterAttached = true;
        },

        getDefaultProductImage() {
            const selectedProduct = window.productData?.selected_product || window.productData;
            return selectedProduct?.media?.[0]?.image?.medium || 
                   selectedProduct?.media?.[0]?.image?.full_size ||
                   window.productData?.media?.[0]?.image?.medium ||
                   null;
        },

        addImagesToOptions() {
            // Prevent duplicate calls
            if (STATE.addImagesToOptionsInProgress) return;
            
            if (!window.productData?.variants) {
                // Retry after a short delay if variants not yet loaded
                setTimeout(() => {
                    if (window.productData?.variants && !STATE.imagesToOptionsAdded) {
                        this.addImagesToOptions();
                    }
                }, 500);
                return;
            }

            STATE.addImagesToOptionsInProgress = true;

            const variants = window.productData.variants;
            const defaultImage = this.getDefaultProductImage();
            if (!defaultImage) {
                STATE.addImagesToOptionsInProgress = false;
                return;
            }

            // Find all variant option list items
            const optionLists = document.querySelectorAll('#product-variants-options ul');
            if (!optionLists.length) {
                STATE.addImagesToOptionsInProgress = false;
                return;
            }
            
            let imagesAdded = 0;
            const getOptionName = (opt) => {
                if (!opt) return '';
                const raw = opt.name ?? opt.title ?? opt.label ?? opt;
                if (typeof raw === 'string') return raw;
                if (typeof raw === 'object' && raw) {
                    return raw.ar || raw.en || raw[window.appLang] || raw[window.storeLang] || '';
                }
                return '';
            };

            optionLists.forEach((ul, optionIndex) => {
                // Limit images to the Color/اللون option group only
                const optionName = getOptionName(window.productOptionsData?.[optionIndex]).trim().toLowerCase();
                const isColorGroup = optionName === 'color' || optionName === 'اللون';
                if (!isColorGroup) return;

                const group = ul.closest('.form-group') || ul.parentElement;
                if (group) group.classList.add('is-color-option');

                // Add selected color name display span next to the label
                const label = group.querySelector('label');
                console.log(label)
                if (label && !label.querySelector('.selected-color-name')) {
                    const colorNameSpan = document.createElement('span');
                    colorNameSpan.className = 'selected-color-name';
                    colorNameSpan.style.cssText = 'color: #666666; margin-inline-start: 6px; font-weight: 400;';
                    label.appendChild(colorNameSpan);
                }

                const listItems = ul.querySelectorAll('li');
                
                listItems.forEach((li) => {
                    // Skip if image already added
                    if (li.querySelector('.variant-option-image')) return;

                    const optionValue = li.getAttribute('value');
                    if (!optionValue) return;

                    // Find matching variant(s) for this option value
                    const matchingVariants = variants.filter(v => {
                        const attributes = (v.attributes || []).map(attr => 
                            (typeof attr === 'object' && attr?.value) ? attr.value : attr
                        );
                        return attributes.includes(optionValue);
                    });

                    // Get image from first matching variant that has media, or use default
                    let variantImage = defaultImage;
                    for (const variant of matchingVariants) {
                        if (variant.media && variant.media.length > 0) {
                            variantImage = variant.media[0].image?.medium || 
                                         variant.media[0].image?.small ||
                                         variant.media[0].image?.full_size;
                            if (variantImage) break;
                        }
                    }

                    if (variantImage) {
                        // Create image wrapper
                        const imageWrapper = document.createElement('div');
                        imageWrapper.className = 'variant-option-image-wrapper';
                       
                        const img = document.createElement('img');
                        img.className = 'variant-option-image';
                        img.src = variantImage;
                        img.alt = optionValue;
                        img.loading = 'lazy'; 
                        img.onerror = function() {
                            // If image fails to load, hide the wrapper
                            this.parentElement.style.display = 'none';
                        };
                        
                        imageWrapper.appendChild(img);
                        
                        // Insert image before the span
                        li.appendChild(imageWrapper);
                        
                        li.classList.add('has-variant-option-image');
                        imagesAdded++;
                    }
                });
            });
            
            if (imagesAdded > 0) {
                STATE.imagesToOptionsAdded = true;
            }

            // Set initial selected color name if one is already selected
            optionLists.forEach((ul, optionIndex) => {
                const optionName = getOptionName(window.productOptionsData?.[optionIndex]).trim().toLowerCase();
                if (optionName !== 'color' && optionName !== 'اللون') return;

                const group = ul.closest('.form-group') || ul.parentElement;
                if (!group) return;

                const selectedLi = ul.querySelector('li.selected, li.active, li[aria-selected="true"]');
                if (selectedLi) {
                    const colorNameSpan = group.querySelector('.selected-color-name');
                    if (colorNameSpan) {
                        colorNameSpan.textContent = selectedLi.getAttribute('value') || '';
                    }
                }
            });

            STATE.addImagesToOptionsInProgress = false;
        }
    };

    // ============================================
    // 9️⃣ SLICK CAROUSEL MODULE
    // ============================================
    const SlickCarousel = {
        init(productImages) {
            if (!productImages?.length) return;

            const $slick = $('#product-images-slick');
            if (!$slick.length || $slick.is(':hidden')) return;

            // Initialize slider on all devices
            if (!$slick.hasClass('slick-initialized')) {
                this.build($slick, productImages);
                STATE.slickInitialized = true;
            }
        },

        destroy() {
            const $slick = $('#product-images-slick');
            if ($slick.length && $slick.hasClass('slick-initialized')) {
                try {
                    $slick.slick('unslick');
                } catch (e) {
                    $slick.removeClass('slick-initialized');
                }
            }
            STATE.slickInitialized = false;
        },

        build($slick, productImages) {
            const isRTL = window.appDirection !== 'ltr';
            const arrowNext = isRTL ? 'icon-keyboard_arrow_left' : 'icon-keyboard_arrow_right';
            const arrowPrev = isRTL ? 'icon-keyboard_arrow_right' : 'icon-keyboard_arrow_left';

            try {
                $slick.slick({
                    infinite: false,
                    autoplay: false,
                    arrows: false,
                    dots: true,
                    rtl: isRTL,
                    slidesToShow: 1,
                    slidesToScroll: 1,
                    nextArrow: `<button class="slick-next slick-arrow" type="button"><span class="${arrowNext}"></span></button>`,
                    prevArrow: `<button class="slick-prev slick-arrow" type="button"><span class="${arrowPrev}"></span></button>`
                });

                this.attachEvents($slick);
            } catch (e) {
                console.error('Slick init error:', e);
            }
        },

        rebuild(productImages) {
            if (!productImages?.length) return;

            const $slick = $('#product-images-slick');
            if (!$slick.length) return;

            const wasInitialized = $slick.hasClass('slick-initialized');
            
            if (wasInitialized) {
                this.destroy();
            }

            $slick.html('');
            $('.product-images-carousel-thumbs').html('');

            productImages.forEach((img, idx) => {
                if (!img?.image?.full_size) return;

                const mainHtml = `<div>
                    <div class="product-detail-image-wrapper" style="position: relative; overflow: hidden;">
                        <a class="image-link" style="display:block; width: 100%; height: 100%;">
                            <img src="${img.image.full_size}" class="carousel-img product-detail-img-main" alt="${img.alt_text || ''}">
                            ${img.provider && img.link ? `<img class="play-icon" src="{{ 'video-play.svg' | asset_url }}" alt="play" onclick="showIframe(this, '${img.link.replace(/'/g, "\\'")}')"/>` : ''}
                        </a>
                        <div class="iframe-video pt-1 d-none">
                            <a id="iframe-close-btn" type="button" class="text-white btn btn-none grow" onClick="hideIframe(this)">X</a>
                            <iframe width="100%" height="100%" src="" frameborder="0" allowfullscreen></iframe>
                        </div>
                    </div>
                </div>`;

                const thumbHtml = `<div class="image_thumb">
                    <a class="d-flex align-items-center justify-content-center thumb-image-a ${idx === 0 ? 'active-thumb' : ''}" data-index="${idx}">
                        <img src="${img.image.medium || img.image.full_size}" data-index="${idx}">
                        ${img.provider && img.link ? `<img class="play-icon" src="{{ 'video-play.svg' | asset_url }}" alt="play" data-index="${idx}"/>` : ''}
                    </a>
                </div>`;

                $slick.append(mainHtml);
                $('.product-images-carousel-thumbs').append(thumbHtml);
            });

            this.init(productImages);
            // Re-initialize slider on mobile if needed
            const isMobile = window.innerWidth <= 768;
            if (isMobile) {
                setTimeout(() => this.init(productImages), 100);
            }
        },

        attachEvents($slick) {
            $slick.off('init beforeChange afterChange');
            
            $slick.on('init', (event, slick) => {
                $('.product-images-carousel').removeClass('product-images-carousel-init');
                // Set initial active thumb
                $('.product-images-carousel-thumbs .thumb-image-a').removeClass('active-thumb');
                $('.product-images-carousel-thumbs .thumb-image-a[data-index="0"]').addClass('active-thumb');
                
                // Fix aria-hidden issue: Remove focus from hidden slides
                this.fixAriaHidden(slick);
            });

            $slick.on('beforeChange', (event, slick, currentSlide, nextSlide) => {
                const iframe = slick.$slides[currentSlide]?.querySelector('.iframe-video');
                if (iframe) {
                    $(iframe).addClass('d-none').find('iframe').attr('src', '');
                }
                
                // Remove focus from current slide before hiding it
                const currentSlideEl = slick.$slides[currentSlide];
                if (currentSlideEl) {
                    const focusedEl = currentSlideEl.querySelector(':focus');
                    if (focusedEl) {
                        focusedEl.blur();
                    }
                }
            });

            $slick.on('afterChange', (event, slick, currentSlide) => {
                const iframe = slick.$slides[currentSlide]?.querySelector('.iframe-video');
                if (iframe) {
                    const playIcon = $(iframe).siblings('.image-link').find('.play-icon');
                    if (playIcon.length) playIcon.click();
                }
                // Update active thumb class
                $('.product-images-carousel-thumbs .thumb-image-a').removeClass('active-thumb');
                $('.product-images-carousel-thumbs .thumb-image-a[data-index="' + currentSlide + '"]').addClass('active-thumb');
                
                // Fix aria-hidden issue after slide change
                this.fixAriaHidden(slick);
            });
        },

        fixAriaHidden(slick) {
            // Ensure focused elements are not in aria-hidden slides
            if (!slick || !slick.$slides) return;
            
            try {
                const activeIndex = slick.currentSlide || 0;
                // slick.$slides is a jQuery object, not an array - use jQuery each or convert to array
                const $slides = $(slick.$slides);
                
                $slides.each((index, slide) => {
                    if (slide) {
                        const isActive = index === activeIndex;
                        const isHidden = slide.getAttribute('aria-hidden') === 'true';
                        
                        // If slide is hidden but has focused element, blur it
                        if (isHidden && !isActive) {
                            const focusedEl = slide.querySelector(':focus');
                            if (focusedEl) {
                                focusedEl.blur();
                            }
                        }
                    }
                });
            } catch (e) {
                // Silently fail if slick is not fully initialized
                console.debug('fixAriaHidden error:', e);
            }
        }
    };


    // ============================================
    // 1️⃣1️⃣ SALE COUNTDOWN TIMER
    // ============================================
    const SaleCountdown = {
        init() {
            const timer = document.querySelector('.sale-countdown-timer-detail');
            if (!timer) return;

            const endDate = new Date(timer.getAttribute('data-end-date'));
            if (isNaN(endDate.getTime())) return;

            const elements = {
                days: timer.querySelector('.countdown-value-detail-days'),
                hours: timer.querySelector('.countdown-value-detail-hours'),
                minutes: timer.querySelector('.countdown-value-detail-minutes'),
                seconds: timer.querySelector('.countdown-value-detail-seconds')
            };

            if (!Object.values(elements).every(el => el)) return;

            const update = () => {
                const diff = endDate.getTime() - Date.now();
                
                if (diff <= 0) {
                    timer.style.display = 'none';
                    return false;
                }

                const days = Math.floor(diff / (1000 * 60 * 60 * 24));
                const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
                const seconds = Math.floor((diff % (1000 * 60)) / 1000);

                elements.days.textContent = String(days).padStart(2, '0');
                elements.hours.textContent = String(hours).padStart(2, '0');
                elements.minutes.textContent = String(minutes).padStart(2, '0');
                elements.seconds.textContent = String(seconds).padStart(2, '0');

                return true;
            };

            update();
            const interval = setInterval(() => {
                if (!update()) clearInterval(interval);
            }, 1000);

            STATE.intervals.push(interval);
        }
    };


    // ============================================
    // 1️⃣3️⃣ OUT OF STOCK NOTIFICATION
    // ============================================
    const OutOfStockNotify = {
        init() {
            window.sendProductNotifyMe = () => this.send();
        },

        async send() {
            const progressEl = $('.send-notify-progress');
            progressEl.removeClass('d-none');

            const countryCode = '+' + ($('.send-notify-country-key').val() || '966');
            const productId = $('.send-notify-product-id').val();
            const email = $('.send-notify-email').val();
            const name = $('.send-notify-name').val();
            const rawPhone = $('.send-notify-phone').val();
            const phone = rawPhone ? countryCode + rawPhone : '';

            const payload = {
                customer_email: email,
                customer_phone_number: phone,
                customer_name: name
            };

            const url = `{{ store.permalink }}api/v1/products/${encodeURIComponent(productId)}/stock-alerts`;

            try {
                const res = await fetch(url, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                if (res.ok) {
                    if (typeof toastr !== 'undefined') {
                        toastr.success('{{ _("Send Successfully") }}');
                    }
                } else {
                    const errData = await res.json().catch(() => null);
                    const msg = errData?.data?.message || errData?.detail || `HTTP ${res.status}`;
                    if (typeof toastr !== 'undefined') {
                        toastr.error(msg, '{{ _("Sorry") }}');
                    }
                }
            } catch (error) {
                if (typeof toastr !== 'undefined') {
                    toastr.error('{{ _("Failed to send alert request") }}', '{{ _("Sorry") }}');
                }
            } finally {
                progressEl.addClass('d-none');
            }
        }
    };

    // ============================================
    // 1️⃣4️⃣ EVENT LISTENERS
    // ============================================
    const EventListeners = {
        init() {
            if (STATE.eventListenersAttached) return;

            // Thumbnail clicks
            if (typeof $ !== 'undefined') {
                $(document).on('click', '.thumb-image-a, #video-play-icon', function(e) {
                    const $target = $(e.target);
                    const $thumbLink = $target.closest('.thumb-image-a');
                    const index = $thumbLink.length ? $thumbLink.attr('data-index') : $target.attr('data-index');
                    
                    if (index !== undefined && $('#product-images-slick').hasClass('slick-initialized')) {
                        // Update active thumb class
                        $('.product-images-carousel-thumbs .thumb-image-a').removeClass('active-thumb');
                        $('.product-images-carousel-thumbs .thumb-image-a[data-index="' + index + '"]').addClass('active-thumb');
                        // Change slide
                        $('#product-images-slick').slick('slickGoTo', parseInt(index), true);
                    }
                });
            }

            // Image lightbox
            // Prevent focus on hidden slides to avoid aria-hidden warnings
            if (typeof $ !== 'undefined') {
                $(document).on('focus', '#product-images-slick .image-link', function() {
                    const $slide = $(this).closest('.slick-slide');
                    if ($slide.attr('aria-hidden') === 'true') {
                        // If trying to focus on hidden slide, blur it
                        $(this).blur();
                        // Focus on active slide instead
                        const $activeSlide = $('#product-images-slick .slick-slide[aria-hidden="false"]');
                        if ($activeSlide.length) {
                            $activeSlide.find('.image-link').first().focus();
                        }
                    }
                });
            }

            if (typeof $ !== 'undefined') {
                $(document).on('click', '#product-images-slick .image-link :not(#main-video-icon)', function() {
                    $('.pswp').removeClass('d-hide');
                    $('.app').addClass('d-hide');

                    if (!window.productImages || !Array.isArray(window.productImages)) return;

                    const images = window.productImages.map(img => img?.image?.full_size).filter(Boolean);
                    const currentIndex = parseInt($('#product-images-slick .slick-active').attr('data-slick-index')) || 0;
                    
                    if (typeof openPhotoSwiper === 'function' && images.length > 0) {
                        openPhotoSwiper(images, currentIndex);
                    }
                });
            }

            // Bundle selections
            window.addEventListener('vitrin:bundle-selections:updated', (e) => {
                const { cartPayload, isSelectionsValid } = e?.detail?.data || {};
                window.bundleCartPayload = cartPayload;

                const addToCartBtn = document.querySelector('.btn-add-to-cart');
                const buyNowBtn = typeof $ !== 'undefined' ? $('.btn-buy-now') : null;

                if (addToCartBtn) {
                    addToCartBtn.disabled = !isSelectionsValid;
                    addToCartBtn.classList.toggle('disabled', !isSelectionsValid);
                }
                if (buyNowBtn && buyNowBtn.length) {
                    buyNowBtn.prop('disabled', !isSelectionsValid);
                }
            });

            // Customer data for notification
            document.addEventListener('zid-customer-fetched', (e) => {
                if (typeof $ === 'undefined') return;
                
                const customer = e.detail.customer;
                if (customer?.mobile) {
                    $('.send-notify-name').val(customer.name || '');
                    $('.send-notify-email').val(customer.email || '');
                    $('.send-notify-country-key').val(customer.mobile.substring(0, 3) || '966');
                    $('.send-notify-phone').val(customer.mobile.substring(3) || '');
                }
            });

            STATE.eventListenersAttached = true;
        }
    };

    // ============================================
    // 1️⃣5️⃣ VIDEO HELPERS
    // ============================================
    window.getIframeLink = (videoLink) => {
        if (!videoLink) return null;
        const match = videoLink.match(/(?:youtube\.com\/(?:[^\/\n\s]+\/\S+\/|(?:v|e(?:mbed)?|.*[?&]v=)|shorts\/)|youtu\.be\/)([a-zA-Z0-9_-]{11})/);
        return match?.[1] ? `https://www.youtube.com/embed/${match[1]}?autoplay=1&enablejsapi=1` : null;
    };

    window.showIframe = (elm, videoSrc) => {
        if (!elm || !videoSrc || typeof $ === 'undefined') return;
        const iframeLink = window.getIframeLink(videoSrc);
        if (!iframeLink) return;

        const $iframe = $(elm).parent('.image-link').siblings('.iframe-video');
        $iframe.removeClass('d-none').find('iframe').attr('src', iframeLink);
    };

    window.hideIframe = (elm) => {
        if (!elm || typeof $ === 'undefined') return;
        $(elm).parent('.iframe-video').addClass('d-none').find('iframe').attr('src', '');
    };

    // ============================================
    // 1️⃣6️⃣ RELATED PRODUCTS SLIDER
    // ============================================
    window.showRelatedProducts = () => {
        const $relatedProducts = $('#related-products.products-slider');
        
        // Check if element exists and if slick is available
        if (!$relatedProducts.length || typeof $ === 'undefined' || !$.fn.slick) {
            return;
        }
        
        // Check if already initialized
        if ($relatedProducts.hasClass('slick-initialized')) {
            return;
        }
        
        const isRTL = window.appDirection !== 'ltr';
        const arrowNext = isRTL ? 'icon-keyboard_arrow_left' : 'icon-keyboard_arrow_right';
        const arrowPrev = isRTL ? 'icon-keyboard_arrow_right' : 'icon-keyboard_arrow_left';

        try {
            $relatedProducts.slick({
                slidesToShow: 5,
                slidesToScroll: 1,
                infinite: false,
                autoplay: false,
                arrows: true,
                dots: false,
                rtl: isRTL,
                nextArrow: `<button class="slick-next slick-arrow" type="button"><span class="${arrowNext}"></span></button>`,
                prevArrow: `<button class="slick-prev slick-arrow" type="button"><span class="${arrowPrev}"></span></button>`,
                responsive: [
                    {
                        breakpoint: 1200,
                        settings: {
                            slidesToShow: 4,
                            slidesToScroll: 1,
                        }
                    },
                    {
                        breakpoint: 992,
                        settings: {
                            slidesToShow: 3,
                            slidesToScroll: 1,
                        }
                    },
                    {
                        breakpoint: 577,
                        settings: {
                            slidesToShow: 2,
                            slidesToScroll: 1,
                        }
                    }
                ]
            });
        } catch (e) {
            console.error('Error initializing related products slider:', e);
        }
    };

    // ============================================
    // 1️⃣7️⃣ MAIN INITIALIZATION
    // ============================================
    function init() {
        // Initialize global variables
        window.productImages = {{ product.selected_product.media | tojson }};
        window.customerWishlistIds = {{ customer.wishlist | tojson if customer else '[]' }};
        window.productData = {{ product | tojson }};

        // Initialize all modules
        StickyBar.init();
        QuantityControls.init();
        CartOperations.init();
        ProductVariants.init();
        SaleCountdown.init();
        OutOfStockNotify.init();
        EventListeners.init();

        // Images to options are now handled in ProductVariants.init() - no need to call again

        // Initialize Slick if images exist
        if (window.productImages?.length) {
            SlickCarousel.init(window.productImages);
            
            // Handle window resize - only attach once
            if (!STATE.resizeHandlerAttached) {
                let resizeTimer;
                window.addEventListener('resize', () => {
                    clearTimeout(resizeTimer);
                    resizeTimer = setTimeout(() => {
                        if (window.productImages?.length) {
                            SlickCarousel.init(window.productImages);
                        }
                    }, 250);
                });
                STATE.resizeHandlerAttached = true;
            }
        }

        // Fill wishlist items
        if (window.customerWishlistIds?.length && typeof fillWishlistItems === 'function') {
            fillWishlistItems(window.customerWishlistIds.map(id => ({ id })));
        }

        // Initial updates
        if (window.productData?.selected_product) {
            // Initialize price updater with initial product
            PriceUpdater.init(window.productData.selected_product);
            
            StickyBar.update(window.productData.selected_product);
            QuantityIndicator.update(window.productData.selected_product);
            StockLocations.update(window.productData.selected_product);
        }

        // Show buy now button if product is in stock (for both guests and customers)
        if (window.productData?.selected_product?.in_stock) {
            $('.btn-buy-now, #sticky-buy-now').removeClass('d-none');
        }

        // Initialize related products slider
        if (typeof window.showRelatedProducts === 'function') {
            window.showRelatedProducts();
        }
    }


    // ============================================
    // 1️⃣8️⃣ CLEANUP ON PAGE UNLOAD
    // ============================================
    window.addEventListener('beforeunload', () => {
        STATE.intervals.forEach(clearInterval);
        STATE.observers.forEach(observer => observer.disconnect());
    });

    // ============================================
    // 1️⃣9️⃣ START APPLICATION
    // ============================================
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
    } else {
        init();
    }

    // Window load event for final checks
    $(window).on('load', () => {
        // Show buy now button if product is in stock (for both guests and customers)
        if (window.productData?.selected_product?.in_stock) {
            $('.btn-buy-now, #sticky-buy-now').removeClass('d-none');
        }

        if (window.productData?.selected_product) {
            StickyBar.update(window.productData.selected_product);
            QuantityIndicator.update(window.productData.selected_product);
            StockLocations.update(window.productData.selected_product);
        }
    });

})();   </script>

{% endblock %}
