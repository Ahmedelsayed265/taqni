        function initSlick(productImages) {
            if (!productImages || !Array.isArray(productImages)) {
                return;
            }

            if (typeof window.jQuery === 'undefined' || !window.jQuery.fn || !window.jQuery.fn.slick) {
                return;
            }

            var $ = window.jQuery;
            var $slider = $('#product-images-slick');
            if (!$slider.length || $slider.hasClass('slick-initialized')) {
                return;
            }

            var arrowNextClass, arrowPrevClass;
            if (window.appDirection === 'ltr') {
                arrowNextClass = 'icon-keyboard_arrow_right';
                arrowPrevClass = 'icon-keyboard_arrow_left';
            } else {
                arrowNextClass = 'icon-keyboard_arrow_left';
                arrowPrevClass = 'icon-keyboard_arrow_right';
            }

            $slider.slick({
                infinite: false,
                autoplay: false,
                arrows: false,
                dots: (productImages.length > 1),
                rtl: !(window.appDirection === 'ltr'),
                nextArrow: '<button class="slick-next slick-arrow" aria-label="{{ _('Next') | e }}" type="button"><span class="' + arrowNextClass + '"></span></button>',
                prevArrow: '<button class="slick-prev slick-arrow" aria-label="{{ _('Previous') | e }}" type="button"><span class="' + arrowPrevClass + '"></span></button>'
            });
